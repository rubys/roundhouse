/target
/tools/compare/target
/_site
/build
/downloads
*.swp

# Local debug/repro binaries — produced ad-hoc during development
# (e.g. one-off compiled reproductions for analyzer issues). Not
# tracked; recreatable on demand.
/repro_*
/probe_*

# Real-blog fixture is regenerated from scripts/create-blog on
# developer machines (`make real-blog`) and in CI. Committing the
# output would mean the repo carries a ~50MB Rails scaffold that
# drifts whenever Rails versions bump — easier to produce it fresh.
/fixtures/real-blog
# Rails 8.0 sibling fixture for the rails-jruby baseline (scripts/bench
# generates it on demand; same regenerate-don't-commit rationale).
/fixtures/real-blog-rails80
/.claude/

# scripts/bench output — per-run timestamps + summaries. Keep the
# harness in git, drop the measurement artifacts.
/bench/results/
/storage

# Python bytecode cache from the python target's runtime, and the
# scratch dir used for ad-hoc emit/transpile output during dev.
/runtime/python/__pycache__/
/tmp/
