# Pins @seconds (and every unit constructor's n) to Integer so the
# temporal arithmetic in ago/from_now stays Time-typed under AOT
# inference — an untyped @seconds widens `Time.now.utc - @seconds` to
# poly, which the declared Time return then contradicts. Corpus units
# are integral (45, minutes(5), 70.days); fractional durations would
# need a widening here first.
module ActiveSupport
  class Duration
    @seconds: Integer

    def initialize: (Integer seconds) -> void
    def self.seconds: (Integer n) -> Duration
    def self.second: (Integer n) -> Duration
    def self.minutes: (Integer n) -> Duration
    def self.minute: (Integer n) -> Duration
    def self.hours: (Integer n) -> Duration
    def self.hour: (Integer n) -> Duration
    def self.days: (Integer n) -> Duration
    def self.day: (Integer n) -> Duration
    def self.weeks: (Integer n) -> Duration
    def self.week: (Integer n) -> Duration
    def self.fortnights: (Integer n) -> Duration
    def self.fortnight: (Integer n) -> Duration
    def self.months: (Integer n) -> Duration
    def self.month: (Integer n) -> Duration
    def self.years: (Integer n) -> Duration
    def self.year: (Integer n) -> Duration
    def ago: () -> Time
    def until: () -> Time
    def from_now: () -> Time
    def since: () -> Time
    def to_i: () -> Integer
    def to_f: () -> Float
    def to_s: () -> String
    def seconds: () -> Integer
  end
end
