# Typing contract for the ruby-family ViewHelpers extensions.
module ActionView
  module ViewHelpers
    def self.content_security_policy_nonce: () -> String
    def self.class_names: (*untyped args) -> String
    def self.number_with_delimiter: (Integer value) -> String
    def self.sanitize_to_id: (String name) -> String
    def self.number_with_precision: (untyped value, ?precision: Integer) -> String
    def self.number_to_human: (untyped value, ?format: String) -> String
  end
end
