# View helpers — module functions invoked from Views::* render
# methods. Surface tracks what real-blog actually uses (link_to,
# button_to, form_with, dom_id, content_for slots, importmap tags,
# turbo_stream_from, truncate, html_escape).
#
# `module_function` means each `def` is callable both as
# `ViewHelpers.foo(...)` and as `foo(...)` from inside a module that
# has `extend ViewHelpers`. We declare them as `self.` methods —
# the call sites in spinel-blog use the qualified form.
module ActionView
  module ViewHelpers
    # ── slot store (content_for / yield) ────────────────────────────
    # Module-level @slots holds the slot hash. Declared as a method
    # signature for the body-typer so reads like `@slots[slot]`
    # resolve through the instance_methods table; the actual write
    # happens at module-eval time (`@slots = {}`) and via
    # content_for_set.
  
    def self.reset_slots!: () -> void
    def self.content_for_set: (Symbol slot, String value) -> void
    def self.content_for_get: (Symbol slot) -> String?
    def self.get_slot: (Symbol slot) -> String
    def self.get_yield: () -> String
    def self.set_yield: (String content) -> void
  
    # ── escaping / formatting ───────────────────────────────────────

    # Monomorphic by design: callers stringify before passing in. The
    # body has no nil/Symbol coercion — every input is already a
    # String. Internal callers (render_attrs, text_area) wrap their
    # potentially-non-String values with `.to_s` at the call site
    # rather than forcing html_escape to handle every shape. Trades
    # caller-side discipline for a far simpler dispatch profile every
    # backend compiler (V8, YJIT, ZJIT, Spinel, rustc) can specialize
    # against.
    def self.html_escape: (String s) -> String

    # Same monomorphization rationale as html_escape: callers handle
    # nil/non-String coercion explicitly. Real-blog's only caller
    # passes `article.body` (typed String per the model RBS) so the
    # contraction lands without source churn.
    def self.truncate: (String s, ?length: Integer, ?omission: String) -> String
  
    # ── DOM helpers ─────────────────────────────────────────────────
    # Monomorphic record-shape: dom_id takes an ActiveRecord::Base
    # subclass instance (was String|Base; the String case is contracted
    # away — callers wanting "article_42" spell it directly). Two call
    # shapes:
    #   dom_id(record)                  -> "article_42"
    #   dom_id(record, :comments_count) -> "comments_count_article_42"
    #
    # The per-model class name reaches dom_id through `record.dom_prefix`
    # — a synthesized per-model instance method (lowerer-emitted, see
    # `push_dom_prefix_method` in model_to_library). This replaces the
    # previous `record_dom_prefix(record)` helper that called
    # `record.class.name.downcase` (runtime introspection).
    def self.dom_id: (ActiveRecord::Base record, ?Symbol? suffix) -> String
  
    # ── HTML element helpers ────────────────────────────────────────
    # `text` is the link/button label — typed String (was untyped).
    # Callers passing a record or other value handle the stringify at
    # the call site. `href` is the URL path. `opts` is the attribute
    # hash (Symbol or String keys; values flatten through render_attrs).
    def self.link_to: (String text, String href, ?Hash[Symbol, untyped] opts) -> String
    def self.button_to: (String text, String href, ?Hash[Symbol, untyped] opts) -> String
  
    def self.csrf_meta_tags: () -> String
    def self.csp_meta_tag: () -> String
  
    # `name` is the asset stem (e.g., "application" → /assets/application.css).
    def self.stylesheet_link_tag: (String name, ?Hash[Symbol, untyped] opts) -> String
  
    # `pins` is the importmap pin array — each entry a record with
    # fixed `:name` and `:path` fields. Record (not `Hash[Symbol,
    # String]`) so strict-typed targets see the literal shape: the
    # lowerer emits `{name: ..., path: ...}` which Crystal parses
    # as `NamedTuple(name: String, path: String)`. When nil/empty,
    # falls back to a Turbo-only shape. `entry` is the JS module
    # entrypoint name.
    def self.javascript_importmap_tags: (
      ?Array[{ name: String, path: String }]? pins,
      ?String entry
    ) -> String
  
    # `stream` is genuinely polymorphic — Rails' turbo_stream_from
    # accepts a String channel name OR an Array (composed channel).
    # JSON.generate handles either, so untyped here.
    def self.turbo_stream_from: (untyped stream) -> String
  
    # ── form_with primitives ───────────────────────────────────────
    # Small typed-scalar helpers callable from macro-inlined form_with
    # expansions. See view_helpers.rb for the runtime/macro split
    # rationale.
    def self.csrf_token_hidden_input: () -> String
    def self.method_override_input: (Symbol method) -> String
    def self.optional_value_attr: (String? value) -> String
    def self.escape_or_empty: (String? value) -> String

    # ── form_with ───────────────────────────────────────────────────
    # `model` is the record (Base subclass instance); `model_name` is
    # the form-prefix string ("article", "comment"); `action` is the
    # submit URL; `method` is :get / :post / :patch / :delete; `opts`
    # is the form-attribute hash. Block yields a FormBuilder; block
    # returns the form body String. Body-typer threads the block
    # return through the form-wrapping concatenation.
    #
    # `model` typed `ActiveRecord::Base` — the param flows straight
    # into `FormBuilder.new(model, ...)`, whose constructor declares
    # Base; an `untyped` here forces strict-typed targets to bridge
    # `Value → Base` at the call site (no real coercion exists).
    # Real-blog callers always pass a Base subclass, so the tighter
    # signature matches actual usage.
    def self.form_with: (
      model: ActiveRecord::Base,
      model_name: String,
      action: String,
      ?method: Symbol,
      ?opts: Hash[Symbol, untyped]
    ) { (FormBuilder) -> String } -> String
  
    # ── attribute rendering (public for FormBuilder) ────────────────
    # `attrs` is a Hash whose keys are Symbol or String and whose
    # values are String/Integer/nil/Hash (nested for data:/aria:).
    # In transpile, callers funnel through a merge helper (rust2's
    # `merge_attrs`, TS spread, Crystal NamedTuple→Hash) that lifts
    # Symbol keys to String, so the param key narrows to String at
    # this boundary; values stay `untyped` because the body branches
    # on `is_a?(Hash)` to handle nested data/aria maps.
    def self.render_attrs: (Hash[String, untyped] attrs) -> String
  
    # ── form builder (yielded by form_with) ─────────────────────────
    class FormBuilder
      # Constructor takes the four pieces of form state. `model` is
      # any AR record (`ActiveRecord::Base` is the closed supertype
      # every app model inherits transitively); use the abstract Base
      # type so strict-typed targets can declare the field as
      # `ActiveRecord::Base` and accept any subclass via covariant
      # assignment. `@model[field]` dispatches via Base's abstract
      # `[]` to the per-model implementation.
      def initialize: (
        ActiveRecord::Base model,
        String model_name,
        String action,
        Symbol method
      ) -> void

      # `attr_reader` — getters only.
      def model: () -> ActiveRecord::Base
      def model_name: () -> String
      def action: () -> String
  
      # Each emit method returns the rendered HTML String. `field` is
      # the attribute name (Symbol). `opts` is the per-element attribute
      # hash. `submit`'s `label` defaults to a method-aware string when
      # omitted.
      def label: (Symbol field, ?Hash[Symbol, untyped] opts) -> String
      def text_field: (Symbol field, ?Hash[Symbol, untyped] opts) -> String
      def text_area: (Symbol field, ?Hash[Symbol, untyped] opts) -> String
      def submit: (?String? label, ?Hash[Symbol, untyped] opts) -> String
    end
  end
end
