module ActionController
  # Strong-parameters analogue. Wraps an
  # ActiveSupport::HashWithIndifferentAccess; key access accepts
  # either Symbol or String. Most signatures take `untyped` keys
  # because HWIA normalizes via `Symbol#to_s`.
  class Parameters
    # `hash` defaults to `nil` — typed as `untyped` for the
    # construction-from-untyped-source case (request bodies) plus the
    # HWIA-passthrough case.
    def initialize: (?untyped hash) -> void

    def get: (untyped key) -> untyped
    def set: (untyped key, untyped value) -> untyped
    def has?: (untyped key) -> bool

    def []: (untyped key) -> untyped
    def []=: (untyped key, untyped value) -> untyped

    def key?: (untyped key) -> bool

    def fetch: (untyped key, ?untyped default) -> untyped

    def empty?: () -> bool

    # Underlying String-keyed Hash (HWIA convention).
    def to_h: () -> Hash[String, untyped]

    # Accepts a Hash or HWIA; HWIA normalizes either on insert.
    def merge: (untyped other_hash) -> Parameters

    # Returns nested Parameters; raises on missing/non-Hash/empty.
    def require: (untyped key) -> Parameters

    # Filtered Parameters containing only allowed_keys. Array elements
    # may be Symbol or String — HWIA normalizes.
    def permit: (Array[untyped] allowed_keys) -> Parameters
  end

  class ParameterMissing < StandardError
  end
end
