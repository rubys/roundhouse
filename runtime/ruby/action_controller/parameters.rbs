module ActionController
  # Strong-parameters analogue. Internal storage is a String-keyed
  # Hash whose values are either flat `String` (form / query /
  # path captures) or nested `Parameters` (resource-shaped bodies).
  # Indifferent access is implemented via `key.to_s` in each
  # accessor — no HWIA wrapper.
  class Parameters
    @hash: Hash[String, String | Parameters]

    def initialize: (?Hash[untyped, untyped]? hash) -> void

    def get: (String | Symbol key) -> (String | Parameters)?
    def set: (String | Symbol key, String | Parameters value) -> (String | Parameters)
    def normalize: (untyped value) -> (String | Parameters)
    def has?: (String | Symbol key) -> bool

    def []: (String | Symbol key) -> (String | Parameters)?
    def []=: (String | Symbol key, String | Parameters value) -> (String | Parameters)

    def key?: (String | Symbol key) -> bool

    def fetch: (String | Symbol key, ?String default) -> String

    def empty?: () -> bool

    # Returns the inner storage Hash. Nested Parameters values are
    # left as-is — callers that want flat output chain `.to_h` per
    # level. (Recursive unwrap would force the value type into a
    # `String | Hash | Nil` union that strict targets can't commit
    # to ergonomically.)
    def to_h: () -> Hash[String, String | Parameters]

    def merge: (Hash[untyped, untyped] other_hash) -> Parameters

    def require: (String | Symbol key) -> Parameters

    def permit: (Array[String | Symbol] allowed_keys) -> Parameters
  end

  class ParameterMissing < StandardError
  end
end
