module ActiveRecord
  class Base
    # Class metadata + schema tracking. `schema_column_names` is
    # provided per-model by the lowerer; Base's stub returns an empty
    # array. `attr_accessor` and `inherited` overrides are gone; their
    # tracking responsibilities moved to per-model generated methods.
    def self.schema_column_names: () -> Array[Symbol]
    def self.table_name: () -> String
    def self.table_name=: (String n) -> String
    def self.abstract?: () -> bool

    # Class-level CRUD. Returns the concrete class instance; our IR
    # lacks a Self type, so Base stands in for the specific subclass.
    def self.instantiate: (Hash[Symbol, String] row) -> Base
    def self.create: (?Hash[Symbol, String] attrs) -> Base
    def self.create!: (?Hash[Symbol, String] attrs) -> Base
    def self.all: () -> Array[Base]
    def self.find: (Integer id) -> Base
    def self.find_by: (Hash[Symbol, String] conditions) -> Base?
    def self.where: (Hash[Symbol, String] conditions) -> Array[Base]
    def self.count: () -> Integer
    def self.exists?: (Integer id) -> bool
    def self.destroy_all: () -> Array[Base]

    # Instance lifecycle
    def initialize: (?Hash[Symbol, String] attrs) -> void
    def attributes: () -> Hash[Symbol, String]
    def persisted?: () -> bool
    def new_record?: () -> bool
    def destroyed?: () -> bool
    def read_attribute: (Symbol name) -> String
    def []: (Symbol name) -> String
    def []=: (Symbol name, String value) -> String

    # Lifecycle hooks — subclasses override. Default: no-op.
    def before_validation: () -> void
    def after_validation: () -> void
    def before_save: () -> void
    def after_save: () -> void
    def before_create: () -> void
    def after_create: () -> void
    def before_update: () -> void
    def after_update: () -> void
    def before_destroy: () -> void
    def after_destroy: () -> void
    def after_commit: () -> void
    def after_create_commit: () -> void
    def after_update_commit: () -> void
    def after_destroy_commit: () -> void
    def after_save_commit: () -> void
    def after_touch: () -> void

    def validate: () -> void
    def valid?: () -> bool
    def save: () -> bool
    def save!: () -> bool
    def destroy: () -> Base
    def update: (Hash[Symbol, String] attrs) -> bool
    def ==: (Base other) -> bool
    def hash: () -> Integer

    # Validations (inlined from the previous Validations module).
    def errors: () -> Array[String]
    def validates_presence_of: (Symbol attr) -> void
    def validates_absence_of: (Symbol attr) -> void
    def validates_length_of: (Symbol attr, ?minimum: Integer?, ?maximum: Integer?, ?is: Integer?) -> void
    def validates_numericality_of: (Symbol attr, ?greater_than: Integer?, ?less_than: Integer?, ?only_integer: bool) -> void
    def validates_inclusion_of: (Symbol attr, within: Array[String]) -> void
    def validates_format_of: (Symbol attr, with: String) -> void
    def validates_uniqueness_of: (Symbol attr, ?scope: Array[Symbol], ?case_sensitive: bool) -> void

    # Broadcasts (inlined from the previous Broadcasts module). The
    # log holder remains as a separate class — see broadcasts.rbs.
    def broadcast_replace_to: (*String channels, ?target: String?) -> nil
    def broadcast_append_to: (*String channels, ?target: String?) -> nil
    def broadcast_prepend_to: (*String channels, ?target: String?) -> nil
    def broadcast_remove_to: (*String channels, ?target: String?) -> nil

    # Public conceptually-private — see base.rb comment.
    def init_from_row: (Hash[Symbol, String] row) -> void

    private
    def read_for_validation: (Symbol attr) -> String
    def blank?: (String value) -> bool

    # Reflection chokepoints — bodies use instance_variable_*, send,
    # and respond_to?. The RBS sigs let callers type cleanly even
    # though the bodies themselves remain unavoidably reflective.
    def _read_ivar: (Symbol name) -> String
    def _write_ivar: (Symbol name, String value) -> String
    def _read_accessor: (Symbol name) -> String
    def _write_accessor: (Symbol name, String value) -> String
    def _has_accessor?: (Symbol name) -> bool
  end
end
