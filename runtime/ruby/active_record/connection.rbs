# Typing contract for the raw-SQL connection facade. Rows are
# Hash[String, untyped] by design — raw SQL's row shape (aliased
# aggregates, computed columns) is genuinely dynamic; see connection.rb.
module ActiveRecord
  class Result
    @rows: Array[Hash[String, untyped]]

    def initialize: (Array[Hash[String, untyped]] rows) -> void
    def rows: () -> Array[Hash[String, untyped]]
    def to_a: () -> Array[Hash[String, untyped]]
    def first: () -> Hash[String, untyped]?
    def each: () { (Hash[String, untyped]) -> void } -> Array[Hash[String, untyped]]
  end

  class Connection
    def adapter_name: () -> String
    def quote: (untyped value) -> String
    def quote_string: (String str) -> String
    def execute: (String sql) -> Result
    def exec_query: (String sql) -> Result
  end

  class Base
    def self.connection: () -> Connection
    def self.transaction: () { () -> untyped } -> untyped
    def self.update_counters: (untyped id, Hash[Symbol, untyped] counters) -> Integer
    def self.record_timestamps=: (untyped value) -> untyped
    def self.record_timestamps: () -> bool
    def update_column: (untyped name, untyped value) -> bool
    def _as_json_only: (Array[Symbol] only) -> Hash[String, untyped]
    # Ruby-family overrides of base.rb's Array-returning fallbacks.
    def self.where: (Hash[Symbol, untyped] conditions) -> Relation
    def self.all: () -> Relation
    # Ruby-family overrides of base.rb's dirty-tracking stubs.
    def __track_saved_changes: (bool was_new) -> void
    def saved_changes: () -> Hash[Symbol, untyped]
  end
end
