# Typing contract for the BCrypt raising façade (bcrypt_facade.rb
# beside this file). Dropped alongside the façade when the spin-shaped
# spinel tree swaps in the real bcrypt package (its surface is
# inferred from the package source).
module BCrypt
  module Engine
    DEFAULT_COST: Integer
  end

  class Password
    @digest: String

    def self.create: (String _secret, ?cost: Integer?) -> BCrypt::Password
    def initialize: (String _digest) -> void
    def ==: (String _other) -> bool
    def to_s: () -> String
  end
end
