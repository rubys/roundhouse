# Typing contract for the gem façades. These are the REAL shapes of the
# touched surface — every body raises via GemFacade.fail! before its
# (unreachable) typed tail, so call sites type against these returns
# while any runtime hit fails loudly.
module GemFacade
  def self.fail!: (String member) -> void
end

module Markly
  SMART: Integer
  DEFAULT: Integer

  def self.parse: (untyped _text, ?flags: Integer, ?extensions: Array[Symbol]) -> Markly::Node

  class Node
    @type: Symbol?

    def initialize: (?Symbol? _type) -> void
    def type: () -> Symbol
    def each: () { (Node) -> void } -> void
    def to_html: (?flags: Integer, ?extensions: Array[Symbol]) -> String
    def string_content: () -> String
    def string_content=: (String _value) -> String
    def url=: (String _value) -> String
    def insert_after: (Node _node) -> void
    def append_child: (Node _node) -> void
  end
end

module Nokogiri
  def self.HTML: (String _html) -> Nokogiri::Document

  class Attr
    def text: () -> String
    def to_s: () -> String
  end

  class Element
    def name=: (String _value) -> String
    def []: (untyped _key) -> String?
    def []=: (untyped _key, String _value) -> String
    def text: () -> String
    def inner_html: () -> String
    def attributes: () -> Hash[String, Attr]
    def content=: (untyped _value) -> untyped
    def replace: (Element _node) -> void
  end

  class NodeSet
    def each: () { (Element) -> void } -> void
  end

  class Document
    def css: (String _selector) -> NodeSet
    def at_css: (String _selector) -> Element?
    def create_element: (String _name) -> Element
  end
end

module Mail
  def self.read_from_string: (String _text) -> Mail::Message

  class Part
    def parts: () -> Array[Mail::Part]
    def content_type: () -> String
    def content_type_parameters: () -> Hash[String, untyped]
    def body: () -> String
  end

  class Message
    def multipart?: () -> bool
    def parts: () -> Array[Mail::Part]
    def content_type: () -> String
    def content_type_parameters: () -> Hash[String, untyped]
    def body: () -> String
  end

  class Address
    @value: String

    def initialize: (String _value) -> void
    def address: () -> String
    def domain: () -> String
    def local: () -> String
  end
end

module ROTP
  class TOTP
    @secret: String

    def initialize: (String _secret, ?issuer: String?) -> void
    def verify: (String _code) -> bool
    def provisioning_uri: (String _account) -> String
    def secret: () -> String
  end

  module Base32
    def self.random: () -> String
  end
end

module RQRCode
  class QRCode
    @data: String

    def initialize: (String _data) -> void
    def as_svg: (?offset: Integer, ?fill: String?, ?color: String?, ?module_size: Integer?, ?shape_rendering: String?) -> String
  end
end

module SVG
  module Graph
    class TimeSeries
      @opts: Hash[Symbol, untyped]

      def initialize: (Hash[Symbol, untyped] _opts) -> void
      def popup_format: () -> String
      def x_label_format: () -> String
      def get_x_values: () -> Array[Integer]
      def get_y_values: () -> Array[Integer]
      def add_data: (?data: untyped, ?template: String?) -> SVG::Graph::TimeSeries
      def burn_svg_only: () -> String
    end
  end
end
