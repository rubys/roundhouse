#!/usr/bin/env bash
# scripts/bench-lobsters — the lobsters benchmark orchestrator.
#
# The lobsters counterpart of scripts/bench: where that measures blog
# throughput per target, this measures the ruby-bench lobsters benchmark
# (frozen 114-visit sequence, in-memory, in-process, single-threaded)
# across runtime × JIT lanes, plus route parity per emit lane.
#
# Usage:  scripts/bench-lobsters [options] [LANE...]
#
#   LANE            lane list — the nightly form. One run dir, one subdir
#                   per lane, one aggregated matrix.json (what
#                   scripts/lobsters-report renders). Lane vocabulary
#                   matches scripts/bench:
#                     rails       real Rails, YJIT        [needs the bundle]
#                     rails-int   real Rails, no JIT      [needs the bundle]
#                     rails-jruby real Rails on JRuby, from a patched
#                                 sibling fixture (see prep_rails_jruby_
#                                 fixture) — list it AFTER jruby, whose
#                                 emit tree it borrows the markly shim from
#                     ruby        roundhouse emit, YJIT
#                     ruby-int    roundhouse emit, no JIT
#                     jruby       roundhouse emit, JRuby/JVM
#                   Rails lanes are skipped (loudly) when the checkout's
#                   bundle isn't installable; the JVM lanes when jruby
#                   isn't on PATH. JIT is pinned per lane via RUBYOPT —
#                   the ambient environment can't leak in. Example:
#                     scripts/bench-lobsters rails rails-int ruby ruby-int jruby rails-jruby --time 20
#
#   With no LANE args this is the single-lane worker (the dev loop and
#   the lane mode's own building block): emit + file-backed parity replay
#   by default, plus the flags below. Until every route returns 200 the
#   headline metric IS the parity count; --time N adds a ms/iter trend.
#
#   --src DIR       lobsters source checkout
#                   (default $LOBSTERS_SRC, else ~/git/ruby-bench/benchmarks/lobsters)
#   --runtime R     which runtime to emit for and replay under:
#                     cruby  (default) — --target ruby,  replay under `ruby`
#                     jruby            — --target jruby, replay under `jruby`
#                   Both drive the SAME scripts/lobsters-replay; only the
#                   emit target, interpreter, and gem/JVM setup differ.
#                   --memory/--frozen work on both (JRuby seeds :memory: via
#                   the JDBC driver's restore()); --vs-rails is CRuby-only
#                   (same-interpreter baseline). Results land under a
#                   per-runtime `latest`/`latest-jruby` symlink so the two
#                   lanes don't cross-compare.
#   --jruby         shorthand for --runtime jruby
#   --skip-emit     reuse the existing build tree (fast replay iteration)
#   --memory        serve from an in-memory SQLite seeded from the staged
#                   DB at boot (SQLite3::Backup on CRuby, JDBC restore()
#                   on JRuby) — the shape the real ruby-bench benchmark
#                   runs; the file-backed default remains for bisection
#                   against older runs
#   --time N        run N timed iterations after the parity pass, preceded
#                   by --warmup discarded iterations
#   --warmup N      discarded warmup iterations before the timed run
#                   (default: 5 for cruby, 100 for jruby's JIT — which warms
#                   slowly here; a publication jruby number wants >=500)
#   --vs-rails      P6 comparison: boot the REAL Rails lobsters (needs the
#                   ruby-bench checkout's bundle), dump + time the frozen
#                   114-visit sequence there, then replay the SAME sequence
#                   against the emit (implies --memory — both stacks must
#                   run the benchmark's in-mem DB shape) and report
#                   roundhouse-vs-Rails ms/iter. The frozen sequence is
#                   versioned at bench/lobsters/frozen-sequence.json; a
#                   regeneration that differs means the ruby-bench DB or
#                   generator changed — investigate before comparing.
#   --frozen        time the emit on the committed frozen 114-visit sequence,
#                   in-memory, WITHOUT booting Rails — the canonical ruby-bench
#                   workload as an emit-only lane (the per-runtime matrix rows,
#                   decoupled from the Rails baseline). Implies --memory;
#                   mutually exclusive with --vs-rails. scripts/lobsters-matrix
#                   drives one of these per runtime/JIT.
#   --out DIR       results dir (default bench/results/lobsters/<timestamp>).
#                   Passing this suppresses the shared `latest` symlink (the
#                   caller owns placement).
#
# Output:
#   bench/results/lobsters/<timestamp>/summary.json   # per-route parity + timing
#   bench/results/lobsters/<timestamp>/summary.md     # rendered table + failures
#   bench/results/lobsters/<timestamp>/emit.log       # transpile diagnostics
#   bench/results/lobsters/latest                     # symlink to newest run
#
# When a previous run exists, the console output ends with a comparison
# against it: pass-count delta, regressed/fixed routes, and changed
# failure signatures — so a nightly cron log doubles as the alarm.
#
# Exit code = number of failing routes, so it doubles as a dev gate;
# nightly wrappers that want blog results regardless should `|| true`.
#
# Dev loop after a compiler change:
#   scripts/bench-lobsters              # re-emit + replay
#   scripts/bench-lobsters --skip-emit  # replay only

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
SRC="${LOBSTERS_SRC:-$HOME/git/ruby-bench/benchmarks/lobsters}"
OUT_DIR=""
EXPLICIT_OUT=0
SKIP_EMIT=0
TIME_ITERS=0
MEMORY=0
VS_RAILS=0
FROZEN=0
RUNTIME=cruby
WARMUP=""              # timed-run warmup iters; default derived per runtime below
WARMUP_EXPLICIT=0      # explicit --warmup also overrides the sequence path's 15
LANES=()               # positional lane args -> orchestrator mode
# OUT_TREE, RUBY_BIN, EMIT_TARGET, GEMS are resolved from RUNTIME after parse.
# Snapshot before the parse loop shifts everything away — the
# provenance step reads this (a bare `$*` there always recorded an
# arg-less command; caught on the first published Hetzner run).
ORIG_ARGS="$*"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --src)       SRC="$2"; shift 2 ;;
        --runtime)   RUNTIME="$2"; shift 2 ;;
        --jruby)     RUNTIME=jruby; shift ;;
        --skip-emit) SKIP_EMIT=1; shift ;;
        --memory)    MEMORY=1; shift ;;
        --vs-rails)  VS_RAILS=1; MEMORY=1; shift ;;
        --frozen)    FROZEN=1; MEMORY=1; shift ;;
        --time)      TIME_ITERS="$2"; shift 2 ;;
        --warmup)    WARMUP="$2"; WARMUP_EXPLICIT=1; shift 2 ;;
        --out)       OUT_DIR="$2"; EXPLICIT_OUT=1; shift 2 ;;
        -h|--help)   sed -n '2,/^$/p' "$0" | sed 's/^# \?//'; exit 0 ;;
        -*)          echo "unknown flag: $1" >&2; exit 2 ;;
        *)           LANES+=("$1"); shift ;;
    esac
done

step() { printf '\033[36m→\033[0m %s\n' "$*"; }
ok()   { printf '\033[32m✓\033[0m %s\n' "$*"; }
fail() { printf '\033[31m✗\033[0m %s\n' "$*" >&2; }

# Route-parity trend vs a previous run: pass-count delta, regressed/fixed
# routes, changed failure signatures. PARITY REGRESSION lines print loudly
# so a `>> bench.log` cron capture stays greppable.
compare_parity() {  # PREV_NAME PREV_JSON CUR_JSON
    ruby -rjson -e '
      prev_name, prev_path, cur_path = ARGV
      prev = JSON.parse(File.read(prev_path))
      cur  = JSON.parse(File.read(cur_path))
      by_route = ->(s) { (s["routes"] || []).to_h { |r| [r["route"], r] } }
      p_routes, c_routes = by_route.(prev), by_route.(cur)
      puts "vs #{prev_name}: #{prev["pass"]}/#{prev["total"]} -> #{cur["pass"]}/#{cur["total"]}"
      c_routes.each do |route, c|
        p = p_routes[route] or next
        if p["ok"] && !c["ok"]
          puts "  PARITY REGRESSION: #{route} #{p["status"]} -> #{c["status"]}"
        elsif !p["ok"] && c["ok"]
          puts "  fixed: #{route} #{p["status"]} -> 200"
        elsif !c["ok"]
          pe = p["error"].to_s.lines.first.to_s.strip
          ce = c["error"].to_s.lines.first.to_s.strip
          puts "  signature changed: #{route}\n    was: #{pe}\n    now: #{ce}" if pe != ce
        end
      end
    ' "$1" "$2" "$3" || true
}

# rails-jruby fixture: a sibling copy of the lobsters checkout patched to
# run stock Rails under JRuby (the blog bench's rails-jruby precedent,
# proven by the 2026-07-17 probe). The recipe:
#   - sqlite3 (C ext) -> activerecord-jdbcsqlite3-adapter 80.0.pre1,
#     which pins Rails to 8.0.x — one minor behind the CRuby lanes;
#     ledgered as a caveat on the report page
#   - markly (C ext) -> the emit tree's commonmark-java shim, snapshotted
#     into the fixture (SAME markdown backend as the roundhouse jruby
#     lane, so the JVM comparison is backend-for-backend fair)
#   - rdoc < 8 (rdoc 8 pulls rbs, a C ext) + top-level ostruct (ruumba's
#     rubocop 0.81 requires it; gone from jruby 10's stdlib)
#   - initializer working around the JRuby 10.1 Time.new(str, in:) call-
#     site bug (TypeError on the 3rd call; hits every Rails timestamp cast)
# Rebuilt when the source Gemfile changes; the benchmark DB re-syncs every
# run. Needs the jruby emit tree for the shim + jars — list the jruby lane
# before rails-jruby.
prep_rails_jruby_fixture() {
    FIXTURE="$REPO_ROOT/build/lobsters-rails-jruby-fixture"
    EMIT_JRUBY="$REPO_ROOT/build/transpiled-lobsters-jruby"
    if [[ ! -f "$EMIT_JRUBY/runtime/markly_jruby.rb" ]] || ! ls "$EMIT_JRUBY/vendor/jars/"commonmark-*.jar >/dev/null 2>&1; then
        fail "rails-jruby fixture needs the jruby emit tree (markly shim + jars): put the jruby lane before rails-jruby"
        return 1
    fi
    if [[ ! -f "$FIXTURE/.source-gemfile" ]] || ! cmp -s "$SRC/Gemfile" "$FIXTURE/.source-gemfile"; then
        step "building rails-jruby fixture at $FIXTURE"
        rm -rf "$FIXTURE"
        cp -R "$SRC" "$FIXTURE"
        cp "$SRC/Gemfile" "$FIXTURE/.source-gemfile"
        rm -f "$FIXTURE/Gemfile.lock"
        perl -0pi -e 's/^gem "sqlite3"$/gem "sqlite3", platform: :mri\ngem "activerecord-jdbcsqlite3-adapter", "80.0.pre1", platform: :jruby/m' "$FIXTURE/Gemfile"
        perl -0pi -e 's/^gem "markly"$/gem "markly", platform: :mri/m' "$FIXTURE/Gemfile"
        perl -0pi -e 's/^gem "cgi"/gem "rdoc", "< 8", platform: :jruby # rdoc 8 pulls rbs (C ext, no jruby build)\ngem "ostruct", platform: :jruby # ruumba -> rubocop 0.81 needs it; not in jruby 10 stdlib\ngem "cgi"/m' "$FIXTURE/Gemfile"
        mkdir -p "$FIXTURE/vendor/jars"
        cp "$EMIT_JRUBY/vendor/jars/"*.jar "$FIXTURE/vendor/jars/"
        cp "$EMIT_JRUBY/runtime/markly_jruby.rb" "$FIXTURE/vendor/markly_jruby.rb"
        cat > "$FIXTURE/config/initializers/00_markly_jruby.rb" <<'INIT'
# rails-jruby fixture: markly is C-ext only; under JRuby load the
# roundhouse commonmark-java shim snapshotted into vendor/ (the same
# markdown backend the roundhouse jruby lane uses).
if RUBY_ENGINE == "jruby"
  ENV["MARKLY_JRUBY_JARS"] ||= File.expand_path("../../vendor/jars", __dir__)
  require File.expand_path("../../vendor/markly_jruby", __dir__)
end
INIT
        cat > "$FIXTURE/config/initializers/01_jruby_time_workaround.rb" <<'INIT'
# JRuby 10.1.0.0 call-site bug: Time.new(str, in: "UTC") raises
# TypeError (no implicit conversion of Hash into Integer) on the 3rd
# call with identical args:
#   3.times { Time.new("2023-05-08 10:21:21", in: "UTC") }
# Rails 8's fast_string_to_time hits it on every timestamp cast. Regex
# fast path (the pre-Rails-8 shape) until fixed upstream; misses return
# nil -> Rails falls back to its slow parse. Upstream: jruby/jruby#9531 --
# drop this initializer (and the fixture rebuild will follow) once fixed.
if RUBY_ENGINE == "jruby"
  module ActiveModel
    module Type
      module Helpers
        module TimeValue
          FAST_TS = /\A(\d{4})-(\d\d)-(\d\d)[ T](\d\d):(\d\d):(\d\d)(?:\.(\d+))?\z/
          def fast_string_to_time(string)
            m = FAST_TS.match(string) or return nil
            usec = m[7] ? m[7].ljust(6, "0")[0, 6].to_i : 0
            args = [m[1].to_i, m[2].to_i, m[3].to_i, m[4].to_i, m[5].to_i, m[6].to_i, usec]
            is_utc? ? ::Time.utc(*args) : ::Time.local(*args)
          end
        end
      end
    end
  end
end
INIT
    else
        cp "$SRC/db/production.sqlite3" "$FIXTURE/db/production.sqlite3"
    fi
    step "rails-jruby fixture: bundle install (jruby)"
    (cd "$FIXTURE" && BUNDLE_WITHOUT=development:test jruby -S bundle install --quiet) || {
        fail "rails-jruby fixture bundle install failed"; return 1; }
}

# ── lane mode (orchestrator) ─────────────────────────────────────────
# One run dir, one subdir per lane, one aggregated matrix.json — the
# layout scripts/lobsters-report renders as the consolidated page. Each
# lane re-invokes this script (or lobsters-rails-replay for the Rails
# lanes) with JIT pinned via RUBYOPT, methodology fixed to the in-memory
# frozen sequence, and output routed to the lane subdir. A lane that
# fails is dropped with a note; the run aggregates whatever succeeded.
if (( ${#LANES[@]} > 0 )); then
    if (( MEMORY == 1 || VS_RAILS == 1 || FROZEN == 1 )) || [[ "$RUNTIME" != cruby ]]; then
        fail "lane mode fixes the methodology (in-memory frozen sequence per lane); drop --memory/--vs-rails/--frozen/--runtime/--jruby"
        exit 2
    fi
    for LANE in "${LANES[@]}"; do
        case "$LANE" in rails|rails-int|ruby|ruby-int|jruby|rails-jruby) ;; *)
            fail "unknown lane: $LANE (want rails rails-int ruby ruby-int jruby rails-jruby)"; exit 2 ;;
        esac
    done
    [[ -d "$SRC" ]] || { fail "lobsters source not found at $SRC (clone ruby-bench or pass --src)"; exit 2; }
    FROZEN_SEQ="$REPO_ROOT/bench/lobsters/frozen-sequence.json"
    [[ -f "$FROZEN_SEQ" ]] || { fail "no committed frozen sequence at $FROZEN_SEQ"; exit 2; }
    (( TIME_ITERS > 0 )) || TIME_ITERS=10

    RUN_TS="$(date +%Y%m%d-%H%M%S)"
    RUN_DIR="${OUT_DIR:-$REPO_ROOT/bench/results/lobsters/$RUN_TS}"
    mkdir -p "$RUN_DIR"

    RAILS_OK=0
    (cd "$SRC" && bundle check >/dev/null 2>&1) && RAILS_OK=1
    JRUBY_OK=0
    command -v jruby >/dev/null 2>&1 && JRUBY_OK=1

    EMITTED_CRUBY=$SKIP_EMIT
    EMITTED_JRUBY=$SKIP_EMIT
    FAILED_LANES=0

    for LANE in "${LANES[@]}"; do
        LDIR="$RUN_DIR/$LANE"
        mkdir -p "$LDIR"
        case "$LANE" in
            rails|rails-int)
                if (( RAILS_OK == 0 )); then
                    fail "lane $LANE skipped: bundle not installable in $SRC"; continue
                fi
                RO=--yjit; JIT_LABEL=YJIT
                [[ "$LANE" == rails-int ]] && { RO=; JIT_LABEL="no JIT"; }
                step "lane $LANE: real Rails on the frozen sequence ($JIT_LABEL; boots Rails, minutes)"
                if RUBYOPT="$RO" ruby "$REPO_ROOT/scripts/lobsters-rails-replay" \
                        --src "$SRC" --warmup 15 --min-iters "$TIME_ITERS" --min-time 10 \
                        --seq-out "$LDIR/sequence.json" --json "$LDIR/rails.json" \
                        >"$LDIR/run.log" 2>&1; then
                    # The rails lane regenerates the sequence; a mismatch with
                    # the committed one means the ruby-bench DB or generator
                    # changed — rows are NOT comparable across that boundary.
                    if ! diff -q "$FROZEN_SEQ" "$LDIR/sequence.json" >/dev/null; then
                        fail "lane $LANE: regenerated sequence != committed frozen-sequence.json"
                    fi
                    ok "lane $LANE done"
                else
                    fail "lane $LANE failed (see $LDIR/run.log)"; FAILED_LANES=$((FAILED_LANES + 1))
                fi
                ;;
            ruby|ruby-int)
                RO=--yjit; JIT_LABEL=YJIT
                [[ "$LANE" == ruby-int ]] && { RO=; JIT_LABEL="no JIT"; }
                CMD=("$0" --frozen --time "$TIME_ITERS" --src "$SRC" --out "$LDIR")
                (( EMITTED_CRUBY == 1 )) && CMD+=(--skip-emit)
                step "lane $LANE: emit replay on the frozen sequence ($JIT_LABEL)"
                if RUBYOPT="$RO" "${CMD[@]}" >"$LDIR/run.log" 2>&1; then
                    EMITTED_CRUBY=1; ok "lane $LANE done"
                else
                    fail "lane $LANE failed (see $LDIR/run.log)"; FAILED_LANES=$((FAILED_LANES + 1))
                fi
                ;;
            rails-jruby)
                if (( JRUBY_OK == 0 )); then
                    fail "lane rails-jruby skipped: no jruby on PATH"; continue
                fi
                if ! prep_rails_jruby_fixture; then
                    FAILED_LANES=$((FAILED_LANES + 1)); continue
                fi
                step "lane rails-jruby: real Rails under JRuby on the frozen sequence (long warmup; many minutes)"
                if RUBYOPT= BUNDLE_WITHOUT=development:test \
                        JAVA_OPTS="${BENCH_JRUBY_HEAP:--Xmx2g -Xms2g} --enable-native-access=ALL-UNNAMED ${JAVA_OPTS:-}" \
                        jruby "$REPO_ROOT/scripts/lobsters-rails-replay" \
                        --src "$FIXTURE" --warmup "${WARMUP:-100}" --min-iters "$TIME_ITERS" --min-time 10 \
                        --seq-out "$LDIR/sequence.json" --json "$LDIR/rails.json" \
                        >"$LDIR/run.log" 2>&1; then
                    if ! diff -q "$FROZEN_SEQ" "$LDIR/sequence.json" >/dev/null; then
                        fail "lane rails-jruby: regenerated sequence != committed frozen-sequence.json"
                    fi
                    ok "lane rails-jruby done"
                else
                    fail "lane rails-jruby failed (see $LDIR/run.log)"; FAILED_LANES=$((FAILED_LANES + 1))
                fi
                ;;
            jruby)
                if (( JRUBY_OK == 0 )); then
                    fail "lane jruby skipped: no jruby on PATH"; continue
                fi
                # JRuby's JIT warms slowly; an unset --warmup gets a bigger
                # default than the CRuby lanes' canonical sequence warmup.
                CMD=("$0" --jruby --frozen --time "$TIME_ITERS" --warmup "${WARMUP:-100}" --src "$SRC" --out "$LDIR")
                (( EMITTED_JRUBY == 1 )) && CMD+=(--skip-emit)
                step "lane jruby: emit replay on the frozen sequence (JRuby/JVM, long warmup)"
                if RUBYOPT= "${CMD[@]}" >"$LDIR/run.log" 2>&1; then
                    EMITTED_JRUBY=1; ok "lane jruby done"
                else
                    fail "lane jruby failed (see $LDIR/run.log)"; FAILED_LANES=$((FAILED_LANES + 1))
                fi
                ;;
        esac
    done

    # Top-level provenance: the ORIGINAL invocation (lane env.json files
    # carry each lane's interpreter; this carries the orchestration).
    ruby -rjson -rsocket -e 'puts JSON.pretty_generate({
      generated_at: Time.now.utc.strftime("%FT%TZ"),
      command: "scripts/bench-lobsters #{ARGV[0]}".strip,
      src: ARGV[1], host: Socket.gethostname,
      roundhouse_commit: `git -C #{ARGV[2]} rev-parse HEAD`.strip,
    })' "$ORIG_ARGS" "$SRC" "$REPO_ROOT" > "$RUN_DIR/env.json" || true

    # Aggregate lane artifacts into matrix.json (one row per lane) and
    # print the console table. Row fields feed scripts/lobsters-report.
    step "aggregating matrix.json"
    ruby - "$RUN_DIR" "$TIME_ITERS" <<'AGG' || FAILED_LANES=$((FAILED_LANES + 1))
require "json"
require "socket"
run_dir, time_iters = ARGV
META = {
  "rails"       => { label: "Rails",      kind: "rails", runtime: "cruby", yjit: true,  jit: "YJIT",   src: "rails.json"   },
  "rails-int"   => { label: "Rails",      kind: "rails", runtime: "cruby", yjit: false, jit: "no JIT", src: "rails.json"   },
  "rails-jruby" => { label: "Rails",      kind: "rails", runtime: "jruby", yjit: nil,   jit: "JRuby",  src: "rails.json"   },
  "ruby"        => { label: "Roundhouse", kind: "emit",  runtime: "cruby", yjit: true,  jit: "YJIT",   src: "summary.json" },
  "ruby-int"    => { label: "Roundhouse", kind: "emit",  runtime: "cruby", yjit: false, jit: "no JIT", src: "summary.json" },
  "jruby"       => { label: "Roundhouse", kind: "emit",  runtime: "jruby", yjit: nil,   jit: "JRuby",  src: "summary.json" },
}
rows = META.filter_map do |id, m|
  path = File.join(run_dir, id, m[:src])
  next unless File.exist?(path)
  data = JSON.parse(File.read(path)) rescue next
  t = m[:src] == "rails.json" ? data : data["sequence_timing"]
  next unless t && t["ms_per_iter_median"]
  env = (JSON.parse(File.read(File.join(run_dir, id, "env.json"))) rescue {})
  { "id" => id, "label" => m[:label], "kind" => m[:kind], "runtime" => m[:runtime],
    "yjit" => m[:yjit], "jit" => m[:jit],
    "ms_median" => t["ms_per_iter_median"], "ms_min" => t["ms_per_iter_min"],
    "ms_max" => t["ms_per_iter_max"], "iters" => t["iterations"], "warmup" => t["warmup"],
    "ruby" => data["ruby"] || env["ruby"], "rails" => data["rails"],
    "visits" => t["visits_per_iter"], "partial" => t["partial"] }
end
abort "no lane produced timing data" if rows.empty?
# Ratio = same-configuration Rails baseline / this row. CRuby emit rows
# pair with Rails at the same JIT level; JVM rows pair with Rails on
# JRuby when that lane ran (same runtime), else fall back to Rails+YJIT
# (Rails' best CRuby configuration).
rails_cruby = rows.select { |r| r["kind"] == "rails" && r["runtime"] == "cruby" }.to_h { |r| [r["yjit"], r] }
rails_jvm   = rows.find { |r| r["kind"] == "rails" && r["runtime"] == "jruby" }
rows.each do |r|
  base = r["runtime"] == "jruby" ? (rails_jvm || rails_cruby[true]) : rails_cruby[r["yjit"]]
  r["vs_rails"] = base ? (base["ms_median"] / r["ms_median"]).round(2) : nil
end
matrix = {
  "generated_at" => Time.now.utc.strftime("%FT%TZ"),
  "host"         => Socket.gethostname,
  "workload"     => "frozen #{rows.filter_map { |r| r["visits"] }.first || 114}-visit sequence, in-memory, in-process, single-threaded",
  "time"         => Integer(time_iters),
  "rows"         => rows,
}
File.write(File.join(run_dir, "matrix.json"), JSON.pretty_generate(matrix))
puts "\n== lobsters lanes (#{rows.size}, ms/iter, lower=better) =="
rows.sort_by { |r| r["ms_median"] }.each do |r|
  printf "  %-11s %-7s %9.2f ms/iter  %s\n", r["label"], r["jit"], r["ms_median"],
         (r["vs_rails"] ? "#{r["vs_rails"]}x vs Rails" : "")
end
AGG

    # Per-lane parity trend vs the previous run (resolve BEFORE repointing
    # latest). Older layouts kept the cruby summary at the run root — the
    # ruby lane falls back to it so the trend survives the layout change.
    LATEST_LINK="$REPO_ROOT/bench/results/lobsters/latest"
    if [[ -e "$LATEST_LINK" ]]; then
        PREV_NAME="$(readlink "$LATEST_LINK" 2>/dev/null || echo previous)"
        for LANE in ruby ruby-int jruby; do
            CUR="$RUN_DIR/$LANE/summary.json"
            [[ -f "$CUR" ]] || continue
            PREV="$LATEST_LINK/$LANE/summary.json"
            if [[ ! -f "$PREV" && "$LANE" == ruby ]]; then PREV="$LATEST_LINK/summary.json"; fi
            [[ -f "$PREV" ]] || continue
            compare_parity "$PREV_NAME ($LANE)" "$PREV" "$CUR"
        done
    fi
    (( EXPLICIT_OUT == 0 )) && ln -sfn "$(basename "$RUN_DIR")" "$LATEST_LINK"

    ok "lane run complete: $RUN_DIR ($FAILED_LANES failed lane(s))"
    exit "$FAILED_LANES"
fi

# ── runtime resolution ───────────────────────────────────────────────
# The lobsters lane runs the SAME emitted app + replay driver under
# either CRuby or JRuby; only the emit target, the interpreter, and the
# gem/JVM setup differ. lobsters-replay is interpreter-agnostic (it
# samples ids and serves through the tree's own adapter), so one driver
# covers both.
case "$RUNTIME" in
    cruby)
        RUBY_BIN=ruby
        EMIT_TARGET=ruby
        OUT_TREE="$REPO_ROOT/build/transpiled-lobsters-ruby"
        GEMS=(sqlite3 bcrypt htmlentities rotp markly nokogiri)
        : "${WARMUP:=5}"
        ;;
    jruby)
        RUBY_BIN=jruby
        EMIT_TARGET=jruby
        OUT_TREE="$REPO_ROOT/build/transpiled-lobsters-jruby"
        # jdbc-sqlite3 replaces the C-ext sqlite3; markly is the
        # commonmark-java shim (jars via bin/fetch-jars), not a gem;
        # bcrypt/nokogiri resolve to their java-platform builds.
        GEMS=(jdbc-sqlite3 bcrypt htmlentities rotp nokogiri)
        # JRuby's JIT needs a LONG warm run before its numbers mean
        # anything, and a pinned heap keeps GC behaviour from drifting
        # between runs (managed-runtime bench discipline). Override the heap
        # with BENCH_JRUBY_HEAP; --enable-native-access silences the
        # jdbc-sqlite3 restricted-method warnings on recent JDKs.
        #
        # Convergence is slow on this metric — the route set round-robins 26
        # cold paths, so each warms independently. Measured ms/iter median
        # vs --warmup (100 timed iters, file-backed, jruby 10.1): warmup 20
        # -> 91, 200 -> 47, 500 -> 42 (steady). So 20 wildly under-reports;
        # 100 is the fast-dev default; a publication-grade number wants an
        # explicit --warmup (which also overrides the sequence path's 15 —
        # a frozen-sequence warmup iteration is 114 visits, so the same
        # steady-state needs fewer iterations there than on the route set).
        : "${WARMUP:=100}"
        export JAVA_OPTS="${BENCH_JRUBY_HEAP:--Xmx2g -Xms2g} --enable-native-access=ALL-UNNAMED ${JAVA_OPTS:-}"
        ;;
    *)
        fail "unknown runtime: $RUNTIME (want cruby|jruby)"; exit 2 ;;
esac

# --vs-rails stays CRuby-only: its point is a same-interpreter baseline
# (real Rails boots under plain `ruby`), so pairing it with a jruby emit
# would compare across runtimes AND stacks at once. Cross-runtime rows
# belong to the matrix, where each lane is labeled. --memory/--frozen work
# on both runtimes (JRuby seeds via the JDBC driver's restore()).
if [[ "$RUNTIME" == jruby ]] && (( VS_RAILS == 1 )); then
    fail "--vs-rails is CRuby-only (same-interpreter baseline); use --frozen for the jruby in-memory lane."
    exit 2
fi

# --frozen: time the emit on the committed frozen 114-visit sequence,
# in-memory, WITHOUT booting Rails — the canonical ruby-bench workload as an
# emit-only lane (the matrix's per-runtime rows, decoupled from the Rails
# baseline). Mutually exclusive with --vs-rails (which owns the Rails side).
FROZEN_SEQ="$REPO_ROOT/bench/lobsters/frozen-sequence.json"
if (( FROZEN == 1 )); then
    (( VS_RAILS == 1 )) && { fail "--frozen and --vs-rails are mutually exclusive (--frozen is the emit-only lane)"; exit 2; }
    [[ -f "$FROZEN_SEQ" ]] || { fail "no committed frozen sequence at $FROZEN_SEQ (run --vs-rails once to freeze it)"; exit 2; }
fi

[[ -d "$SRC" ]] || { fail "lobsters source not found at $SRC (clone ruby-bench or pass --src)"; exit 2; }
[[ -f "$SRC/db/production.sqlite3" ]] || { fail "no benchmark DB at $SRC/db/production.sqlite3"; exit 2; }

TIMESTAMP="$(date +%Y%m%d-%H%M%S)"
[[ -z "$OUT_DIR" ]] && OUT_DIR="$REPO_ROOT/bench/results/lobsters/$TIMESTAMP"
mkdir -p "$OUT_DIR"

# ── emit ─────────────────────────────────────────────────────────────
if (( SKIP_EMIT == 0 )) || [[ ! -f "$OUT_TREE/main.rb" ]]; then
    step "transpiling lobsters (--target $EMIT_TARGET --allow-unsupported)"
    # cargo run rebuilds the compiler when sources changed, so the dev
    # loop never replays against a stale binary. Survey-mode warnings
    # are the expected torrent — keep them in emit.log, not the console.
    if ! (cd "$REPO_ROOT" && cargo run --quiet --bin roundhouse -- \
            --target "$EMIT_TARGET" "$SRC" -o "$OUT_TREE" --allow-unsupported \
            >"$OUT_DIR/emit.log" 2>&1); then
        fail "emit failed; last lines of $OUT_DIR/emit.log:"
        tail -20 "$OUT_DIR/emit.log" >&2
        exit 1
    fi
    ok "emitted to $OUT_TREE ($(grep -c 'warning' "$OUT_DIR/emit.log" || true) warnings in emit.log)"
fi

# The JRuby tree's Markly shim needs the commonmark-java jars, which can't
# ride the text-only emit. Fetch them into the tree (idempotent — the
# generated bin/fetch-jars skips jars already present). Run every time
# (even under --skip-emit) so a tree that predates the jars self-heals.
if [[ "$RUNTIME" == jruby ]]; then
    step "fetching commonmark-java jars (bin/fetch-jars)"
    sh "$OUT_TREE/bin/fetch-jars" >/dev/null || { fail "bin/fetch-jars failed"; exit 1; }
fi

# ── stage DB ─────────────────────────────────────────────────────────
# Fresh copy every run: the replay logs in and writes session state, and
# stale WAL/SHM artifacts from a crashed run would skew the next one.
step "staging benchmark DB"
DB="$OUT_TREE/storage/bench.sqlite3"
mkdir -p "$(dirname "$DB")"
rm -f "$DB" "$DB-wal" "$DB-shm"
sqlite3 "$SRC/db/production.sqlite3" ".backup $DB"

# ── provenance ───────────────────────────────────────────────────────
# Run under the target interpreter so RUBY_DESCRIPTION names the runtime
# actually replayed (jruby vs cruby), not whatever `ruby` is on PATH.
"$RUBY_BIN" -rjson -e 'puts JSON.pretty_generate({
  generated_at: Time.now.utc.strftime("%FT%TZ"),
  command: ARGV[0], src: ARGV[1],
  runtime: ARGV[3],
  roundhouse_commit: `git -C #{ARGV[2]} rev-parse HEAD`.strip,
  ruby: RUBY_DESCRIPTION,
  java_opts: ENV["JAVA_OPTS"],
})' "scripts/bench-lobsters $ORIG_ARGS" "$SRC" "$REPO_ROOT" "$RUNTIME" > "$OUT_DIR/env.json" || true

# ── runtime gems ─────────────────────────────────────────────────────
# The replay runs under the ambient interpreter's gem home, not a bundle.
# A runtime bump empties the per-version gem dir (same hazard scripts/bench
# self-heals around), so check-then-install rather than assume. markly +
# nokogiri back Markdowner (guarded requires in the overlay: boot survives
# without them but /u/:username fails), so a fresh box needs them too. The
# GEMS set is runtime-resolved above (jruby swaps sqlite3->jdbc-sqlite3 and
# drops markly, which its tree provides via the commonmark-java shim); the
# gem tool is the interpreter's own so java-platform builds resolve.
if [[ "$RUNTIME" == jruby ]]; then GEM=(jruby -S gem); else GEM=(gem); fi
for g in "${GEMS[@]}"; do
    if ! "${GEM[@]}" list -i "^${g}$" >/dev/null 2>&1; then
        step "installing gem $g ($RUNTIME)"
        "${GEM[@]}" install --no-document "$g" >/dev/null
    fi
done

# ── Rails side (P6 comparison) ───────────────────────────────────────
FROZEN_SEQ="$REPO_ROOT/bench/lobsters/frozen-sequence.json"
if (( VS_RAILS == 1 )); then
    step "timing real Rails on the frozen sequence (boot + 15 warmup + >=10 iters; several minutes)"
    ruby "$REPO_ROOT/scripts/lobsters-rails-replay" \
        --src "$SRC" \
        --seq-out "$OUT_DIR/sequence.json" \
        --json "$OUT_DIR/rails.json"
    if [[ -f "$FROZEN_SEQ" ]]; then
        if ! diff -q "$FROZEN_SEQ" "$OUT_DIR/sequence.json" >/dev/null; then
            fail "regenerated sequence DIFFERS from $FROZEN_SEQ — ruby-bench DB/generator changed; comparison vs older runs is invalid"
        fi
    else
        mkdir -p "$(dirname "$FROZEN_SEQ")"
        cp "$OUT_DIR/sequence.json" "$FROZEN_SEQ"
        ok "froze sequence at $FROZEN_SEQ (commit it)"
    fi
fi

# ── replay ───────────────────────────────────────────────────────────
step "replaying benchmark routes under $RUNTIME (in-process Main.run_rack)"
REPLAY_ARGS=(--json "$OUT_DIR/summary.json" --md "$OUT_DIR/summary.md")
if (( TIME_ITERS > 0 )); then
    REPLAY_ARGS+=(--time "$TIME_ITERS")
    # The --vs-rails and --frozen paths time the frozen --sequence, which
    # keeps its OWN established warmup (15) so the canonical-metric
    # methodology stays fixed — the per-runtime WARMUP default doesn't
    # touch it. An EXPLICIT --warmup overrides everywhere: the jruby
    # sequence lane needs a longer warm run than the CRuby-derived 15.
    if (( VS_RAILS == 0 && FROZEN == 0 )) || (( WARMUP_EXPLICIT == 1 )); then
        REPLAY_ARGS+=(--warmup "$WARMUP")
    fi
fi
(( MEMORY == 1 ))    && REPLAY_ARGS+=(--memory)
(( VS_RAILS == 1 ))  && REPLAY_ARGS+=(--sequence "$OUT_DIR/sequence.json")
# --frozen replays the COMMITTED frozen sequence (no Rails boot, no per-run
# regeneration) so an emit-only run lands on the exact ruby-bench workload.
(( FROZEN == 1 ))    && REPLAY_ARGS+=(--sequence "$FROZEN_SEQ")

status=0
(cd "$OUT_TREE" && "$RUBY_BIN" "$REPO_ROOT/scripts/lobsters-replay" "${REPLAY_ARGS[@]}") || status=$?

# ── compare against the previous run ─────────────────────────────────
# Resolve the runtime's own `latest` BEFORE repointing it (cruby keeps the
# bare `latest` for back-compat; other runtimes get `latest-<runtime>`) so
# the two lanes never cross-compare. Regressions print loudly so a
# `>> bench.log` cron capture is greppable (PARITY REGRESSION).
#
# Skipped entirely when --out was given explicitly: that means a caller (e.g.
# scripts/lobsters-matrix) owns result placement, and repointing the shared
# `latest` symlink at a run buried under a caller's dir would break it.
LATEST_NAME="latest"; [[ "$RUNTIME" != cruby ]] && LATEST_NAME="latest-$RUNTIME"
PREV_LINK="$REPO_ROOT/bench/results/lobsters/$LATEST_NAME"
if (( EXPLICIT_OUT == 0 )) && [[ -f "$OUT_DIR/summary.json" ]]; then
    PREV_NAME="$(readlink "$PREV_LINK" 2>/dev/null || echo previous)"
    PREV_SUM="$PREV_LINK/summary.json"
    # `latest` may point at a lane-layout run (no root summary); compare
    # against its matching emit lane instead.
    if [[ ! -f "$PREV_SUM" ]]; then
        PREV_SUM="$PREV_LINK/ruby/summary.json"
        [[ "$RUNTIME" == jruby ]] && PREV_SUM="$PREV_LINK/jruby/summary.json"
    fi
    [[ -f "$PREV_SUM" ]] && compare_parity "$PREV_NAME" "$PREV_SUM" "$OUT_DIR/summary.json"
fi

# ── roundhouse vs Rails ──────────────────────────────────────────────
if (( VS_RAILS == 1 )) && [[ -f "$OUT_DIR/rails.json" && -f "$OUT_DIR/summary.json" ]]; then
    ruby -rjson -e '
      rails   = JSON.parse(File.read(ARGV[0]))
      ours    = JSON.parse(File.read(ARGV[1]))["sequence_timing"]
      abort "no sequence_timing in summary.json" unless ours
      r, o = rails["ms_per_iter_median"], ours["ms_per_iter_median"]
      ratio = (r / o).round(2)
      partial = ours["partial"] ? " [PARTIAL — #{ours["failed_visits"]} failing visits]" : ""
      puts "", "== roundhouse vs Rails (frozen #{rails["visits_per_iter"]}-visit sequence) =="
      puts "  rails:      #{r} ms/iter (#{rails["iterations"]} iters, #{rails["ruby"][/ruby [^ ]+/]}, rails #{rails["rails"]})"
      puts "  roundhouse: #{o} ms/iter (#{ours["iterations"]} iters)#{partial}"
      puts "  ratio:      #{ratio}x #{r > o ? "faster" : "SLOWER"} than Rails"
      md = "\n## roundhouse vs Rails\n\n| stack | ms/iter median | iters |\n|-------|---:|---:|\n" \
           "| rails #{rails["rails"]} | #{r} | #{rails["iterations"]} |\n" \
           "| roundhouse#{partial} | #{o} | #{ours["iterations"]} |\n\n" \
           "**#{ratio}x #{r > o ? "faster" : "slower"} than Rails**\n"
      File.write(ARGV[2], md, mode: "a")
    ' "$OUT_DIR/rails.json" "$OUT_DIR/summary.json" "$OUT_DIR/summary.md" || true
fi

# Repoint the shared `latest` symlink only for default-placement runs; a
# caller passing --out (the matrix) manages its own tree.
(( EXPLICIT_OUT == 0 )) && ln -sfn "$(basename "$OUT_DIR")" "$REPO_ROOT/bench/results/lobsters/$LATEST_NAME" 2>/dev/null || true
ok "summary written to $OUT_DIR/summary.md"
exit "$status"
