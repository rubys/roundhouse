#!/usr/bin/env ruby
# scripts/bench-report — render a bench summary.json to self-contained HTML.
#
# Usage:
#   scripts/bench-report PATH/TO/summary.json [OUT.html]
#
# Defaults OUT to index.html alongside the input. Pure stdlib; inline
# SVG charts; no JS, no CDN. Open the resulting file directly in a
# browser, archive it, or serve it statically — the chart artifacts
# outlive any chart library's CDN.

require 'json'
require 'time'

input = ARGV[0] or abort "usage: scripts/bench-report PATH/TO/summary.json [OUT.html]"
out   = ARGV[1] || File.join(File.dirname(File.expand_path(input)), 'index.html')

cells = JSON.parse(File.read(input))

# env.json is written by scripts/bench alongside summary.json. Optional:
# reports for runs that predate it (or hand-assembled summaries) still
# render, just without the provenance line and environment appendix.
run_path = File.dirname(File.expand_path(input))
env = begin
  JSON.parse(File.read(File.join(run_path, 'env.json')))
rescue Errno::ENOENT, JSON::ParserError
  nil
end

# per-run.json is JSONL (one record per timed run) written alongside
# summary.json — the only place the run-to-run spread survives the median
# collapse. Optional, same as env.json: older runs render without the
# stability section. Tolerate a partially-written / truncated tail line.
per_run = begin
  path = File.join(run_path, 'per-run.json')
  if File.exist?(path)
    File.readlines(path).filter_map do |line|
      line = line.strip
      JSON.parse(line) unless line.empty?
    rescue JSON::ParserError
      nil
    end
  end
end

# ── ordering / metadata ──────────────────────────────────────────────

TARGET_ORDER = %w[rust crystal go kotlin swift spinel elixir typescript python ruby ruby-int jruby rails rails-int rails-jruby]
ENDPOINT_ORDER = %w[/articles /articles/1 /articles/new /articles.json /articles/1.json]

# Brand-ish but muted; enough contrast in greyscale.
COLOR = {
  'rust'       => '#b7410e',
  'crystal'    => '#1c1c1c',
  'go'         => '#00add8',
  'kotlin'     => '#c711a8',
  'swift'      => '#f05138',
  'spinel'     => '#7d4cdb',
  'elixir'     => '#4b275f',
  'typescript' => '#3178c6',
  'python'     => '#3776ab',
  'ruby'       => '#cc342d',
  'ruby-int'   => '#e89c93',
  'jruby'      => '#5382a1',
  'rails'      => '#666666',
  'rails-int'  => '#aaaaaa',
  'rails-jruby' => '#46707f',
}

GROUP_LABEL = {
  'AOT'      => 'compiled (AOT)',
  'JIT'      => 'JIT / interpreter',
  'interp'   => 'interpreter, no JIT',
  'baseline' => 'Rails baseline',
}

# ── index data ───────────────────────────────────────────────────────

by = Hash.new { |h, k| h[k] = {} }
cells.each { |c| by[c['endpoint']][c['target']] = c }

endpoints = ENDPOINT_ORDER & by.keys
targets   = TARGET_ORDER & cells.map { |c| c['target'] }.uniq

run_dir   = File.basename(File.dirname(File.expand_path(input)))
total     = cells.size
runs      = cells.first['runs']

# ── number formatting ────────────────────────────────────────────────

def fmt_int(n)  ; n.to_i.to_s.reverse.scan(/\d{1,3}/).join(',').reverse ; end
def fmt_dec(n, p = 1) ; format("%.#{p}f", n.to_f) ; end

# ── env.json helpers ─────────────────────────────────────────────────

def lscpu_field(env, name)
  rows = env && env.dig('cpu', 'lscpu', 'lscpu')
  rows && rows.find { |r| r['field'] == "#{name}:" }&.dig('data')
end

def kv_table(rows)
  out = +"<table>\n<tbody>\n"
  rows.each do |k, v|
    next if v.nil? || v.to_s.empty?
    out << "<tr><th>#{k}</th><td>#{v}</td></tr>\n"
  end
  out << "</tbody></table>\n"
end

# ── SVG primitives ───────────────────────────────────────────────────

def svg_open(w, h)
  %(<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 #{w} #{h}" ) +
  %(width="#{w}" height="#{h}" font-family="-apple-system,system-ui,sans-serif" font-size="12">)
end

def svg_close ; '</svg>' ; end

def t(x, y, s, anchor: 'start', size: 12, weight: nil, fill: '#222')
  a = %(text-anchor="#{anchor}" font-size="#{size}" fill="#{fill}")
  a << %( font-weight="#{weight}") if weight
  %(<text x="#{x}" y="#{y}" #{a}>#{s}</text>)
end

def r(x, y, w, h, fill:, stroke: nil)
  s = stroke ? %( stroke="#{stroke}") : ''
  %(<rect x="#{x}" y="#{y}" width="#{w}" height="#{h}" fill="#{fill}"#{s}/>)
end

def l(x1, y1, x2, y2, stroke: '#ddd', sw: 1, dash: nil)
  d = dash ? %( stroke-dasharray="#{dash}") : ''
  %(<line x1="#{x1}" y1="#{y1}" x2="#{x2}" y2="#{y2}" stroke="#{stroke}" stroke-width="#{sw}"#{d}/>)
end

# ── log-scale horizontal bar chart (one per endpoint) ────────────────

def hbar_log(rows, metric:, unit:, min_decade: 2, max_decade: nil)
  values = rows.map { |c| c[metric].to_f }
  max_decade ||= [Math.log10(values.max).ceil, min_decade + 1].max

  width      = 760
  left_pad   = 110
  right_pad  = 100
  plot_w     = width - left_pad - right_pad
  row_h      = 22
  gap        = 6
  top        = 10
  bottom     = 28
  height     = top + (row_h + gap) * rows.size + bottom

  buf = +svg_open(width, height)

  # X-axis decade gridlines + labels
  decades = (min_decade..max_decade).to_a
  decades.each do |d|
    x = left_pad + (d - min_decade).to_f / (max_decade - min_decade) * plot_w
    buf << l(x, top, x, height - bottom, stroke: '#e5e5e5')
    label = 10 ** d
    buf << t(x, height - bottom + 14, fmt_int(label), anchor: 'middle', fill: '#666', size: 10)
  end
  buf << t(width - 4, height - bottom + 14, unit, anchor: 'end', fill: '#999', size: 10)

  # Sort rows by metric desc for visual ranking
  ranked = rows.sort_by { |c| -c[metric].to_f }

  ranked.each_with_index do |c, i|
    y = top + i * (row_h + gap)
    v = c[metric].to_f
    lv = Math.log10([v, 1].max)
    bar = ((lv - min_decade) / (max_decade - min_decade) * plot_w).round
    bar = [bar, 1].max

    target = c['target']
    buf << t(left_pad - 8, y + row_h * 0.7, target, anchor: 'end', weight: 'bold')
    buf << r(left_pad, y, bar, row_h, fill: COLOR[target])
    label = metric == 'req_sec' ? fmt_int(v) : fmt_int(v)
    buf << t(left_pad + bar + 6, y + row_h * 0.7, label, fill: '#222')
  end

  buf << svg_close
  buf
end

# ── grouped vertical bars (lowerer dividend, YJIT, multiplier) ───────

def grouped_bars(groups, series:, max: nil, value_fmt: ->(v) { fmt_int(v) }, suffix: '')
  # groups: [{label:, values: {series_key => value}}]
  width      = 760
  left_pad   = 50
  right_pad  = 20
  plot_w     = width - left_pad - right_pad
  bot_pad    = 60
  top_pad    = 30
  plot_h     = 240
  height     = top_pad + plot_h + bot_pad

  all_vals = groups.flat_map { |g| g[:values].values }.compact
  max_v = max || ((all_vals.max || 0) * 1.15)
  max_v = 1.0 if !max_v.is_a?(Numeric) || !max_v.finite? || max_v <= 0
  band  = plot_w.to_f / groups.size
  bar_count = series.size
  bar_w = [(band - 24) / bar_count, 80].min
  inner_gap = 4

  buf = +svg_open(width, height)

  # Y-axis gridlines (nice round ticks at 5 levels)
  step = nice_step(max_v / 5.0)
  ticks = (0..(max_v / step).ceil).map { |i| i * step }
  ticks.each do |v|
    y = top_pad + plot_h - (v / max_v) * plot_h
    buf << l(left_pad, y, width - right_pad, y, stroke: '#eee')
    buf << t(left_pad - 6, y + 4, fmt_int(v), anchor: 'end', fill: '#888', size: 10)
  end

  groups.each_with_index do |g, gi|
    cx = left_pad + band * gi + band / 2
    series.each_with_index do |key, si|
      v = g[:values][key].to_f
      bx = cx - (bar_w * bar_count + inner_gap * (bar_count - 1)) / 2.0 + si * (bar_w + inner_gap)
      bh = (v / max_v) * plot_h
      by = top_pad + plot_h - bh
      buf << r(bx, by, bar_w, bh, fill: COLOR[key])
      buf << t(bx + bar_w / 2.0, by - 4, value_fmt.call(v) + suffix,
               anchor: 'middle', fill: '#444', size: 10)
    end
    # Endpoint label
    buf << t(cx, top_pad + plot_h + 16, g[:label],
             anchor: 'middle', fill: '#333', size: 11)
    # Multi-line second-row annotation
    if g[:annotation]
      buf << t(cx, top_pad + plot_h + 32, g[:annotation],
               anchor: 'middle', fill: '#666', size: 11, weight: 'bold')
    end
  end

  # Legend
  legend_y = 16
  legend_x = left_pad
  series.each do |key|
    buf << r(legend_x, legend_y - 10, 14, 12, fill: COLOR[key])
    buf << t(legend_x + 18, legend_y, key, fill: '#333')
    legend_x += 110
  end

  buf << svg_close
  buf
end

def nice_step(raw)
  # Guard against degenerate input: an all-zero / empty series (e.g. a
  # partial run that didn't measure a target this chart references)
  # yields raw <= 0, and Math.log10(0) is -Infinity, which #floor
  # rejects with FloatDomainError. Fall back to a step of 1.
  return 1.0 unless raw.is_a?(Numeric) && raw.finite? && raw > 0
  exp = Math.log10(raw).floor
  base = 10 ** exp
  frac = raw / base
  step_frac = if frac < 1.5 then 1
              elsif frac < 3 then 2
              elsif frac < 7 then 5
              else 10
              end
  step_frac * base
end

# ── HTML scaffold ────────────────────────────────────────────────────

styles = <<~CSS
  body { font-family: -apple-system, system-ui, sans-serif; color: #222;
         max-width: 880px; margin: 2em auto; padding: 0 1em; line-height: 1.5; }
  h1 { font-size: 1.6em; margin-bottom: 0.2em; }
  h2 { font-size: 1.2em; margin-top: 2em; border-bottom: 1px solid #ddd;
       padding-bottom: 0.2em; }
  h3 { font-size: 1.0em; color: #555; margin: 1.4em 0 0.4em; }
  .meta { color: #666; font-size: 0.9em; margin-bottom: 1em; }
  .methodology { background: #f7f7f7; border-left: 3px solid #ccc;
                 padding: 0.6em 1em; font-size: 0.92em; }
  .methodology code { background: #ececec; padding: 0.05em 0.3em;
                      border-radius: 3px; font-size: 0.9em; }
  .caveat { color: #777; font-size: 0.9em; font-style: italic; }
  table { border-collapse: collapse; font-size: 0.88em; margin: 0.4em 0; }
  th, td { padding: 4px 10px; border-bottom: 1px solid #eee; }
  th { text-align: left; }
  td.num { text-align: right; font-variant-numeric: tabular-nums; }
  details summary { cursor: pointer; color: #555; padding: 0.4em 0; }
  .legend { font-size: 0.85em; color: #666; }
  svg { display: block; margin: 0.4em auto; }
CSS

html = +"<!doctype html>\n<html lang=en>\n<head>\n<meta charset=utf-8>\n"
html << "<title>Roundhouse bench — #{run_dir}</title>\n<style>#{styles}</style>\n</head>\n<body>\n"

html << "<h1>Roundhouse benchmark results</h1>\n"
provenance = ''
if env
  sha = env.dig('git', 'sha').to_s[0, 12]
  provenance << " · captured #{env['captured_at']}" if env['captured_at']
  provenance << %( · <code>#{sha}</code>) unless sha.empty?
end
html << %(<div class="meta">Run <code>#{run_dir}</code>#{provenance} · #{total} cells × #{runs} runs · #{endpoints.size} endpoints × #{targets.size} targets</div>\n)

# Sibling artifacts published alongside this page (relative links, so
# they work both served and opened from the run directory directly).
artifacts = %w[env.json per-run.json summary.json summary.md]
  .select { |f| File.exist?(File.join(run_path, f)) }
unless artifacts.empty?
  html << %(<div class="meta">Artifacts: #{artifacts.map { |f| %(<a href="#{f}"><code>#{f}</code></a>) }.join(' · ')}</div>\n)
end

# Keep the methodology prose generic — machine and harness specifics come
# from env.json (with a bland fallback when it's absent); exact toolchain
# versions live in the environment appendix at the bottom of the page.
if env
  clock   = env['clock'] || {}
  ghz     = clock['max_khz'] ? fmt_dec(clock['max_khz'].to_i / 1_000_000.0, 1) + ' GHz' : nil
  boost   = clock['boost'] == '0' ? '<strong>boost disabled</strong>' : 'boost enabled'
  machine = [
    lscpu_field(env, 'Model name'),
    "#{lscpu_field(env, 'Core(s) per socket')}c/#{lscpu_field(env, 'CPU(s)')}t",
    ghz, boost,
    clock['governor'] ? "governor=#{clock['governor']}" : nil,
  ].compact.join(', ')
  machine << ", #{(env['memory_mb'].to_f / 1024).round} GB RAM" if env['memory_mb']
  machine << ", #{env.dig('os', 'pretty_name')}" if env.dig('os', 'pretty_name')
  h       = env['harness'] || {}
  harness = "workers=#{Array(h['workers']).join('/')}, c=#{h['concurrency']}, " \
            "#{h['runs']}×#{h['duration_sec']}s runs per cell after #{h['warmup_sec']}s warmup"
  appendix_ref = ' Full hardware, toolchain versions, and the exact invocation are in the <a href="#environment">environment appendix</a> below.'
else
  machine = 'Bare-metal Linux host, frequency boost disabled, governor=performance'
  harness = "workers=1, c=64, #{runs} runs per cell"
  appendix_ref = ''
end

# Only point at the stability section when per-run.json is present to back
# it (older runs render without that section, and the anchor with it).
spread_ref = per_run && !per_run.empty? ? ' (the run-to-run spread is in the <a href="#stability">stability</a> section below)' : ''

html << <<~METHOD
  <div class="methodology">
    <strong>Methodology.</strong> #{machine}. Toolchains pinned via <a href="https://mise.jdx.dev">mise</a>. Harness: <code>scripts/bench</code> — #{harness}; the median of the #{runs} runs is reported#{spread_ref}. Quiet machine throughout. The JVM cells (<code>jruby</code>, <code>kotlin</code>) run under a fixed JVM heap (<code>-Xmx512m=-Xms512m</code>): their RSS is a deliberate budget, not the JVM's default share of host RAM, so they stay comparable to the other cells' working sets.#{appendix_ref}
    <p class="caveat">These numbers measure one specific Rails reference app — not arbitrary Rails workloads. See <a href="https://github.com/rubys/roundhouse/issues/16">#16</a> for the fixture-fragility caveats.</p>
    #{(targets.include?('rails-jruby') ? %(<p class="caveat"><code>rails-jruby</code> is the stock-Rails-on-the-JVM baseline — the same blog, pinned to <strong>Rails 8.0</strong> (one minor behind the others' 8.1) on a <strong>prerelease</strong> AR-JDBC adapter (<code>activerecord-jdbcsqlite3-adapter 80.0.pre1</code>), the only combination that drives ActiveRecord on JRuby 10 today.</p>) : '')}
    #{(targets.include?('spinel') ? %(<p class="caveat"><code>spinel</code> runs the <em>same</em> Roundhouse-emitted framework as the CRuby <code>ruby</code> cell, but on the <a href="https://github.com/matz/spinel">Spinel</a> VM behind the Tep fiber server rather than CRuby + Puma — so the <code>ruby</code> → <code>spinel</code> gap is a runtime swap, not a framework or source change.</p>) : '')}
  </div>
METHOD

# ── Section: throughput per endpoint ─────────────────────────────────

html << "<h2>1. Throughput across targets</h2>\n"
html << %(<p>Each endpoint is its own chart. Bars are log-scaled; raw req/sec is shown at the right.</p>\n)
endpoints.each do |ep|
  rows = targets.map { |t| by[ep][t] }.compact
  html << "<h3>#{ep}</h3>\n"
  html << hbar_log(rows, metric: 'req_sec', unit: 'req/sec', min_decade: 2, max_decade: 6)
end

# ── Section: lowerer dividend ────────────────────────────────────────

# Cross-language comparison: only meaningful when both ruby and rails
# were measured this run. Skip the whole section otherwise so a partial
# run (e.g. spinel-only) still produces a report.
if (%w[ruby rails] - targets).empty?
  html << "<h2>2. Lowerer dividend (ruby vs rails)</h2>\n"
  html << <<~P
    <p>Same Ruby interpreter, same YJIT, same Puma — the only variable is whether the framework runtime is Rails or Roundhouse-emitted. The multiplier above each pair is the lift from the lowerer pipeline.</p>
  P

  groups = endpoints.map do |ep|
    ruby_v  = by[ep]['ruby']&.dig('req_sec').to_f
    rails_v = by[ep]['rails']&.dig('req_sec').to_f
    {
      label:      ep,
      annotation: rails_v > 0 ? "#{fmt_dec(ruby_v / rails_v, 1)}×" : '',
      values:     { 'ruby' => ruby_v, 'rails' => rails_v },
    }
  end
  html << grouped_bars(groups, series: %w[ruby rails])

  # The same swap on the JVM, reported as the measured ratio when both
  # JRuby cells ran.
  if (%w[jruby rails-jruby] - targets).empty?
    jr   = by['/articles']['jruby']&.dig('req_sec').to_f
    rjr  = by['/articles']['rails-jruby']&.dig('req_sec').to_f
    rb   = by['/articles']['ruby']&.dig('req_sec').to_f
    rl   = by['/articles']['rails']&.dig('req_sec').to_f
    if rjr > 0 && rl > 0
      html << %(<p>The same comparison <em>on the JVM</em>: emitted <code>jruby</code> beats stock <code>rails-jruby</code> by <strong>#{fmt_dec(jr / rjr, 0)}×</strong> on <code>/articles</code>, against <strong>#{fmt_dec(rb / rl, 0)}×</strong> for <code>ruby</code> over <code>rails</code> on CRuby.</p>\n)
    end
  end
end

# ── Section: YJIT contribution ───────────────────────────────────────

# Restrict to the JIT/interp variants that were actually measured; skip
# the section if none of them ran.
yjit_series = %w[ruby ruby-int rails rails-int] & targets
unless yjit_series.empty?
  html << "<h2>3. YJIT contribution</h2>\n"
  html << <<~P
    <p>Each pair compares a cell with YJIT (<code>ruby</code>, <code>rails</code>) against its interpreter-only variant (<code>ruby-int</code>, <code>rails-int</code>). The bars show how far YJIT moves each.</p>
  P

  yjit_groups = endpoints.map do |ep|
    {
      label:  ep,
      values: yjit_series.each_with_object({}) { |t, h| h[t] = by[ep][t]&.dig('req_sec').to_f },
    }
  end
  html << grouped_bars(yjit_groups, series: yjit_series)
end

# ── Section: cost economics ──────────────────────────────────────────

html << "<h2>4. Cost economics (req/sec per GB of RSS)</h2>\n"
html << <<~P
  <p>Throughput normalized by memory footprint — req/sec divided by RSS in GB. This reorders the raw throughput charts above: targets with small working sets rise and high-RSS targets fall. Bars are log-scaled. How much the metric matters depends on the deployment shape — most on metered or serverless surfaces, least on bare metal with memory headroom.</p>
P
endpoints.each do |ep|
  rows = targets.map { |t| by[ep][t] }.compact
  html << "<h3>#{ep}</h3>\n"
  html << hbar_log(rows, metric: 'rps_per_gb', unit: 'req/sec/GB', min_decade: 3, max_decade: 7)
end

# ── Section: HTML→JSON multiplier ────────────────────────────────────

html << "<h2>5. HTML → JSON multiplier</h2>\n"
html << <<~P
  <p>Per-target lift going from <code>/articles</code> (HTML) to <code>/articles.json</code> (JSON). The asymmetry isn't JSON-escape vs HTML-escape — both paths concatenate and escape strings. What JSON skips is the <em>layout chain</em> (csrf_meta_tag, importmap, asset-manifest scan, content_for slots) and the <em>per-row view helpers</em> (link_to, button_to, dom_id, tag.*) that the HTML index template invokes for every record. The chart below shows the multiplier per target.</p>
P

if targets.include?('rails-jruby')
  rjr_html = by['/articles']['rails-jruby']&.dig('req_sec').to_f
  rjr_json = by['/articles.json']['rails-jruby']&.dig('req_sec').to_f
  if rjr_html > 0 && rjr_json > 0 && rjr_json < rjr_html
    html << %(<p><code>rails-jruby</code>'s multiplier falls below 1× (#{fmt_dec(rjr_json / rjr_html, 1)}×): its JSON endpoint measures slower than its HTML one.</p>\n)
  end
end

# Collapse the JIT/non-JIT variants, compute each target's HTML→JSON
# multiplier, then rank by it (like the other bar charts) so the chart
# reads as an ordering rather than canonical target order.
mult_values = (targets - %w[ruby-int rails-int]).each_with_object({}) do |t, h|
  html_v = by['/articles'][t]&.dig('req_sec').to_f
  json_v = by['/articles.json'][t]&.dig('req_sec').to_f
  h[t] = html_v > 0 ? (json_v / html_v) : 0
end
mult_targets = mult_values.keys.sort_by { |t| -mult_values[t] }
# Single-group chart looks silly; redraw as per-target bars
html << <<~SVG
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 760 #{40 + 30 * mult_targets.size}" width="760">
    #{mult_targets.each_with_index.map { |tgt, i|
      v = mult_values[tgt]
      bar_w = ((v / 6.0) * 540).round
      y = 20 + i * 28
      [
        %(<text x="100" y="#{y + 14}" text-anchor="end" font-weight="bold" font-family="-apple-system,system-ui,sans-serif" font-size="12">#{tgt}</text>),
        %(<rect x="110" y="#{y}" width="#{bar_w}" height="20" fill="#{COLOR[tgt]}"/>),
        %(<text x="#{110 + bar_w + 6}" y="#{y + 14}" font-family="-apple-system,system-ui,sans-serif" font-size="12">#{fmt_dec(v, 1)}×</text>)
      ].join
    }.join}
    #{[1, 2, 3, 4, 5, 6].map { |d|
      x = 110 + (d / 6.0) * 540
      %(<line x1="#{x}" y1="10" x2="#{x}" y2="#{20 + 28 * mult_targets.size}" stroke="#e5e5e5"/>) +
      %(<text x="#{x}" y="#{30 + 28 * mult_targets.size}" text-anchor="middle" font-size="10" fill="#888" font-family="-apple-system,system-ui,sans-serif">#{d}×</text>)
    }.join}
  </svg>
SVG

# ── Section: memory footprint ────────────────────────────────────────

html << "<h2>6. Memory footprint (RSS)</h2>\n"
html << "<p>Max RSS observed across all endpoints, per target, sorted low to high. The field spans more than two orders of magnitude. The three JVM cells run under a fixed heap budget rather than an organically-grown working set — see the note below the chart.</p>\n"

mem_rows = targets.map do |tgt|
  max_rss = endpoints.map { |ep| by[ep][tgt]&.dig('rss_mb').to_f }.max
  { 'target' => tgt, 'rss_mb' => max_rss }
end
mem_rows.sort_by! { |r| r['rss_mb'] }

mem_max = mem_rows.map { |r| r['rss_mb'] }.max
mem_svg_h = 30 + 28 * mem_rows.size
html << svg_open(760, mem_svg_h)
mem_rows.each_with_index do |row, i|
  y = 10 + i * 28
  v = row['rss_mb']
  bar = (v / mem_max * 540).round
  html << t(100, y + 14, row['target'], anchor: 'end', weight: 'bold')
  html << r(110, y, bar, 20, fill: COLOR[row['target']])
  html << t(110 + bar + 6, y + 14, "#{fmt_int(v)} MB", fill: '#444')
end
html << svg_close
if targets.include?('jruby')
  html << %(<p class="caveat">The JVM cells run under a fixed <code>-Xmx512m</code> heap, so the heap can't grab a host-dependent share of RAM; the rest is metaspace and code-cache, bounded by the app's class count rather than the box. Read the JVM bars as a pinned budget, not an organically-grown working set like the other cells.</p>\n)
end

# ── Section: latency ─────────────────────────────────────────────────

html << "<h2>7. Latency (p50 / p99 at c=64)</h2>\n"
html << "<p>Latencies are at c=64 concurrent connections; treat p50 as the median per-connection wait and p99 as the tail. Rows are ordered by measured median p50 across endpoints, fastest first.</p>\n"

html << "<table>\n<thead><tr><th>target</th>"
endpoints.each { |ep| html << "<th colspan=2>#{ep}</th>" }
html << "</tr>\n<tr><th></th>"
endpoints.each { html << "<th>p50</th><th>p99</th>" }
html << "</tr></thead>\n<tbody>\n"
# Order rows by latency (median p50 across endpoints, ascending) so the
# table reads as a ranking like the sorted bar charts. Median is robust
# to single-endpoint outliers.
lat_order = targets.sort_by do |tgt|
  ps = endpoints.map { |ep| by[ep][tgt]&.dig('p50_ms') }.compact.sort
  ps.empty? ? Float::INFINITY : ps[ps.size / 2]
end
lat_order.each do |tgt|
  html << "<tr><td><strong>#{tgt}</strong></td>"
  endpoints.each do |ep|
    c = by[ep][tgt]
    if c
      html << %(<td class="num">#{fmt_dec(c['p50_ms'], 1)}</td><td class="num">#{fmt_dec(c['p99_ms'], 1)}</td>)
    else
      html << "<td>-</td><td>-</td>"
    end
  end
  html << "</tr>\n"
end
html << "</tbody></table>\n"
html << %(<p class="legend">All values in milliseconds. Lower is better.</p>\n)

# ── Section: run-to-run stability (from per-run.json) ────────────────

# The summary collapses each cell to its median run; per-run.json is the
# only artifact that keeps the individual runs, so the spread lives here.
# Fully data-driven (no hand-tuned numbers) so it can't go stale: the
# headline CV, the outlier threshold, and the cold-first-run count are all
# computed from the records read above. Skipped entirely when per-run.json
# is absent (older runs) or yields no usable rows.
if per_run && !per_run.empty?
  # Group by cell; keep each run's req/sec ordered by its run index so the
  # per-run columns line up regardless of file order.
  series = Hash.new { |h, k| h[k] = [] }
  per_run.each do |row|
    next unless row['target'] && row['endpoint'] && row['req_sec']
    series[[row['target'], row['endpoint']]] << [row['run'].to_i, row['req_sec'].to_f]
  end

  stats = series.filter_map do |(tgt, ep), pairs|
    vs = pairs.sort_by(&:first).map(&:last)
    next if vs.empty?
    mean = vs.sum / vs.size
    sd   = Math.sqrt(vs.map { |v| (v - mean)**2 }.sum / vs.size)
    cv   = mean > 0 ? sd / mean * 100 : 0.0
    { target: tgt, endpoint: ep, runs: vs, cv: cv }
  end

  unless stats.empty?
    cvs        = stats.map { |s| s[:cv] }.sort
    median_cv  = cvs[cvs.size / 2]
    runs_each  = series.values.map(&:size).max
    threshold  = 3.0
    warmup     = env&.dig('harness', 'warmup_sec')

    html << %(<h2 id="stability">Run-to-run stability</h2>\n)
    html << <<~P
      <p>Each cell is timed #{runs_each} times and the charts above report the median run. This section reads <code>per-run.json</code> directly to show how far the individual runs strayed from it. Across all #{stats.size} cells the median run-to-run coefficient of variation in req/sec is <strong>#{fmt_dec(median_cv, 2)}%</strong> — the timed runs of a given cell agree to a fraction of a percent, so the reported medians aren't masking noise.</p>
    P

    noisy = stats.select { |s| s[:cv] >= threshold }.sort_by { |s| -s[:cv] }
    if noisy.empty?
      html << %(<p>No cell varies by more than #{fmt_dec(threshold, 0)}% across its runs.</p>\n)
    else
      cold_first = noisy.count { |s| s[:runs].size > 1 && s[:runs].first == s[:runs].min }
      warm_note  = if cold_first > 0
        warmup_txt = warmup ? "fixed #{warmup}s warmup" : 'fixed warmup window'
        "; in #{cold_first} of them the first timed run is the slowest, consistent with residual warmup the #{warmup_txt} doesn't fully absorb"
      else
        ''
      end
      html << %(<p>The #{noisy.size} cell#{noisy.size == 1 ? '' : 's'} that vary by more than #{fmt_dec(threshold, 0)}% are concentrated in the lowest-throughput cells, where a small absolute swing is a larger fraction of the rate#{warm_note}:</p>\n)
      html << "<table>\n<thead><tr><th>target</th><th>endpoint</th>"
      (1..runs_each).each { |i| html << "<th>run #{i}</th>" }
      html << "<th>CV</th></tr></thead>\n<tbody>\n"
      noisy.each do |s|
        html << "<tr><td><strong>#{s[:target]}</strong></td><td>#{s[:endpoint]}</td>"
        runs_each.times { |i| html << %(<td class="num">#{s[:runs][i] ? fmt_int(s[:runs][i]) : '-'}</td>) }
        html << %(<td class="num">#{fmt_dec(s[:cv], 1)}%</td></tr>\n)
      end
      html << "</tbody></table>\n"
      html << %(<p class="legend">req/sec per timed run; CV = standard deviation ÷ mean.</p>\n)
    end
  end
end

# ── Section: raw data table ──────────────────────────────────────────

html << "<details>\n<summary>Raw cell data (#{cells.size} rows)</summary>\n"
html << "<table>\n<thead><tr><th>target</th><th>endpoint</th><th>req/sec</th><th>p50 (ms)</th><th>p99 (ms)</th><th>RSS (MB)</th><th>req/sec/GB</th></tr></thead>\n<tbody>\n"
cells.sort_by { |c| [TARGET_ORDER.index(c['target']) || 99, ENDPOINT_ORDER.index(c['endpoint']) || 99] }.each do |c|
  html << "<tr>"
  html << "<td>#{c['target']}</td>"
  html << "<td>#{c['endpoint']}</td>"
  html << %(<td class="num">#{fmt_int(c['req_sec'])}</td>)
  html << %(<td class="num">#{fmt_dec(c['p50_ms'], 2)}</td>)
  html << %(<td class="num">#{fmt_dec(c['p99_ms'], 2)}</td>)
  html << %(<td class="num">#{fmt_int(c['rss_mb'])}</td>)
  html << %(<td class="num">#{fmt_int(c['rps_per_gb'])}</td>)
  html << "</tr>\n"
end
html << "</tbody></table>\n</details>\n"

# ── Section: environment appendix ────────────────────────────────────

if env
  html << %(<details id="environment">\n<summary>Environment#{env['captured_at'] ? " (captured #{env['captured_at']})" : ''}</summary>\n)

  clock = env['clock'] || {}
  html << "<h3>Host</h3>\n"
  html << kv_table([
    ['hostname', env.dig('host', 'hostname')],
    ['OS',       env.dig('os', 'pretty_name')],
    ['kernel',   env.dig('host', 'uname')],
    ['board',    [env.dig('cpu', 'board_vendor'), env.dig('cpu', 'board_name')].compact.reject(&:empty?).join(' ')],
    ['CPU',      lscpu_field(env, 'Model name')],
    ['topology', lscpu_field(env, 'CPU(s)') && "#{lscpu_field(env, 'Core(s) per socket')} cores / #{lscpu_field(env, 'CPU(s)')} threads"],
    ['clock',    clock['governor'] && "governor=#{clock['governor']}, boost #{clock['boost'] == '0' ? 'disabled' : 'enabled'}, #{(clock['max_khz'].to_i / 1000)} MHz max"],
    ['memory',   env['memory_mb'] && "#{fmt_int(env['memory_mb'])} MB"],
  ])

  toolchains = env['toolchains'] || {}
  unless toolchains.empty?
    html << "<h3>Toolchains</h3>\n"
    html << kv_table(toolchains.sort.map { |name, ver| [name, "<code>#{ver}</code>"] })
  end

  h = env['harness'] || {}
  requested  = Array(h['targets'])
  unmeasured = requested - targets
  html << "<h3>Harness</h3>\n"
  html << kv_table([
    ['command',     h['command'] && "<code>#{h['command']}</code>"],
    ['workers',     Array(h['workers']).join(', ')],
    ['concurrency', h['concurrency']],
    ['runs',        h['runs'] && "#{h['runs']} × #{h['duration_sec']}s after #{h['warmup_sec']}s warmup"],
    ['wrk threads', h['wrk_threads']],
    ['endpoints',   Array(h['endpoints']).map { |e| "<code>#{e}</code>" }.join(' ')],
    ['targets',     requested.join(', ')],
    ['not measured', unmeasured.empty? ? nil : "#{unmeasured.join(', ')} (requested but produced no cells)"],
  ])

  g = env['git'] || {}
  unless g.empty?
    html << "<h3>Source</h3>\n"
    html << kv_table([
      ['commit',  g['sha'] && "<code>#{g['sha']}</code>#{g['dirty'] ? ' (dirty)' : ''}"],
      ['branch',  g['branch']],
      ['subject', g['subject']],
    ])
  end

  c = env['conditions'] || {}
  unless c.empty?
    html << "<h3>Conditions at start</h3>\n"
    html << kv_table([
      ['load average', Array(c['loadavg_1_5_15']).join(' / ')],
      ['uptime',       c['uptime']],
    ])
  end

  html << "</details>\n"
end

html << %(<hr><p class="meta">Generated #{Time.now.utc.iso8601} from <code>#{File.basename(input)}</code>.</p>\n)
html << "</body>\n</html>\n"

File.write(out, html)
$stderr.puts "wrote #{out} (#{html.bytesize} bytes)"
