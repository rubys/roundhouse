#!/usr/bin/env ruby
# scripts/bench-report — render a bench summary.json to self-contained HTML.
#
# Usage:
#   scripts/bench-report PATH/TO/summary.json [OUT.html]
#
# Defaults OUT to index.html alongside the input. Pure stdlib; inline
# SVG charts; no JS, no CDN. Open the resulting file directly in a
# browser, archive it, or serve it statically — the chart artifacts
# outlive any chart library's CDN.

require 'json'
require 'time'

input = ARGV[0] or abort "usage: scripts/bench-report PATH/TO/summary.json [OUT.html]"
out   = ARGV[1] || File.join(File.dirname(File.expand_path(input)), 'index.html')

cells = JSON.parse(File.read(input))

# ── ordering / metadata ──────────────────────────────────────────────

TARGET_ORDER = %w[rust crystal go kotlin spinel elixir typescript python ruby ruby-int jruby rails rails-int rails-jruby]
ENDPOINT_ORDER = %w[/articles /articles/1 /articles/new /articles.json /articles/1.json]

# Brand-ish but muted; enough contrast in greyscale.
COLOR = {
  'rust'       => '#b7410e',
  'crystal'    => '#1c1c1c',
  'go'         => '#00add8',
  'kotlin'     => '#c711a8',
  'spinel'     => '#7d4cdb',
  'elixir'     => '#4b275f',
  'typescript' => '#3178c6',
  'python'     => '#3776ab',
  'ruby'       => '#cc342d',
  'ruby-int'   => '#e89c93',
  'jruby'      => '#5382a1',
  'rails'      => '#666666',
  'rails-int'  => '#aaaaaa',
  'rails-jruby' => '#46707f',
}

GROUP_LABEL = {
  'AOT'      => 'compiled (AOT)',
  'JIT'      => 'JIT / interpreter',
  'interp'   => 'interpreter, no JIT',
  'baseline' => 'Rails baseline',
}

# ── index data ───────────────────────────────────────────────────────

by = Hash.new { |h, k| h[k] = {} }
cells.each { |c| by[c['endpoint']][c['target']] = c }

endpoints = ENDPOINT_ORDER & by.keys
targets   = TARGET_ORDER & cells.map { |c| c['target'] }.uniq

run_dir   = File.basename(File.dirname(File.expand_path(input)))
total     = cells.size
runs      = cells.first['runs']

# ── number formatting ────────────────────────────────────────────────

def fmt_int(n)  ; n.to_i.to_s.reverse.scan(/\d{1,3}/).join(',').reverse ; end
def fmt_dec(n, p = 1) ; format("%.#{p}f", n.to_f) ; end

# ── SVG primitives ───────────────────────────────────────────────────

def svg_open(w, h)
  %(<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 #{w} #{h}" ) +
  %(width="#{w}" height="#{h}" font-family="-apple-system,system-ui,sans-serif" font-size="12">)
end

def svg_close ; '</svg>' ; end

def t(x, y, s, anchor: 'start', size: 12, weight: nil, fill: '#222')
  a = %(text-anchor="#{anchor}" font-size="#{size}" fill="#{fill}")
  a << %( font-weight="#{weight}") if weight
  %(<text x="#{x}" y="#{y}" #{a}>#{s}</text>)
end

def r(x, y, w, h, fill:, stroke: nil)
  s = stroke ? %( stroke="#{stroke}") : ''
  %(<rect x="#{x}" y="#{y}" width="#{w}" height="#{h}" fill="#{fill}"#{s}/>)
end

def l(x1, y1, x2, y2, stroke: '#ddd', sw: 1, dash: nil)
  d = dash ? %( stroke-dasharray="#{dash}") : ''
  %(<line x1="#{x1}" y1="#{y1}" x2="#{x2}" y2="#{y2}" stroke="#{stroke}" stroke-width="#{sw}"#{d}/>)
end

# ── log-scale horizontal bar chart (one per endpoint) ────────────────

def hbar_log(rows, metric:, unit:, min_decade: 2, max_decade: nil)
  values = rows.map { |c| c[metric].to_f }
  max_decade ||= [Math.log10(values.max).ceil, min_decade + 1].max

  width      = 760
  left_pad   = 110
  right_pad  = 100
  plot_w     = width - left_pad - right_pad
  row_h      = 22
  gap        = 6
  top        = 10
  bottom     = 28
  height     = top + (row_h + gap) * rows.size + bottom

  buf = +svg_open(width, height)

  # X-axis decade gridlines + labels
  decades = (min_decade..max_decade).to_a
  decades.each do |d|
    x = left_pad + (d - min_decade).to_f / (max_decade - min_decade) * plot_w
    buf << l(x, top, x, height - bottom, stroke: '#e5e5e5')
    label = 10 ** d
    buf << t(x, height - bottom + 14, fmt_int(label), anchor: 'middle', fill: '#666', size: 10)
  end
  buf << t(width - 4, height - bottom + 14, unit, anchor: 'end', fill: '#999', size: 10)

  # Sort rows by metric desc for visual ranking
  ranked = rows.sort_by { |c| -c[metric].to_f }

  ranked.each_with_index do |c, i|
    y = top + i * (row_h + gap)
    v = c[metric].to_f
    lv = Math.log10([v, 1].max)
    bar = ((lv - min_decade) / (max_decade - min_decade) * plot_w).round
    bar = [bar, 1].max

    target = c['target']
    buf << t(left_pad - 8, y + row_h * 0.7, target, anchor: 'end', weight: 'bold')
    buf << r(left_pad, y, bar, row_h, fill: COLOR[target])
    label = metric == 'req_sec' ? fmt_int(v) : fmt_int(v)
    buf << t(left_pad + bar + 6, y + row_h * 0.7, label, fill: '#222')
  end

  buf << svg_close
  buf
end

# ── grouped vertical bars (lowerer dividend, YJIT, multiplier) ───────

def grouped_bars(groups, series:, max: nil, value_fmt: ->(v) { fmt_int(v) }, suffix: '')
  # groups: [{label:, values: {series_key => value}}]
  width      = 760
  left_pad   = 50
  right_pad  = 20
  plot_w     = width - left_pad - right_pad
  bot_pad    = 60
  top_pad    = 30
  plot_h     = 240
  height     = top_pad + plot_h + bot_pad

  all_vals = groups.flat_map { |g| g[:values].values }.compact
  max_v = max || ((all_vals.max || 0) * 1.15)
  max_v = 1.0 if !max_v.is_a?(Numeric) || !max_v.finite? || max_v <= 0
  band  = plot_w.to_f / groups.size
  bar_count = series.size
  bar_w = [(band - 24) / bar_count, 80].min
  inner_gap = 4

  buf = +svg_open(width, height)

  # Y-axis gridlines (nice round ticks at 5 levels)
  step = nice_step(max_v / 5.0)
  ticks = (0..(max_v / step).ceil).map { |i| i * step }
  ticks.each do |v|
    y = top_pad + plot_h - (v / max_v) * plot_h
    buf << l(left_pad, y, width - right_pad, y, stroke: '#eee')
    buf << t(left_pad - 6, y + 4, fmt_int(v), anchor: 'end', fill: '#888', size: 10)
  end

  groups.each_with_index do |g, gi|
    cx = left_pad + band * gi + band / 2
    series.each_with_index do |key, si|
      v = g[:values][key].to_f
      bx = cx - (bar_w * bar_count + inner_gap * (bar_count - 1)) / 2.0 + si * (bar_w + inner_gap)
      bh = (v / max_v) * plot_h
      by = top_pad + plot_h - bh
      buf << r(bx, by, bar_w, bh, fill: COLOR[key])
      buf << t(bx + bar_w / 2.0, by - 4, value_fmt.call(v) + suffix,
               anchor: 'middle', fill: '#444', size: 10)
    end
    # Endpoint label
    buf << t(cx, top_pad + plot_h + 16, g[:label],
             anchor: 'middle', fill: '#333', size: 11)
    # Multi-line second-row annotation
    if g[:annotation]
      buf << t(cx, top_pad + plot_h + 32, g[:annotation],
               anchor: 'middle', fill: '#666', size: 11, weight: 'bold')
    end
  end

  # Legend
  legend_y = 16
  legend_x = left_pad
  series.each do |key|
    buf << r(legend_x, legend_y - 10, 14, 12, fill: COLOR[key])
    buf << t(legend_x + 18, legend_y, key, fill: '#333')
    legend_x += 110
  end

  buf << svg_close
  buf
end

def nice_step(raw)
  # Guard against degenerate input: an all-zero / empty series (e.g. a
  # partial run that didn't measure a target this chart references)
  # yields raw <= 0, and Math.log10(0) is -Infinity, which #floor
  # rejects with FloatDomainError. Fall back to a step of 1.
  return 1.0 unless raw.is_a?(Numeric) && raw.finite? && raw > 0
  exp = Math.log10(raw).floor
  base = 10 ** exp
  frac = raw / base
  step_frac = if frac < 1.5 then 1
              elsif frac < 3 then 2
              elsif frac < 7 then 5
              else 10
              end
  step_frac * base
end

# ── HTML scaffold ────────────────────────────────────────────────────

styles = <<~CSS
  body { font-family: -apple-system, system-ui, sans-serif; color: #222;
         max-width: 880px; margin: 2em auto; padding: 0 1em; line-height: 1.5; }
  h1 { font-size: 1.6em; margin-bottom: 0.2em; }
  h2 { font-size: 1.2em; margin-top: 2em; border-bottom: 1px solid #ddd;
       padding-bottom: 0.2em; }
  h3 { font-size: 1.0em; color: #555; margin: 1.4em 0 0.4em; }
  .meta { color: #666; font-size: 0.9em; margin-bottom: 1em; }
  .methodology { background: #f7f7f7; border-left: 3px solid #ccc;
                 padding: 0.6em 1em; font-size: 0.92em; }
  .methodology code { background: #ececec; padding: 0.05em 0.3em;
                      border-radius: 3px; font-size: 0.9em; }
  .caveat { color: #777; font-size: 0.9em; font-style: italic; }
  table { border-collapse: collapse; font-size: 0.88em; margin: 0.4em 0; }
  th, td { padding: 4px 10px; border-bottom: 1px solid #eee; }
  th { text-align: left; }
  td.num { text-align: right; font-variant-numeric: tabular-nums; }
  details summary { cursor: pointer; color: #555; padding: 0.4em 0; }
  .legend { font-size: 0.85em; color: #666; }
  svg { display: block; margin: 0.4em auto; }
CSS

html = +"<!doctype html>\n<html lang=en>\n<head>\n<meta charset=utf-8>\n"
html << "<title>Roundhouse bench — #{run_dir}</title>\n<style>#{styles}</style>\n</head>\n<body>\n"

html << "<h1>Roundhouse benchmark results</h1>\n"
html << %(<div class="meta">Run <code>#{run_dir}</code> · #{total} cells × #{runs} runs · #{endpoints.size} endpoints × #{targets.size} targets</div>\n)

html << <<~METHOD
  <div class="methodology">
    <strong>Methodology.</strong> Hetzner AX41-NVMe (Ryzen 5 3600, 6c/12t, 3.6 GHz base, <strong>boost disabled</strong>, governor=performance), 64 GB ECC DDR4, NVMe SSD, Ubuntu 24.04. Toolchains via <a href="https://mise.jdx.dev">mise</a> — Ruby 4.0.2+YJIT, Rust 1.94, Go 1.24, Node 25, Crystal 1.20, Elixir 1.18/OTP 28, Python 3.14, Kotlin/JVM (Gradle 9.5, OpenJDK 21), JRuby 10/OpenJDK 21. Harness: <code>scripts/bench</code> defaults — workers=1, c=64, 3×20s runs per cell. Quiet machine throughout (Kamal services moved off bench port). The JVM cells (<code>jruby</code>, <code>kotlin</code>) run under a fixed JVM heap (<code>-Xmx512m=-Xms512m</code>): their RSS is a deliberate budget, not the JVM's default share of host RAM, so they stay comparable to the other cells' working sets.
    <p class="caveat">These numbers measure one specific Rails reference app — not arbitrary Rails workloads. See <a href="https://github.com/rubys/roundhouse/issues/16">#16</a> for the fixture-fragility caveats.</p>
    #{(targets.include?('rails-jruby') ? %(<p class="caveat"><code>rails-jruby</code> is the stock-Rails-on-the-JVM baseline — the same blog, pinned to <strong>Rails 8.0</strong> (one minor behind the others' 8.1) on a <strong>prerelease</strong> AR-JDBC adapter (<code>activerecord-jdbcsqlite3-adapter 80.0.pre1</code>), the only combination that drives ActiveRecord on JRuby 10 today. It collapses to the shared 8.1 fixture once AR-JDBC ships Rails 8.1 support.</p>) : '')}
  </div>
METHOD

# NOTE: the former "Spinel concurrency note" was removed 2026-05-29. It
# described a prefork-blocking Tep::Server that no longer matches the
# artifact (Tep::Server::Scheduled — fiber-per-connection — is now the
# default, and a fiber-aware connection pool is wired). Rather than
# publish a speculative replacement before there's data, write the
# caveat against a real spinel run. When the spinel row lands, add a
# note covering: concurrent numbers gated on spinel#1052 (GC UAF crashes
# the fiber server under load) until fixed; and that on the RAM-cached
# DB the pool's concurrency benefit is largely latent (CPU-bound) until
# an I/O-bound working-set variant exists. See issue #3.

# ── Section: throughput per endpoint ─────────────────────────────────

html << "<h2>1. Throughput across targets</h2>\n"
html << %(<p>Each endpoint is its own chart. Bars are log-scaled; raw req/sec is shown at the right.</p>\n)
endpoints.each do |ep|
  rows = targets.map { |t| by[ep][t] }.compact
  html << "<h3>#{ep}</h3>\n"
  html << hbar_log(rows, metric: 'req_sec', unit: 'req/sec', min_decade: 2, max_decade: 6)
end

# ── Section: lowerer dividend ────────────────────────────────────────

# Cross-language comparison: only meaningful when both ruby and rails
# were measured this run. Skip the whole section otherwise so a partial
# run (e.g. spinel-only) still produces a report.
if (%w[ruby rails] - targets).empty?
  html << "<h2>2. Lowerer dividend (ruby vs rails)</h2>\n"
  html << <<~P
    <p>Same Ruby interpreter, same YJIT, same Puma — the only variable is whether the framework runtime is Rails or Roundhouse-emitted. The multiplier above each pair is the lift from the lowerer pipeline.</p>
  P

  groups = endpoints.map do |ep|
    ruby_v  = by[ep]['ruby']&.dig('req_sec').to_f
    rails_v = by[ep]['rails']&.dig('req_sec').to_f
    {
      label:      ep,
      annotation: rails_v > 0 ? "#{fmt_dec(ruby_v / rails_v, 1)}×" : '',
      values:     { 'ruby' => ruby_v, 'rails' => rails_v },
    }
  end
  html << grouped_bars(groups, series: %w[ruby rails])

  # The same swap on the JVM, when both JRuby cells ran — the dividend is
  # larger there because the JIT rewards the emitted code's monomorphic
  # call shapes far more than Rails' reflection-heavy ones.
  if (%w[jruby rails-jruby] - targets).empty?
    jr   = by['/articles']['jruby']&.dig('req_sec').to_f
    rjr  = by['/articles']['rails-jruby']&.dig('req_sec').to_f
    rb   = by['/articles']['ruby']&.dig('req_sec').to_f
    rl   = by['/articles']['rails']&.dig('req_sec').to_f
    if rjr > 0 && rl > 0
      html << %(<p>The same comparison <em>on the JVM</em> is far more lopsided: emitted <code>jruby</code> beats stock <code>rails-jruby</code> by <strong>#{fmt_dec(jr / rjr, 0)}×</strong> on <code>/articles</code>, against <strong>#{fmt_dec(rb / rl, 0)}×</strong> for <code>ruby</code> over <code>rails</code> on CRuby. Roundhouse doesn't make the JVM faster — it emits code in the monomorphic shape the JIT can optimize, which Rails' autoload/reflection/metaprogramming never takes, so the lowerer pays off roughly twice as much for the same VM.</p>\n)
    end
  end
end

# ── Section: YJIT contribution ───────────────────────────────────────

# Restrict to the JIT/interp variants that were actually measured; skip
# the section if none of them ran.
yjit_series = %w[ruby ruby-int rails rails-int] & targets
unless yjit_series.empty?
  html << "<h2>3. YJIT contribution</h2>\n"
  html << <<~P
    <p>YJIT consistently helps Roundhouse-emitted Ruby (small, predictable call shapes). On Rails it's neutral-to-slightly-negative — the deep autoload + reflection chain blunts it.</p>
  P

  yjit_groups = endpoints.map do |ep|
    {
      label:  ep,
      values: yjit_series.each_with_object({}) { |t, h| h[t] = by[ep][t]&.dig('req_sec').to_f },
    }
  end
  html << grouped_bars(yjit_groups, series: yjit_series)
end

# ── Section: cost economics ──────────────────────────────────────────

html << "<h2>4. Cost economics (req/sec per GB of RSS)</h2>\n"
html << <<~P
  <p>Throughput normalized by memory footprint. Reorders the table — rust and crystal pull further ahead; high-RSS targets (typescript, rails) move down, and the JVM cells move down hardest. <code>kotlin</code> is the sharpest illustration: it tops raw throughput (section 1) but its ~760 MB drags it to mid-field on req/sec/GB — roughly between <code>go</code> and <code>python</code>, and below both on the JSON endpoints — so the JVM's speed win is largely cancelled by its memory cost. <code>jruby</code>'s top-tier raw throughput is dragged down the same way, landing roughly level with CRuby <code>ruby</code>. <code>rails-jruby</code> lands at or near the bottom of every endpoint: ~1.5 GB sinks even respectable throughput, leaving it less cost-efficient than CRuby <code>rails</code> despite winning on raw req/sec. Applicability varies by deployment shape: matters most for metered/serverless surfaces, least for bare-metal-with-headroom.</p>
P
endpoints.each do |ep|
  rows = targets.map { |t| by[ep][t] }.compact
  html << "<h3>#{ep}</h3>\n"
  html << hbar_log(rows, metric: 'rps_per_gb', unit: 'req/sec/GB', min_decade: 3, max_decade: 7)
end

# ── Section: HTML→JSON multiplier ────────────────────────────────────

html << "<h2>5. HTML → JSON multiplier</h2>\n"
html << <<~P
  <p>Per-target lift going from <code>/articles</code> (HTML) to <code>/articles.json</code> (JSON). The asymmetry isn't JSON-escape vs HTML-escape — both paths concatenate and escape strings. What JSON skips is the <em>layout chain</em> (csrf_meta_tag, importmap, asset-manifest scan, content_for slots) and the <em>per-row view helpers</em> (link_to, button_to, dom_id, tag.*) that the HTML index template invokes for every record.</p>
  <p>Interpreter-bound targets get the least lift because per-call dispatch overhead dominates whether the work is helpers or serialization — ruby is the flattest of the whole field at just 1.1×, and rails only 1.8×. Compiled and BEAM targets show the helper-chain cost more clearly because their serialization is fast: elixir (2.8×) and go (2.2×) lead the multiplier, with python at 2.0× and rust/crystal/typescript/kotlin in the 1.1–1.6× band. Go's gap is the largest of the AOT-compiled set even after the IR string-builder annotation pass closed part of it; kotlin is the flattest of the compiled/JVM set (1.1×) — its serialization is fast enough that the helper chain barely registers.</p>
P

if (%w[jruby rails-jruby] - targets).empty?
  html << <<~P
    <p><strong>On the JVM the multiplier exposes which render path JITs.</strong> Emitted <code>jruby</code> behaves normally (~1.3×). But <code>rails-jruby</code> is the one target in the whole field where JSON is <em>slower</em> than HTML (~0.8×). Stock Rails' jbuilder is a <code>method_missing</code> DSL — every <code>json.extract!</code>/<code>json.url</code> is dynamic dispatch, plus a per-row <code>article_url(…, format: :json)</code> route synthesis — which the JIT can't inline-cache, so the JSON path gets almost no JVM lift while ERB's compiled, monomorphic template methods get 2×+. (Cross-VM: HTML rendering lifts ~2.2× from CRuby to JRuby; jbuilder JSON lifts ~1.0×.) Emitted JSON shows no such dip because the lowerer compiles the jbuilder view into a plain method of direct <code>io &lt;&lt; …</code> string appends and a non-reflective path helper — exactly the shape the JIT optimizes. The "slow JSON" isn't a serialization cost; it's stock Rails leaving JIT headroom on the table that the transpile collects.</p>
  P
end

mult_targets = targets - %w[ruby-int rails-int]  # collapse JIT/non-JIT variants
mult_groups = [{
  label:  'HTML→JSON',
  values: mult_targets.each_with_object({}) do |t, h|
    html_v = by['/articles'][t]&.dig('req_sec').to_f
    json_v = by['/articles.json'][t]&.dig('req_sec').to_f
    h[t] = html_v > 0 ? (json_v / html_v) : 0
  end
}]
# Single-group chart looks silly; redraw as per-target bars
html << <<~SVG
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 760 #{40 + 30 * mult_targets.size}" width="760">
    #{mult_targets.each_with_index.map { |tgt, i|
      v = mult_groups[0][:values][tgt]
      bar_w = ((v / 6.0) * 540).round
      y = 20 + i * 28
      [
        %(<text x="100" y="#{y + 14}" text-anchor="end" font-weight="bold" font-family="-apple-system,system-ui,sans-serif" font-size="12">#{tgt}</text>),
        %(<rect x="110" y="#{y}" width="#{bar_w}" height="20" fill="#{COLOR[tgt]}"/>),
        %(<text x="#{110 + bar_w + 6}" y="#{y + 14}" font-family="-apple-system,system-ui,sans-serif" font-size="12">#{fmt_dec(v, 1)}×</text>)
      ].join
    }.join}
    #{[1, 2, 3, 4, 5, 6].map { |d|
      x = 110 + (d / 6.0) * 540
      %(<line x1="#{x}" y1="10" x2="#{x}" y2="#{20 + 28 * mult_targets.size}" stroke="#e5e5e5"/>) +
      %(<text x="#{x}" y="#{30 + 28 * mult_targets.size}" text-anchor="middle" font-size="10" fill="#888" font-family="-apple-system,system-ui,sans-serif">#{d}×</text>)
    }.join}
  </svg>
SVG

# ── Section: memory footprint ────────────────────────────────────────

html << "<h2>6. Memory footprint (RSS)</h2>\n"
html << "<p>Max RSS observed across all endpoints, per target. The native + CRuby + Node field spreads across four tiers: rust and crystal sit under 30 MB; go lands near 36 MB; python around 80 MB; elixir, ruby, and ruby-int cluster at 135–160 MB; and typescript, rails-int, and rails top that group out at 370–420 MB. The three JVM cells sit a full order of magnitude higher, in a tier of their own: emitted <code>kotlin</code> at ~760 MB and emitted <code>jruby</code> at ~940 MB (each a pinned 512 MB heap plus JVM metaspace and code-cache) and <code>rails-jruby</code> at ~1.5 GB — stock Rails' enormous class footprint on top of the same heap budget. That's the JVM's trade: warm-JIT throughput (section 1) bought with memory, which the cost-economics chart (section 4) compounds into req/sec/GB.</p>\n"

mem_rows = targets.map do |tgt|
  max_rss = endpoints.map { |ep| by[ep][tgt]&.dig('rss_mb').to_f }.max
  { 'target' => tgt, 'rss_mb' => max_rss }
end
mem_rows.sort_by! { |r| r['rss_mb'] }

mem_max = mem_rows.map { |r| r['rss_mb'] }.max
mem_svg_h = 30 + 28 * mem_rows.size
html << svg_open(760, mem_svg_h)
mem_rows.each_with_index do |row, i|
  y = 10 + i * 28
  v = row['rss_mb']
  bar = (v / mem_max * 540).round
  html << t(100, y + 14, row['target'], anchor: 'end', weight: 'bold')
  html << r(110, y, bar, 20, fill: COLOR[row['target']])
  html << t(110 + bar + 6, y + 14, "#{fmt_int(v)} MB", fill: '#444')
end
html << svg_close
if targets.include?('jruby')
  html << %(<p class="caveat">The three JVM bars run under a fixed <code>-Xmx512m</code> heap, so the heap can't grab a host-dependent share of RAM; the rest is metaspace/code-cache, which is bounded by the app's class count, not the box. <code>kotlin</code> (~760&nbsp;MB) is emitted Kotlin and <code>jruby</code> (~940&nbsp;MB) is the same emitted Ruby as the <code>ruby</code> cell; <code>rails-jruby</code> (~1.5&nbsp;GB, the tallest bar) is stock Rails' far larger class footprint. Read all three as "the cost of the JVM's warm-JIT throughput," not organically-grown working sets like the other cells.</p>\n)
end

# ── Section: latency ─────────────────────────────────────────────────

html << "<h2>7. Latency (p50 / p99 at c=64)</h2>\n"
html << "<p>Latencies are c=64 concurrent connections; treat p50 as median per-connection wait, p99 as tail. Warm <code>kotlin</code> leads the field — p50 ~0.4–1.0 ms, at or below <code>rust</code> on most endpoints — with rust just behind (0.4–1.7 ms). Warm <code>jruby</code> joins the front too, p50 ~1.3–2.3 ms in the crystal/elixir band. Then go 2–8 ms, typescript and python 3–13 ms, ruby 8–16 ms. The Rails baselines trail: <code>rails-jruby</code> at 36–74 ms (the JVM does shave the CRuby <code>rails</code> 48–129 ms), with <code>rails</code> the slowest. The order roughly matches the throughput chart inversely. Tail behaviour: go's p99 on <code>/articles/new</code> (~43 ms against a ~3 ms p50, a ~13× spread the others don't show) points at allocation/GC churn in the render path; <code>rails-jruby</code>'s p99 runs ~1.3–2× its p50 across endpoints — the JVM's GC tail under a pinned heap.</p>\n"

html << "<table>\n<thead><tr><th>target</th>"
endpoints.each { |ep| html << "<th colspan=2>#{ep}</th>" }
html << "</tr>\n<tr><th></th>"
endpoints.each { html << "<th>p50</th><th>p99</th>" }
html << "</tr></thead>\n<tbody>\n"
# Order rows by latency (median p50 across endpoints, ascending) so the
# table reads as a ranking like the sorted bar charts — and so warm
# jruby lands at the front where the prose puts it, rather than buried
# mid-table by canonical TARGET_ORDER. Median is robust to single-endpoint
# outliers (e.g. go's /articles render-path spike).
lat_order = targets.sort_by do |tgt|
  ps = endpoints.map { |ep| by[ep][tgt]&.dig('p50_ms') }.compact.sort
  ps.empty? ? Float::INFINITY : ps[ps.size / 2]
end
lat_order.each do |tgt|
  html << "<tr><td><strong>#{tgt}</strong></td>"
  endpoints.each do |ep|
    c = by[ep][tgt]
    if c
      html << %(<td class="num">#{fmt_dec(c['p50_ms'], 1)}</td><td class="num">#{fmt_dec(c['p99_ms'], 1)}</td>)
    else
      html << "<td>-</td><td>-</td>"
    end
  end
  html << "</tr>\n"
end
html << "</tbody></table>\n"
html << %(<p class="legend">All values in milliseconds. Lower is better.</p>\n)

# ── Section: raw data table ──────────────────────────────────────────

html << "<details>\n<summary>Raw cell data (#{cells.size} rows)</summary>\n"
html << "<table>\n<thead><tr><th>target</th><th>endpoint</th><th>req/sec</th><th>p50 (ms)</th><th>p99 (ms)</th><th>RSS (MB)</th><th>req/sec/GB</th></tr></thead>\n<tbody>\n"
cells.sort_by { |c| [TARGET_ORDER.index(c['target']) || 99, ENDPOINT_ORDER.index(c['endpoint']) || 99] }.each do |c|
  html << "<tr>"
  html << "<td>#{c['target']}</td>"
  html << "<td>#{c['endpoint']}</td>"
  html << %(<td class="num">#{fmt_int(c['req_sec'])}</td>)
  html << %(<td class="num">#{fmt_dec(c['p50_ms'], 2)}</td>)
  html << %(<td class="num">#{fmt_dec(c['p99_ms'], 2)}</td>)
  html << %(<td class="num">#{fmt_int(c['rss_mb'])}</td>)
  html << %(<td class="num">#{fmt_int(c['rps_per_gb'])}</td>)
  html << "</tr>\n"
end
html << "</tbody></table>\n</details>\n"

html << %(<hr><p class="meta">Generated #{Time.now.utc.iso8601} from <code>#{File.basename(input)}</code>.</p>\n)
html << "</body>\n</html>\n"

File.write(out, html)
$stderr.puts "wrote #{out} (#{html.bytesize} bytes)"
