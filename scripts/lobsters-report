#!/usr/bin/env ruby
# scripts/lobsters-report — render a lobsters bench run to self-contained HTML.
#
# The lobsters counterpart to scripts/bench-report: where that renders the
# blog throughput matrix, this renders one scripts/bench-lobsters run —
# route parity, the frozen 114-visit sequence timing, and the
# roundhouse-vs-Rails comparison — into a single static page.
#
# CONSOLIDATION: the primary input is the LANE layout that
# `bench-lobsters LANES…` writes — matrix.json at the run root plus one
# subdir per lane (rails/rails-int/ruby/ruby-int/jruby) — rendered as
# three sections: (1) headline + runtime × JIT matrix (stability folded
# in), (2) per-endpoint breakdown (chart = each stack's best config, all
# lanes in the table), (3) coverage & parity — the attestation that the
# timing sections measured a complete app surface per emit target. The
# pre-orchestrator LEGACY layout (summary.json at the root, optional
# matrix/ + jruby/ symlinks) still renders so archived runs and
# single-lane dev runs re-render unchanged.
#
# Usage:
#   scripts/lobsters-report [PATH] [OUT.html]
#
#   PATH defaults to bench/results/lobsters/latest. It may be either the
#   run directory or the summary.json inside it. OUT defaults to
#   index.html alongside summary.json, so the page publishes next to the
#   raw artifacts already served at roundbench.showcase.party/lobsters/.
#
# Pure stdlib; inline SVG charts; no JS, no CDN. Open the file directly,
# archive it, or serve it statically — the chart artifacts outlive any
# chart library's CDN. Degrades gracefully: a parity-only run (no
# rails.json / sequence_timing, as before P6 landed) still renders, just
# without the timing and comparison sections.

require 'json'
require 'time'

arg = ARGV[0] || File.join(__dir__, '..', 'bench', 'results', 'lobsters', 'latest')
arg = File.expand_path(arg)
run_path = File.directory?(arg) ? arg : File.dirname(arg)
out = ARGV[1] || File.join(run_path, 'index.html')

# Optional sidecar files. The comparison/matrix/jruby sections only
# render when their data is present.
def sibling(dir, name)
  path = File.join(dir, name)
  File.exist?(path) ? JSON.parse(File.read(path)) : nil
rescue JSON::ParserError
  nil
end

# Two layouts render through this one page:
#  - LANE layout (bench-lobsters LANES…): matrix.json at the run root and
#    one subdir per lane; the `ruby` lane is the canonical emit.
#  - LEGACY layout: summary.json at the run root plus optional matrix/
#    and jruby/ links (the pre-orchestrator nightly) — kept so archived
#    runs re-render unchanged.
lanes_mode = File.exist?(File.join(run_path, 'matrix.json'))
if lanes_mode
  matrix = sibling(run_path, 'matrix.json') or abort "unparseable matrix.json in #{run_path}"
  prim   = %w[ruby ruby-int].find { |id| File.exist?(File.join(run_path, id, 'summary.json')) }
  prim or abort "lane layout but no ruby lane summary under #{run_path}"
  input   = File.join(run_path, prim, 'summary.json')
  summary = JSON.parse(File.read(input))
  # Rails baseline at the SAME JIT level as the primary emit lane.
  rails = sibling(File.join(run_path, prim == 'ruby' ? 'rails' : 'rails-int'), 'rails.json')
  # Lane env carries the interpreter (the headline's JIT label); the
  # run-root env carries the orchestration command — merge, root wins.
  env = (sibling(File.join(run_path, prim), 'env.json') || {}).merge(sibling(run_path, 'env.json') || {})
  env = nil if env.empty?
  jruby     = sibling(File.join(run_path, 'jruby'), 'summary.json')
  jruby_env = jruby && sibling(File.join(run_path, 'jruby'), 'env.json')
else
  prim  = nil
  input = File.directory?(arg) ? File.join(arg, 'summary.json') : arg
  File.exist?(input) or abort "no summary.json at #{input}"
  summary = JSON.parse(File.read(input))
  rails = sibling(run_path, 'rails.json')
  env   = sibling(run_path, 'env.json')
  # Sibling lanes linked into the run dir by the pre-orchestrator nightly.
  # Read strictly through the in-dir links — never the shared `latest`
  # pointers — so re-rendering an archived run can't pull another night's
  # data into its page.
  matrix    = sibling(File.join(run_path, 'matrix'), 'matrix.json')
  jruby     = sibling(File.join(run_path, 'jruby'),  'summary.json')
  jruby_env = jruby && sibling(File.join(run_path, 'jruby'), 'env.json')
end

jruby_pass = jruby && (jruby['pass'] || (jruby['routes'] || []).count { |r| r['ok'] })
jruby_total = jruby && (jruby['total'] || (jruby['routes'] || []).size)
# In the lane layout the jruby lane runs the SAME in-memory frozen
# sequence as everyone else — it lives in the matrix, the per-endpoint
# table, and the parity table. The standalone file-backed section (and
# its caveats) only applies to the legacy layout's separate run.
jruby_seq = lanes_mode && jruby && jruby['sequence_timing']
legacy_jruby = !lanes_mode && jruby

routes   = summary['routes'] || []
timing   = summary['sequence_timing']
run_dir  = File.basename(run_path)

# ── formatting ───────────────────────────────────────────────────────

def fmt_int(n)  ; n.to_i.to_s.reverse.scan(/\d{1,3}/).join(',').reverse ; end
def fmt_dec(n, p = 1) ; format("%.#{p}f", n.to_f) ; end

# JIT state from a RUBY_DESCRIPTION. The headline lane inherits the ambient
# RUBYOPT (unlike the matrix, which pins YJIT per lane), so the page must
# say which JIT level each measurement actually ran — nil when unknown.
def jit_label(desc) ; desc && (desc.include?('+YJIT') ? '+YJIT' : 'no JIT') ; end

# Coefficient of variation (%) across a lane's timed iterations — the
# "is the median masking noise?" number, one per lane.
def cv_pct(iter_ms)
  return nil unless iter_ms && iter_ms.size > 1
  mean = iter_ms.sum / iter_ms.size.to_f
  return nil unless mean > 0
  Math.sqrt(iter_ms.map { |v| (v - mean)**2 }.sum / iter_ms.size) / mean * 100
end
def esc(s) ; s.to_s.gsub('&', '&amp;').gsub('<', '&lt;').gsub('>', '&gt;') ; end

def kv_table(rows)
  out = +"<table>\n<tbody>\n"
  rows.each do |k, v|
    next if v.nil? || v.to_s.empty?
    out << "<tr><th>#{k}</th><td>#{v}</td></tr>\n"
  end
  out << "</tbody></table>\n"
end

# ── SVG primitives (shared shape with scripts/bench-report) ───────────

def svg_open(w, h)
  %(<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 #{w} #{h}" ) +
  %(width="#{w}" height="#{h}" font-family="-apple-system,system-ui,sans-serif" font-size="12">)
end
def svg_close ; '</svg>' ; end

def t(x, y, s, anchor: 'start', size: 12, weight: nil, fill: '#222')
  a = %(text-anchor="#{anchor}" font-size="#{size}" fill="#{fill}")
  a << %( font-weight="#{weight}") if weight
  %(<text x="#{x}" y="#{y}" #{a}>#{esc(s)}</text>)
end
def r(x, y, w, h, fill:, stroke: nil)
  s = stroke ? %( stroke="#{stroke}") : ''
  %(<rect x="#{x}" y="#{y}" width="#{w}" height="#{h}" fill="#{fill}"#{s}/>)
end
def l(x1, y1, x2, y2, stroke: '#ddd', sw: 1, dash: nil)
  d = dash ? %( stroke-dasharray="#{dash}") : ''
  %(<line x1="#{x1}" y1="#{y1}" x2="#{x2}" y2="#{y2}" stroke="#{stroke}" stroke-width="#{sw}"#{d}/>)
end

COLOR_RH    = '#7d4cdb'   # roundhouse (matches spinel/violet family in bench-report)
COLOR_RAILS = '#cc342d'   # Rails (ruby red)
COLOR_JR    = '#5382a1'   # JRuby (steel blue, matches bench-report's jruby)
COLOR_OK    = '#2e7d32'
COLOR_FAIL  = '#c0392b'

# ── vs-Rails comparison: horizontal ms/iter bars, lower is better ─────
#
# Bars are linear (not log) — the whole point is the visible size ratio,
# and both stacks sit within one decade. A min–max whisker rides each bar
# so the median isn't mistaken for a point estimate.

def compare_bars(rows, left_pad: 90)
  width    = 760
  right    = 110
  plot_w   = width - left_pad - right
  row_h    = 34
  gap      = 14
  top      = 14
  height   = top + (row_h + gap) * rows.size + 24

  max_v = rows.map { |r| r[:max] || r[:median] }.max.to_f * 1.12
  max_v = 1.0 unless max_v.finite? && max_v > 0

  buf = +svg_open(width, height)
  rows.each_with_index do |row, i|
    y  = top + i * (row_h + gap)
    bw = (row[:median].to_f / max_v * plot_w).round
    buf << t(left_pad - 8, y + row_h * 0.62, row[:label], anchor: 'end', weight: 'bold')
    buf << r(left_pad, y, [bw, 1].max, row_h, fill: row[:color])
    buf << t(left_pad + [bw, 1].max + 8, y + row_h * 0.62,
             "#{fmt_dec(row[:median], 1)} ms", fill: '#222', weight: 'bold')
    if row[:note]
      buf << t(left_pad + [bw, 1].max + 8, y + row_h * 0.62 + 13, row[:note], fill: '#777', size: 10)
    end
    # min–max whisker across the bar's vertical mid-line
    if row[:min] && row[:max]
      ymid = y + row_h / 2.0
      x1 = left_pad + (row[:min].to_f / max_v * plot_w)
      x2 = left_pad + (row[:max].to_f / max_v * plot_w)
      buf << l(x1, ymid, x2, ymid, stroke: '#00000055', sw: 1)
      [x1, x2].each { |x| buf << l(x, ymid - 5, x, ymid + 5, stroke: '#00000055', sw: 1) }
    end
    if row[:iters]
      buf << t(left_pad + 8, y + row_h * 0.62 + 13, "n=#{row[:iters]}", fill: '#ffffffcc', size: 10)
    end
  end
  buf << svg_close
  buf
end

# ── frozen-sequence stability: one column per timed iteration ─────────
#
# Columns are scaled within a tight band around the observed spread (not
# from zero) so run-to-run jitter is legible; the dashed line marks the
# median. This is the "is the number stable?" chart.

def iter_columns(iter_ms, median:, min:, max:, color: COLOR_RH)
  return '' if iter_ms.nil? || iter_ms.empty?
  width    = 760
  left_pad = 44
  right    = 12
  plot_w   = width - left_pad - right
  top      = 14
  plot_h   = 150
  bot      = 24
  height   = top + plot_h + bot

  lo = min * 0.985
  hi = max * 1.015
  span = (hi - lo)
  span = 1.0 unless span.finite? && span > 0
  colw = plot_w.to_f / iter_ms.size
  bw   = [colw - 2, 1].max

  buf = +svg_open(width, height)
  # y ticks: min / median / max
  [[min, '#888'], [median, color], [max, '#888']].each do |v, c|
    yy = top + plot_h - (v - lo) / span * plot_h
    dash = (v == median) ? '4 3' : nil
    buf << l(left_pad, yy, width - right, yy, stroke: (v == median ? color : '#eee'), dash: dash)
    buf << t(left_pad - 6, yy + 4, fmt_dec(v, 0), anchor: 'end', fill: c, size: 10)
  end
  iter_ms.each_with_index do |v, i|
    x  = left_pad + i * colw
    bh = (v - lo) / span * plot_h
    bh = 1 if bh < 1
    yy = top + plot_h - bh
    buf << r(x + (colw - bw) / 2, yy, bw, bh, fill: "#{color}99")
  end
  buf << t(left_pad, top + plot_h + 16, "iteration 1", fill: '#999', size: 10)
  buf << t(width - right, top + plot_h + 16, "iteration #{iter_ms.size}", anchor: 'end', fill: '#999', size: 10)
  buf << svg_close
  buf
end

# ── per-endpoint rails vs roundhouse: paired log-scaled bars ─────────
#
# Two bars per endpoint (rails red, roundhouse violet), rows sorted by
# Rails ms descending so the endpoints that dominate the sequence sit on
# top. Log scale because endpoint latencies span 0.1–30+ ms.

def paired_hbar(rows, jr: false)
  vals = rows.flat_map { |r| [r[:rails], r[:rh], (r[:jr] if jr)] }.compact.select { |v| v > 0 }
  return '' if vals.empty?
  min_dec = [Math.log10(vals.min).floor, 0].min
  max_dec = [Math.log10(vals.max).ceil, min_dec + 1].max

  nbars    = jr ? 3 : 2
  width    = 760
  left_pad = 190
  right    = 70
  plot_w   = width - left_pad - right
  barh     = 8
  inner    = 2
  gap      = 9
  group_h  = barh * nbars + inner * (nbars - 1) + gap
  top      = 22
  bot      = 26
  height   = top + group_h * rows.size + bot

  buf = +svg_open(width, height)
  # legend
  buf << r(left_pad, 6, 12, 10, fill: COLOR_RAILS)
  buf << t(left_pad + 16, 15, 'rails', fill: '#333', size: 11)
  buf << r(left_pad + 70, 6, 12, 10, fill: COLOR_RH)
  buf << t(left_pad + 86, 15, 'roundhouse', fill: '#333', size: 11)
  if jr
    buf << r(left_pad + 170, 6, 12, 10, fill: COLOR_JR)
    buf << t(left_pad + 186, 15, 'jruby', fill: '#333', size: 11)
  end

  (min_dec..max_dec).each do |d|
    x = left_pad + (d - min_dec).to_f / (max_dec - min_dec) * plot_w
    buf << l(x, top, x, height - bot, stroke: '#eee')
    buf << t(x, height - bot + 14, fmt_int(10 ** d), anchor: 'middle', fill: '#888', size: 10)
  end
  buf << t(width - 2, height - bot + 14, 'ms', anchor: 'end', fill: '#aaa', size: 10)

  scale = ->(v) do
    lv = Math.log10([v, 10.0 ** min_dec].max)
    [((lv - min_dec) / (max_dec - min_dec) * plot_w).round, 1].max
  end

  rows.each_with_index do |row, i|
    y = top + i * group_h
    label_y = y + (barh * nbars + inner * (nbars - 1)) / 2.0 + 3
    buf << t(left_pad - 6, label_y, row[:key], anchor: 'end', size: 10, fill: '#333')
    if row[:rails]
      buf << r(left_pad, y, scale.call(row[:rails]), barh, fill: COLOR_RAILS)
    end
    if row[:rh]
      buf << r(left_pad, y + barh + inner, scale.call(row[:rh]), barh, fill: COLOR_RH)
    end
    if jr && row[:jr] && row[:jr] > 0
      buf << r(left_pad, y + (barh + inner) * 2, scale.call(row[:jr]), barh, fill: COLOR_JR)
    end
    if row[:ratio]
      buf << t(width - right + 4, label_y, "#{fmt_dec(row[:ratio], 1)}×",
               fill: (row[:ratio] >= 1 ? COLOR_OK : COLOR_FAIL), size: 10, weight: 'bold')
    end
  end
  buf << svg_close
  buf
end

# ── per-route latency: log-scaled horizontal bars ────────────────────
#
# Route timings span two-plus decades (sub-ms static pages up to /u), so
# a log scale is the only honest fit. Decades are derived from the data
# and allowed below 1 ms.

def route_hbar(routes, metric:, unit:, fmt:)
  vals = routes.map { |c| c[metric].to_f }.reject { |v| v <= 0 }
  return '' if vals.empty?
  min_dec = [Math.log10(vals.min).floor, 3].min
  max_dec = [Math.log10(vals.max).ceil, min_dec + 1].max

  width    = 760
  left_pad = 190
  right    = 90
  plot_w   = width - left_pad - right
  row_h    = 16
  gap      = 3
  top      = 8
  bot      = 26
  height   = top + (row_h + gap) * routes.size + bot

  buf = +svg_open(width, height)
  (min_dec..max_dec).each do |d|
    x = left_pad + (d - min_dec).to_f / (max_dec - min_dec) * plot_w
    buf << l(x, top, x, height - bot, stroke: '#eee')
    buf << t(x, height - bot + 14, fmt_int(10 ** d), anchor: 'middle', fill: '#888', size: 10)
  end
  buf << t(width - 2, height - bot + 14, unit, anchor: 'end', fill: '#aaa', size: 10)

  routes.sort_by { |c| -c[metric].to_f }.each_with_index do |c, i|
    y = top + i * (row_h + gap)
    v = c[metric].to_f
    lv = Math.log10([v, 10.0 ** min_dec].max)
    bar = ((lv - min_dec) / (max_dec - min_dec) * plot_w).round
    bar = [bar, 1].max
    fill = c['ok'] == false ? COLOR_FAIL : COLOR_RH
    buf << t(left_pad - 6, y + row_h * 0.8, c['route'], anchor: 'end', size: 10, fill: '#333')
    buf << r(left_pad, y, bar, row_h, fill: fill)
    buf << t(left_pad + bar + 5, y + row_h * 0.8, fmt.call(v), fill: '#444', size: 10)
  end
  buf << svg_close
  buf
end

# ── page ─────────────────────────────────────────────────────────────

pass  = summary['pass']  || routes.count { |r| r['ok'] }
total = summary['total'] || routes.size
thin  = summary['thin']  || routes.count { |r| r['thin'] }
all_pass = pass == total && total > 0

speedup = nil
if rails && timing && rails['ms_per_iter_median'].to_f > 0 && timing['ms_per_iter_median'].to_f > 0
  speedup = rails['ms_per_iter_median'].to_f / timing['ms_per_iter_median'].to_f
end

# Sections are numbered in render order but the timing/comparison ones
# only appear when their data is present, so hand out numbers as we go.
@section = 0
def section_no ; @section += 1 ; end

styles = <<~CSS
  body { font-family: -apple-system, system-ui, sans-serif; color: #222;
         max-width: 880px; margin: 2em auto; padding: 0 1em; line-height: 1.5; }
  h1 { font-size: 1.6em; margin-bottom: 0.2em; }
  h2 { font-size: 1.2em; margin-top: 2em; border-bottom: 1px solid #ddd;
       padding-bottom: 0.2em; }
  h3 { font-size: 1.0em; color: #555; margin: 1.4em 0 0.4em; }
  .meta { color: #666; font-size: 0.9em; margin-bottom: 1em; }
  .methodology { background: #f7f7f7; border-left: 3px solid #ccc;
                 padding: 0.6em 1em; font-size: 0.92em; }
  .methodology code { background: #ececec; padding: 0.05em 0.3em;
                      border-radius: 3px; font-size: 0.9em; }
  .caveat { color: #777; font-size: 0.9em; font-style: italic; }
  .badges { margin: 0.8em 0 0.4em; }
  .badge { display: inline-block; padding: 0.25em 0.7em; border-radius: 999px;
           font-size: 0.9em; font-weight: 600; margin-right: 0.5em; }
  .badge.pass { background: #e7f4e8; color: #2e7d32; }
  .badge.fail { background: #fdecea; color: #c0392b; }
  .badge.speed { background: #efe9fb; color: #5b32b0; }
  table { border-collapse: collapse; font-size: 0.88em; margin: 0.4em 0; }
  th, td { padding: 4px 10px; border-bottom: 1px solid #eee; }
  th { text-align: left; }
  td.num { text-align: right; font-variant-numeric: tabular-nums; }
  td.ok  { color: #2e7d32; font-weight: 600; }
  td.no  { color: #c0392b; font-weight: 600; }
  details summary { cursor: pointer; color: #555; padding: 0.4em 0; }
  .legend { font-size: 0.85em; color: #666; }
  svg { display: block; margin: 0.4em auto; max-width: 100%; }
CSS

html = +"<!doctype html>\n<html lang=en>\n<head>\n<meta charset=utf-8>\n"
html << %(<meta name="viewport" content="width=device-width, initial-scale=1">\n)
html << "<title>Lobsters bench — #{run_dir}</title>\n<style>#{styles}</style>\n</head>\n<body>\n"

html << "<h1>Lobsters benchmark results</h1>\n"
prov = ''
prov << " · #{summary['generated_at']}" if summary['generated_at']
if env && env['roundhouse_commit']
  prov << %( · <code>#{env['roundhouse_commit'][0, 12]}</code>)
end
html << %(<div class="meta">Run <code>#{run_dir}</code>#{prov}</div>\n)

html << %(<div class="badges">)
html << %(<span class="badge #{all_pass ? 'pass' : 'fail'}">#{pass}/#{total} routes return 200</span>\n)
html << %(<span class="badge fail">#{thin} thin</span>\n) if thin.to_i > 0
if speedup
  html << %(<span class="badge speed">#{fmt_dec(speedup, 2)}× faster than Rails</span>\n)
end
if jruby_total.to_i > 0
  html << %(<span class="badge #{jruby_pass == jruby_total ? 'pass' : 'fail'}">jruby #{jruby_pass}/#{jruby_total} routes</span>\n)
end
html << "</div>\n"

# Sibling artifacts published alongside this page.
artifact_names = if lanes_mode
  %w[matrix.json env.json] +
    (matrix['rows'] || []).map { |r| File.join(r['id'], r['kind'] == 'rails' ? 'rails.json' : 'summary.json') }
else
  %w[summary.json summary.md rails.json sequence.json env.json emit.log
     matrix/matrix.json jruby/summary.json jruby/summary.md]
end
artifacts = artifact_names.select { |f| File.exist?(File.join(run_path, f)) }
unless artifacts.empty?
  html << %(<div class="meta">Artifacts: #{artifacts.map { |f| %(<a href="#{f}"><code>#{f}</code></a>) }.join(' · ')}</div>\n)
end

# ── methodology ──────────────────────────────────────────────────────

vpi   = timing&.dig('visits_per_iter') || rails&.dig('visits_per_iter')
db    = summary['db']
memnote = summary['memory'] ? 'an in-memory SQLite seeded at boot' : 'a file-backed SQLite'
html << <<~METHOD
  <div class="methodology">
    <strong>Methodology.</strong> The route table replays each distinct lobsters route once against the Roundhouse emit and records status, response bytes, and single-shot latency. #{vpi ? "The stability and comparison numbers replay a <strong>frozen #{vpi}-visit sequence</strong> (versioned at <code>bench/lobsters/frozen-sequence.json</code>) so every run — and the Rails baseline — walks the identical path." : ''} Both stacks serve from #{memnote}#{db ? " (<code>#{esc(db)}</code>)" : ''}, the shape the ruby-bench lobsters benchmark runs. Median of the timed iterations is reported.
    #{matrix ? %(<p>The <strong>runtime × JIT matrix</strong> section re-runs the same frozen sequence once per interpreter × JIT lane — in-process, in-memory, single-threaded — so its rows differ only in the runtime under test.</p>) : ''}
    #{legacy_jruby ? %(<p>The <strong>JRuby lane</strong> replays the JRuby-emitted app in its own run: file-backed (no in-memory backup on the JDBC adapter) and timing the full route set — its numbers trend against earlier JRuby runs, not against the in-memory sections.</p>) : ''}
    <p class="caveat">This measures one specific reference app (the ruby-bench lobsters fixture), not arbitrary Rails workloads. The Rails baseline runs the <em>real</em> Rails lobsters over the same sequence; the roundhouse cell serves the same routes from the Roundhouse-emitted framework.</p>
  </div>
METHOD

# ── Section: vs Rails (legacy layout only — the lane layout's headline
# lives at the top of the matrix section, since they are one dataset) ──

if rails && timing && !lanes_mode
  html << "<h2>#{section_no}. Roundhouse vs Rails</h2>\n"
  html << %(<p>Milliseconds per iteration of the frozen #{vpi}-visit sequence — <strong>lower is better</strong>. The whisker spans each stack's min–max across its timed iterations.</p>\n)
  html << compare_bars([
    { label: ["rails #{rails['rails']}", jit_label(rails['ruby'])].compact.join(' '), color: COLOR_RAILS,
      median: rails['ms_per_iter_median'], min: rails['ms_per_iter_min'],
      max: rails['ms_per_iter_max'], iters: rails['iterations'] },
    { label: ['roundhouse', jit_label(env&.dig('ruby'))].compact.join(' '), color: COLOR_RH,
      median: timing['ms_per_iter_median'], min: timing['ms_per_iter_min'],
      max: timing['ms_per_iter_max'], iters: timing['iterations'] },
  ], left_pad: 160)
  if speedup
    html << %(<p><strong>#{fmt_dec(speedup, 2)}× faster than Rails</strong> — )
    html << %(#{fmt_dec(timing['ms_per_iter_median'], 1)} ms/iter vs Rails' #{fmt_dec(rails['ms_per_iter_median'], 1)} ms/iter.</p>\n)
  end
end

# ── Section: runtime × JIT matrix (from matrix/matrix.json) ──────────

mrows = matrix && (matrix['rows'] || [])
if mrows && !mrows.empty?
  msorted = mrows.sort_by { |r| r['ms_median'].to_f }
  mby_key = mrows.to_h { |r| [[r['kind'], r['yjit']], r] }
  # Colors keyed by lane id (matches the blog bench vocabulary); the
  # kind/yjit fallback covers matrix.json files that predate lane ids.
  mcolor = { 'rails' => COLOR_RAILS, 'rails-int' => '#e89c93', 'rails-jruby' => '#46707f',
             'ruby' => COLOR_RH, 'ruby-int' => '#b9a3ea', 'jruby' => COLOR_JR }
  lane_color = ->(r) do
    mcolor[r['id']] ||
      (r['kind'] == 'rails' ? (r['yjit'] ? COLOR_RAILS : '#e89c93')
                            : (r['yjit'] ? COLOR_RH    : '#b9a3ea'))
  end
  lane_jit = ->(r) { r['jit'] || (r['yjit'] ? '+YJIT' : 'no JIT') }

  # In the lane layout this section IS the headline — the vs-Rails number
  # is the same-JIT pair of these rows, so it opens the section rather
  # than duplicating as a chart of its own.
  if lanes_mode && speedup
    html << "<h2>#{section_no}. Roundhouse vs Rails — runtime × JIT</h2>\n"
    html << %(<p><strong>#{fmt_dec(speedup, 2)}× faster than Rails</strong> — #{fmt_dec(timing['ms_per_iter_median'], 1)} ms/iter vs Rails' #{fmt_dec(rails['ms_per_iter_median'], 1)}, both stacks CRuby with YJIT. The full field:</p>\n)
  else
    html << "<h2>#{section_no}. Runtime × JIT matrix</h2>\n"
  end
  html << <<~P
    <p>Every lane replays the same frozen sequence <strong>in-process, in-memory, single-threaded</strong> — no HTTP server, no load generator — so the only variable across rows is the interpreter × JIT under test (the <a href="https://railsatscale.com/2023-08-25-we-turned-lobsters-into-a-rails-benchmark-for-yjit/">ruby-bench lobsters-for-YJIT</a> shape). Lower is better; whiskers span each lane's min–max.</p>
  P
  html << compare_bars(msorted.map { |r|
    { label: "#{r['label']} #{lane_jit.(r)}", color: lane_color.(r),
      median: r['ms_median'], min: r['ms_min'], max: r['ms_max'],
      iters: r['iters'],
      note: (r['vs_rails'] && r['kind'] != 'rails' ? "#{fmt_dec(r['vs_rails'], 2)}× vs Rails" : nil) }
  }, left_pad: 160)

  insights = []
  %w[rails emit].each do |kind|
    on, off = mby_key[[kind, true]], mby_key[[kind, false]]
    next unless on && off && on['ms_median'].to_f > 0
    name = kind == 'rails' ? 'Rails' : 'Roundhouse'
    insights << "<strong>#{name}</strong> gains #{fmt_dec(off['ms_median'].to_f / on['ms_median'].to_f, 2)}× from YJIT (#{fmt_dec(off['ms_median'], 1)} → #{fmt_dec(on['ms_median'], 1)} ms/iter)"
  end
  [true, false].each do |yj|
    rl, em = mby_key[['rails', yj]], mby_key[['emit', yj]]
    next unless rl && em && em['ms_median'].to_f > 0
    insights << "<strong>Roundhouse</strong> is #{fmt_dec(rl['ms_median'].to_f / em['ms_median'].to_f, 2)}× faster than Rails #{yj ? 'with YJIT' : 'without a JIT'} (#{fmt_dec(rl['ms_median'], 1)} → #{fmt_dec(em['ms_median'], 1)} ms/iter)"
  end
  rj_row = mrows.find { |r| r['id'] == 'rails-jruby' }
  je_row = mrows.find { |r| r['id'] == 'jruby' }
  if rj_row && je_row && je_row['ms_median'].to_f > 0
    insights << "On the JVM, <strong>Roundhouse</strong> is #{fmt_dec(rj_row['ms_median'].to_f / je_row['ms_median'].to_f, 2)}× faster than Rails (#{fmt_dec(rj_row['ms_median'], 1)} → #{fmt_dec(je_row['ms_median'], 1)} ms/iter)"
    rl_y = mby_key[['rails', true]]
    if rl_y && rl_y['ms_median'].to_f > 0
      insights << "<strong>Rails itself</strong> runs #{fmt_dec(rj_row['ms_median'].to_f / rl_y['ms_median'].to_f, 2)}× slower on JRuby than on CRuby+YJIT (#{fmt_dec(rl_y['ms_median'], 1)} → #{fmt_dec(rj_row['ms_median'], 1)} ms/iter)"
    end
  end
  html << "<ul>\n#{insights.map { |i| "<li>#{i}</li>" }.join("\n")}\n</ul>\n" unless insights.empty?

  # Per-lane iteration series (lane layout): a CV column in the table
  # and collapsible stability strips — the old standalone stability
  # section, folded in so it scales with the lane count.
  lane_iters = {}
  if lanes_mode
    mrows.each do |r|
      data = sibling(File.join(run_path, r['id']), r['kind'] == 'rails' ? 'rails.json' : 'summary.json')
      t = r['kind'] == 'rails' ? data : data && data['sequence_timing']
      im = t && t['iter_ms']
      lane_iters[r['id']] = im if im && im.size > 1
    end
  end
  cv_col = !lane_iters.empty?

  html << "<table>\n<thead><tr><th>stack</th><th>JIT</th><th>ms/iter</th><th>min–max</th>#{cv_col ? '<th>CV</th>' : ''}<th>iters</th><th>vs Rails</th></tr></thead>\n<tbody>\n"
  msorted.each do |r|
    html << "<tr>"
    html << %(<td><strong>#{esc(r['label'])}</strong></td>)
    html << %(<td>#{lane_jit.(r)}</td>)
    html << %(<td class="num">#{fmt_dec(r['ms_median'], 2)}</td>)
    html << %(<td class="num">#{fmt_dec(r['ms_min'], 1)}–#{fmt_dec(r['ms_max'], 1)}</td>)
    if cv_col
      cv = cv_pct(lane_iters[r['id']])
      html << %(<td class="num">#{cv ? "#{fmt_dec(cv, 1)}%" : '—'}</td>)
    end
    html << %(<td class="num">#{r['iters']}</td>)
    html << %(<td class="num">#{r['vs_rails'] ? "#{fmt_dec(r['vs_rails'], 2)}×" : '—'}</td>)
    html << "</tr>\n"
  end
  html << "</tbody></table>\n"
  jr_note = if mrows.any? { |r| r['id'] == 'jruby' }
    mrows.any? { |r| r['id'] == 'rails-jruby' } ?
      ' The JVM rows pair with each other: Roundhouse JRuby\'s ratio is vs Rails on JRuby.' :
      ' The JRuby row compares against Rails +YJIT — Rails\' best CRuby configuration.'
  else
    ''
  end
  cv_note = cv_col ? ' CV = per-lane standard deviation ÷ mean across the timed iterations.' : ''
  html << %(<p class="legend">“vs Rails” compares each row to Rails at the same JIT level.#{jr_note}#{cv_note}</p>\n)
  if (rjc = mrows.find { |r| r['id'] == 'rails-jruby' })
    html << %(<p class="caveat"><code>Rails JRuby</code> is the stock-Rails-on-the-JVM baseline: the same app from a patched fixture — Rails #{esc(rjc['rails'] || '8.0.x')} (the AR-JDBC prerelease adapter pins it one minor behind the CRuby lanes), markdown through the same commonmark-java shim the Roundhouse JRuby lane uses, and a JRuby <code>Time.new</code> call-site bug worked around in an initializer.</p>\n)
  end

  strips = msorted.filter_map { |r| (im = lane_iters[r['id']]) ? [r, im] : nil }
  unless strips.empty?
    html << "<details>\n<summary>Per-lane iteration stability (#{strips.size} lanes)</summary>\n"
    strips.each do |r, im|
      html << "<h3>#{esc(r['label'])} #{lane_jit.(r)} — #{fmt_dec(r['ms_median'], 1)} ms/iter median over #{im.size} iterations (#{r['warmup']} warmup)</h3>\n"
      html << iter_columns(im, median: r['ms_median'], min: r['ms_min'], max: r['ms_max'],
                           color: lane_color.(r))
    end
    html << %(<p class="legend">Each column is one timed iteration, scaled within a tight band around the lane's spread; the dashed line is the median.</p>\n)
    html << "</details>\n"
  end

  prov = [matrix['generated_at'], matrix['host'] && "host <code>#{esc(matrix['host'])}</code>"].compact.join(' · ')
  if lanes_mode
    html << %(<p class="caveat">Lanes measured #{prov} — one process per lane, JIT pinned per lane.</p>\n) unless prov.empty?
  else
    # Legacy layout: the headline was a SEPARATE run inheriting ambient
    # RUBYOPT — tie it to its same-JIT matrix row; the cross-JIT gap is
    # real, not jitter.
    head_note = ''
    if speedup && env&.dig('ruby')
      head_yjit = env['ruby'].include?('+YJIT')
      if mby_key[['emit', head_yjit]]
        head_note = %( The headline comparison above ran #{head_yjit ? 'with YJIT' : 'without a JIT'} on both stacks, so it corresponds to the #{head_yjit ? '+YJIT' : 'no-JIT'} rows here; small differences from those rows are run-to-run jitter.)
      end
    end
    html << %(<p class="caveat">Matrix lanes measured #{prov} — one process per lane over the same emit tree.#{head_note}</p>\n) unless prov.empty?
  end
end

# ── Section: per-endpoint breakdown ──────────────────────────────────

rh_pr = timing && timing['per_route']
rl_pr = rails && rails['per_route']
jr_pr = jruby_seq && jruby_seq['per_route']
# The no-JIT lanes' per-endpoint medians (lane layout): table-only columns
# — the chart stays at one series per stack's best configuration. Skipped
# when the primary emit lane IS ruby-int (they'd duplicate the main columns).
rl_int_pr = prim == 'ruby' ? sibling(File.join(run_path, 'rails-int'), 'rails.json')&.dig('per_route') : nil
rh_int_pr = prim == 'ruby' ? sibling(File.join(run_path, 'ruby-int'), 'summary.json')&.dig('sequence_timing', 'per_route') : nil
rl_jvm_pr = lanes_mode ? sibling(File.join(run_path, 'rails-jruby'), 'rails.json')&.dig('per_route') : nil
if rh_pr && rl_pr && !rh_pr.empty?
  shared = rh_pr.keys.select { |k| rl_pr.key?(k) }
  rh_iters = timing['iterations'].to_i
  breakdown = shared.map do |k|
    rl = rl_pr[k]['ms_median'].to_f
    rh = rh_pr[k]['ms_median'].to_f
    { key: k, rails: rl, rh: rh,
      jr: jr_pr&.dig(k, 'ms_median')&.to_f,
      rails_int: rl_int_pr&.dig(k, 'ms_median')&.to_f,
      rh_int:    rh_int_pr&.dig(k, 'ms_median')&.to_f,
      rails_jvm: rl_jvm_pr&.dig(k, 'ms_median')&.to_f,
      ratio: rh > 0 ? rl / rh : nil,
      per_iter: rh_iters > 0 ? (rh_pr[k]['n'].to_f / rh_iters).round : nil }
  end.sort_by { |r| -r[:rails] }

  jr_col  = jr_pr && breakdown.any? { |b| b[:jr] }
  rli_col = rl_int_pr && breakdown.any? { |b| b[:rails_int] }
  rhi_col = rh_int_pr && breakdown.any? { |b| b[:rh_int] }
  rjv_col = rl_jvm_pr && breakdown.any? { |b| b[:rails_jvm] }
  chart_note = if jr_col
    ' The chart shows each stack\'s <strong>best configuration</strong> — Rails +YJIT, Roundhouse +YJIT, Roundhouse on JRuby' \
      "#{rli_col || rhi_col ? '; the no-JIT lanes appear as extra columns in the table below' : ''}."
  else
    ''
  end
  html << "<h2>#{section_no}. Per-endpoint breakdown</h2>\n"
  html << <<~P
    <p>Where the overall #{speedup ? "#{fmt_dec(speedup, 2)}× " : ''}win comes from — each endpoint's median latency over every timed visit of the frozen sequence#{jr_col ? ', per lane' : ', Rails vs roundhouse'}. Bars are log-scaled; the <strong>ratio</strong> at the right is Rails ÷ roundhouse#{jr_col ? ' (both CRuby +YJIT)' : ''} (green = roundhouse faster).#{chart_note}</p>
    <p class="caveat">A diagnostic breakdown, not a re-derivation: per-endpoint medians don't sum to the sequence median (GC and ordering don't decompose linearly), and the sub-millisecond rows sit near clock resolution — trust the ranking, not the third decimal.</p>
  P
  html << paired_hbar(breakdown, jr: jr_col)

  html << "<details>\n<summary>Per-endpoint table (#{breakdown.size} endpoints)</summary>\n"
  html << "<table>\n<thead><tr><th>endpoint</th><th>rails</th>#{rli_col ? '<th>rails no-JIT</th>' : ''}#{rjv_col ? '<th>rails JRuby</th>' : ''}<th>roundhouse</th>#{rhi_col ? '<th>roundhouse no-JIT</th>' : ''}#{jr_col ? '<th>jruby</th>' : ''}<th>ratio</th><th>visits/iter</th></tr></thead>\n<tbody>\n"
  breakdown.each do |b|
    rcls = b[:ratio].nil? ? '' : (b[:ratio] >= 1 ? 'ok' : 'no')
    html << "<tr>"
    html << %(<td><code>#{esc(b[:key])}</code></td>)
    html << %(<td class="num">#{fmt_dec(b[:rails], 2)}</td>)
    html << %(<td class="num">#{b[:rails_int] ? fmt_dec(b[:rails_int], 2) : '—'}</td>) if rli_col
    html << %(<td class="num">#{b[:rails_jvm] ? fmt_dec(b[:rails_jvm], 2) : '—'}</td>) if rjv_col
    html << %(<td class="num">#{fmt_dec(b[:rh], 2)}</td>)
    html << %(<td class="num">#{b[:rh_int] ? fmt_dec(b[:rh_int], 2) : '—'}</td>) if rhi_col
    html << %(<td class="num">#{b[:jr] ? fmt_dec(b[:jr], 2) : '—'}</td>) if jr_col
    html << %(<td class="num #{rcls}">#{b[:ratio] ? "#{fmt_dec(b[:ratio], 2)}×" : '—'}</td>)
    html << %(<td class="num">#{b[:per_iter]}</td>)
    html << "</tr>\n"
  end
  html << "</tbody></table>\n"
  if jr_col || rli_col || rhi_col || rjv_col
    html << %(<p class="legend">All lane columns are median ms per visit; ratio = rails ÷ roundhouse (the +YJIT pair).</p>\n)
  end
  html << "</details>\n"
end

# ── Section: frozen-sequence stability (legacy layout only — the lane
# layout folds this into the matrix section's CV column + strips) ──────

if timing && timing['iter_ms'] && !lanes_mode
  n = timing['iter_ms'].size
  html << "<h2>#{section_no}. Frozen-sequence stability</h2>\n"
  caption = "#{fmt_dec(timing['ms_per_iter_median'], 1)} ms/iter median over #{n} iterations " \
            "(min #{fmt_dec(timing['ms_per_iter_min'], 1)}, max #{fmt_dec(timing['ms_per_iter_max'], 1)}, " \
            "#{timing['warmup']} warmup). Each column is one timed iteration; the dashed line is the median."
  html << "<p>#{caption}</p>\n"
  if timing['failed_visits'].to_i > 0
    html << %(<p class="caveat">#{timing['failed_visits']} visit(s) failed during timing#{timing['partial'] ? ' — partial run' : ''}.</p>\n)
  end
  html << iter_columns(timing['iter_ms'],
                       median: timing['ms_per_iter_median'],
                       min: timing['ms_per_iter_min'],
                       max: timing['ms_per_iter_max'])
end

# ── Section: route parity ────────────────────────────────────────────

# In the lane layout the jruby lane replayed the same routes — render its
# parity as extra columns so cross-runtime coverage reads off one table.
jr_routes = lanes_mode && jruby ? (jruby['routes'] || []).to_h { |r| [r['route'], r] } : {}

if lanes_mode
  # This section is the COVERAGE ATTESTATION, not a performance chart:
  # it certifies that the timing sections above measured a complete
  # application surface, per emit target. (The old single-shot latency
  # chart invited performance readings of noisy one-shot numbers that
  # the medians above answer properly — dropped.)
  jr_all = !jr_routes.empty? && jruby_pass == jruby_total
  html << "<h2>#{section_no}. Coverage &amp; parity (#{pass}/#{total}#{jr_routes.empty? ? '' : " · jruby #{jruby_pass}/#{jruby_total}"})</h2>\n"
  if all_pass && (jr_routes.empty? || jr_all)
    html << <<~P
      <p>What the numbers above are numbers <em>of</em>: every distinct route the benchmark exercises returns <strong>200 on every emit target</strong> — the timing sections measure a complete application, not a working subset. Response sizes are compared across runtimes as a same-output proxy (bodies differ only in CSRF token and clock; normalized body hashes are the planned upgrade). A failing cell here would invalidate that lane's rows above.</p>
    P
  else
    fails = []
    fails << "#{total - pass} route(s) fail on the CRuby lane" unless all_pass
    fails << "#{jruby_total - jruby_pass} route(s) fail on the jruby lane" unless jr_routes.empty? || jr_all
    html << %(<p><strong>Incomplete coverage:</strong> #{fails.join('; ')} — the failing routes' visits short-circuit cheaply, so treat the affected lane's timing rows above as optimistic. Details in the table.</p>\n)
  end
else
  html << "<h2>#{section_no}. Route parity (#{pass}/#{total})</h2>\n"
  html << %(<p>Every distinct benchmark route, replayed once. Bars are log-scaled single-shot latency; #{all_pass ? 'all routes return 200' : 'red bars are non-200 routes'}.</p>\n)
  html << route_hbar(routes, metric: 'ms', unit: 'ms', fmt: ->(v) { "#{fmt_dec(v, 1)} ms" })
end

html << "<details open>\n<summary>Per-route table (#{routes.size} routes)</summary>\n"
html << "<table>\n<thead><tr><th>route</th><th>status</th><th>bytes</th><th>ms</th>#{jr_routes.empty? ? '' : '<th>jruby</th><th>jruby ms</th>'}</tr></thead>\n<tbody>\n"
routes.each do |c|
  status_cls = c['ok'] == false ? 'no' : 'ok'
  html << "<tr>"
  html << %(<td><code>#{esc(c['route'])}</code>#{c['thin'] ? ' <span class="no">(thin)</span>' : ''}</td>)
  html << %(<td class="num #{status_cls}">#{c['status']}</td>)
  html << %(<td class="num">#{fmt_int(c['bytes'])}</td>)
  html << %(<td class="num">#{fmt_dec(c['ms'], 2)}</td>)
  unless jr_routes.empty?
    if (j = jr_routes[c['route']])
      jcls = j['ok'] == false ? 'no' : 'ok'
      # Response sizes should track the CRuby lane (bodies are byte-
      # identical mod CSRF token + clock); flag drift beyond noise.
      bytes_note = (j['bytes'].to_i - c['bytes'].to_i).abs > 64 ? %( <span class="no">(#{fmt_int(j['bytes'])} B)</span>\n) : ''
      html << %(<td class="num #{jcls}">#{j['status']}#{bytes_note}</td>)
      html << %(<td class="num">#{fmt_dec(j['ms'], 2)}</td>)
    else
      html << %(<td class="num">—</td><td class="num">—</td>)
    end
  end
  html << "</tr>\n"
end
html << "</tbody></table>\n"
if lanes_mode
  drift = jr_routes.empty? ? '' : ' jruby cells flag a response size that drifts more than 64 bytes from the CRuby lane\'s.'
  html << %(<p class="legend">ms columns are single-shot diagnostic latencies — use the medians above for performance.#{drift}</p>\n)
end
html << "</details>\n"

# ── Section: JRuby lane (legacy layout only — in the lane layout the ──
# jruby lane lives in the matrix / per-endpoint / parity sections) ─────

if legacy_jruby
  jt = jruby['sequence_timing'] || jruby['timing']
  html << "<h2>#{section_no}. JRuby lane (#{jruby_pass}/#{jruby_total})</h2>\n"
  metric = if jruby['sequence_timing']
    "the frozen #{jt['visits_per_iter']}-visit sequence"
  elsif jt
    "the full route set (#{jt['routes_per_iter']} routes per iteration)"
  else
    'route parity only'
  end
  html << <<~P
    <p>The same lobsters app emitted with <code>--target jruby</code> and replayed in-process under JRuby, in its own run. This lane is <strong>file-backed</strong> — the JDBC SQLite adapter has no in-memory backup — and times #{metric}, so its numbers trend against earlier JRuby runs rather than comparing with the in-memory sections above.</p>
  P
  facts = [['route parity', "#{jruby_pass}/#{jruby_total} routes return 200"]]
  if jt
    facts += [
      ['ms/iter (median)', "#{fmt_dec(jt['ms_per_iter_median'], 1)} ms"],
      ['min–max',          "#{fmt_dec(jt['ms_per_iter_min'], 1)}–#{fmt_dec(jt['ms_per_iter_max'], 1)} ms"],
      ['iterations',       jt['iterations']],
      ['warmup',           jt['warmup'] && "#{jt['warmup']} discarded iterations (JRuby's JIT warms slowly on this metric)"],
    ]
    facts << ['partial', 'yes — failing routes short-circuit cheaply; not comparable to a full-parity run'] if jt['partial']
  end
  facts << ['runtime', jruby_env&.dig('ruby') && "<code>#{esc(jruby_env['ruby'])}</code>"]
  facts << ['java opts', jruby_env&.dig('java_opts') && "<code>#{esc(jruby_env['java_opts'])}</code>"]
  facts << ['measured', jruby['generated_at']]
  html << kv_table(facts)
  jbad = (jruby['routes'] || []).reject { |r| r['ok'] }
  unless jbad.empty?
    html << %(<p class="caveat">Non-200 routes: #{jbad.map { |r| "<code>#{esc(r['route'])}</code> (#{r['status']})" }.join(', ')}.</p>\n)
  end
end

# ── environment appendix ─────────────────────────────────────────────

html << %(<details id="environment">\n<summary>Environment</summary>\n)
html << "<h3>Run</h3>\n"
html << kv_table([
  ['command',    env&.dig('command') && "<code>#{esc(env['command'])}</code>"],
  ['source',     env&.dig('src') && "<code>#{esc(env['src'])}</code>"],
  ['commit',     env&.dig('roundhouse_commit') && "<code>#{env['roundhouse_commit']}</code>"],
  ['captured',   env&.dig('generated_at') || summary['generated_at']],
  ['database',   db && "<code>#{esc(db)}</code>"],
  ['seed',       summary['seed']],
  ['story / comment', [summary['story_id'], summary['comment_id']].compact.join(' / ')],
])
html << "<h3>Stacks</h3>\n"
html << kv_table([
  ['roundhouse ruby', env&.dig('ruby') && "<code>#{esc(env['ruby'])}</code>"],
  ['rails ruby',      rails&.dig('ruby') && "<code>#{esc(rails['ruby'])}</code>"],
  ['rails',           rails&.dig('rails')],
])
if timing || rails
  html << "<h3>Sequence</h3>\n"
  html << kv_table([
    ['visits/iter',       vpi],
    ['warmup',            timing&.dig('warmup') || rails&.dig('warmup')],
    ['roundhouse iters',  timing&.dig('iterations')],
    ['rails iters',       rails&.dig('iterations')],
  ])
end
html << "</details>\n"

html << %(<hr><p class="meta">Generated #{Time.now.utc.iso8601} from <code>#{File.basename(input)}</code>.</p>\n)
html << "</body>\n</html>\n"

File.write(out, html)
$stderr.puts "wrote #{out} (#{html.bytesize} bytes)"
