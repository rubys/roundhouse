#!/usr/bin/env ruby
# scripts/lobsters-matrix — run the lobsters benchmark across runtime × JIT
# lanes and render ONE comparison page: the lobsters analogue of the blog
# bench matrix (rubys.github.io/roundhouse/bench/), scaled down to the
# runtimes that are ready and grown over time.
#
# FIDELITY TO railsatscale (the ruby-bench lobsters-for-YJIT benchmark):
# every lane is measured the SAME way — driven IN-PROCESS at the Rack layer
# (no HTTP server, no wrk), against an IN-MEMORY SQLite seeded from the file
# DB, SINGLE-THREADED, replaying the SAME frozen 114-visit sequence. The only
# thing that varies across rows is the language × JIT under test. wrk (adds a
# per-language web server to the measurement) and file-backed I/O (~11% here)
# are gratuitous differences and are deliberately kept out.
#
# v1 lanes (all CRuby-family — more runtimes join as they gain an in-process
# replay driver + an in-memory DB seed; see the ladder in the memory notes):
#   ruby      — roundhouse emit, YJIT on      (bench-lobsters --frozen)
#   ruby-int  — roundhouse emit, YJIT off      "
#   rails     — real Rails,      YJIT on       (lobsters-rails-replay)   [needs bundle]
#   rails-int — real Rails,      YJIT off       "                        [needs bundle]
#
# Usage:
#   scripts/lobsters-matrix [--time N] [--src DIR] [--skip-emit] [--no-rails] [--out DIR]
#   scripts/lobsters-matrix --render DIR        # re-render index.html from DIR/matrix.json
#
#   --time N     min timed iterations per lane (default 10; ≥N and ≥10s, the
#                ruby-bench rule). Bigger = tighter medians on a quiet box.
#   --src DIR    lobsters checkout (default $LOBSTERS_SRC or ~/git/ruby-bench/…)
#   --skip-emit  reuse the existing emit tree (skip transpile)
#   --no-rails   emit lanes only (skip the Rails baseline)
#   --out DIR    matrix dir (default bench/results/lobsters/matrix/<timestamp>)
#   --render DIR re-render DIR/index.html from an existing DIR/matrix.json and
#                exit (iterate on the page without re-benchmarking)
#
# Output (OUT dir):
#   matrix.json  # machine-readable: one row per lane
#   index.html   # the rendered comparison page (self-contained, theme-aware)
# plus bench/results/lobsters/matrix/latest -> newest matrix dir.
#
# A lane that fails is dropped with a note; the page renders from whatever
# succeeded (so a box without the Rails bundle still gets the emit rows).

require "json"
require "socket"
require "fileutils"

REPO = File.expand_path("..", __dir__)
FROZEN = File.join(REPO, "bench/lobsters/frozen-sequence.json")

opts = { time: 10, src: ENV["LOBSTERS_SRC"] || File.expand_path("~/git/ruby-bench/benchmarks/lobsters"),
         skip_emit: false, rails: true, out: nil, render: nil }
args = ARGV.dup
until args.empty?
  case (a = args.shift)
  when "--time"      then opts[:time] = Integer(args.shift)
  when "--src"       then opts[:src] = File.expand_path(args.shift)
  when "--skip-emit" then opts[:skip_emit] = true
  when "--no-rails"  then opts[:rails] = false
  when "--out"       then opts[:out] = File.expand_path(args.shift)
  when "--render"    then opts[:render] = File.expand_path(args.shift)
  when "-h", "--help" then puts File.read(__FILE__)[/\A(#.*\n)+/].gsub(/^# ?/, ""); exit 0
  else abort "lobsters-matrix: unknown arg #{a}"
  end
end

def step(msg) = warn("\e[36m→\e[0m #{msg}")
def ok(msg)   = warn("\e[32m✓\e[0m #{msg}")
def bad(msg)  = warn("\e[31m✗\e[0m #{msg}")
def dir_p(d)  = (FileUtils.mkdir_p(d); d)

def h(s) = s.to_s.gsub("&", "&amp;").gsub("<", "&lt;").gsub(">", "&gt;")
def ruby_short(desc) = desc.to_s[/ruby \d+\.\d+\.\d+/] || desc.to_s[/[^ ]+ \d+\.\d+/] || desc.to_s

# ── render ───────────────────────────────────────────────────────────
def render_page(matrix, mdir)
  rows   = matrix["rows"]
  sorted = rows.sort_by { |r| r["ms_median"] }              # fastest first
  maxms  = rows.map { |r| r["ms_median"] }.max
  by_key = rows.to_h { |r| [[r["kind"], r["yjit"]], r] }

  bars = sorted.map do |r|
    pct   = (r["ms_median"] / maxms * 100).round(1)
    label = "#{r["label"]} #{r["yjit"] ? "+YJIT" : "· no-JIT"}"
    ratio = r["vs_rails"] ? %{<span class="ratio">#{r["vs_rails"]}× vs Rails</span>} : ""
    <<~BAR
      <div class="bar-row">
        <div class="bar-label">#{h(label)}</div>
        <div class="bar-track"><div class="bar-fill #{r["kind"]}" style="width:#{pct}%"></div></div>
        <div class="bar-meta"><span class="bar-ms">#{r["ms_median"]}<small>ms/iter</small></span>#{ratio}</div>
      </div>
    BAR
  end.join("\n")

  table = sorted.map do |r|
    ratio = r["vs_rails"] ? "#{r["vs_rails"]}×" : "—"
    <<~ROW
      <tr>
        <td><span class="dot #{r["kind"]}"></span>#{h(r["label"])}</td>
        <td>#{r["yjit"] ? "YJIT" : "no-JIT"}</td>
        <td class="num strong">#{r["ms_median"]}</td>
        <td class="num dim">#{r["ms_min"]}–#{r["ms_max"]}</td>
        <td class="num dim">#{r["iters"]}</td>
        <td class="num">#{ratio}</td>
      </tr>
    ROW
  end.join("\n")

  insights = []
  %w[rails emit].each do |kind|
    on = by_key[[kind, true]]; off = by_key[[kind, false]]
    next unless on && off
    name = kind == "rails" ? "Rails" : "Roundhouse"
    insights << "<b>#{name}</b> gains #{(off["ms_median"] / on["ms_median"]).round(2)}× from YJIT (#{off["ms_median"]} → #{on["ms_median"]} ms/iter)"
  end
  [true, false].each do |yj|
    rl = by_key[["rails", yj]]; em = by_key[["emit", yj]]
    next unless rl && em
    insights << "<b>Roundhouse</b> is #{(rl["ms_median"] / em["ms_median"]).round(2)}× faster than Rails #{yj ? "with YJIT" : "without a JIT"} (#{rl["ms_median"]} → #{em["ms_median"]} ms/iter)"
  end

  rubies  = rows.map { |r| ruby_short(r["ruby"]) }.uniq
  rails_v = rows.map { |r| r["rails"] }.compact.uniq.first

  html = <<~HTML
    <title>Lobsters benchmark — Roundhouse vs Rails</title>
    <style>
      :root {
        --bg:#fcfcfd; --panel:#f4f5f7; --fg:#181b21; --dim:#5c6470; --line:#e5e7ec;
        --rails:#b45309; --emit:#2f6feb; --accent:#2f6feb;
        --track:#eceef2;
      }
      @media (prefers-color-scheme: dark) {
        :root { --bg:#121419; --panel:#191c22; --fg:#e7e9ee; --dim:#949cab; --line:#282c34;
                --rails:#f0a020; --emit:#6ea8fe; --accent:#6ea8fe; --track:#22262e; }
      }
      :root[data-theme="light"] { --bg:#fcfcfd; --panel:#f4f5f7; --fg:#181b21; --dim:#5c6470;
        --line:#e5e7ec; --rails:#b45309; --emit:#2f6feb; --accent:#2f6feb; --track:#eceef2; }
      :root[data-theme="dark"]  { --bg:#121419; --panel:#191c22; --fg:#e7e9ee; --dim:#949cab;
        --line:#282c34; --rails:#f0a020; --emit:#6ea8fe; --accent:#6ea8fe; --track:#22262e; }
      * { box-sizing:border-box; }
      body { margin:0; background:var(--bg); color:var(--fg);
        font:15px/1.55 -apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
        -webkit-font-smoothing:antialiased; }
      .wrap { max-width:820px; margin:0 auto; padding:2.75rem 1.25rem 4rem; }
      h1 { font-size:1.55rem; margin:0 0 .3rem; letter-spacing:-.015em; text-wrap:balance; }
      .sub { color:var(--dim); margin:0 0 2.25rem; font-size:.95rem; max-width:60ch; text-wrap:pretty; }
      .sub b { color:var(--fg); font-weight:600; }
      h2 { font-size:.78rem; text-transform:uppercase; letter-spacing:.08em; color:var(--dim);
        margin:2.4rem 0 1rem; font-weight:700; }
      .bars { display:flex; flex-direction:column; gap:.5rem; }
      .bar-row { display:grid; grid-template-columns:8.5rem 1fr 10.5rem; align-items:center; gap:.85rem; }
      .bar-label { font-size:.88rem; text-align:right; color:var(--fg); }
      .bar-track { background:var(--track); border-radius:4px; height:1.7rem; overflow:hidden; }
      .bar-fill { height:100%; border-radius:4px; }
      .bar-fill.rails { background:var(--rails); } .bar-fill.emit { background:var(--emit); }
      .bar-meta { display:flex; flex-direction:column; line-height:1.25; }
      .bar-ms { font-variant-numeric:tabular-nums; font-weight:600; font-size:.95rem; }
      .bar-ms small { color:var(--dim); font-weight:400; font-size:.72rem; margin-left:.25rem; }
      .ratio { color:var(--accent); font-weight:600; font-size:.8rem; }
      .lower { color:var(--dim); font-size:.8rem; margin:.6rem 0 0; }
      table { border-collapse:collapse; width:100%; margin:.2rem 0 .4rem; font-size:.92rem; }
      th,td { text-align:left; padding:.5rem .55rem; border-bottom:1px solid var(--line); }
      th { color:var(--dim); font-weight:600; font-size:.72rem; text-transform:uppercase; letter-spacing:.05em; }
      td.num { text-align:right; font-variant-numeric:tabular-nums; }
      td.strong { font-weight:700; } td.dim { color:var(--dim); }
      .dot { display:inline-block; width:.58rem; height:.58rem; border-radius:50%; margin-right:.5rem; vertical-align:middle; }
      .dot.rails { background:var(--rails); } .dot.emit { background:var(--emit); }
      .note { color:var(--dim); font-size:.85rem; margin:.1rem 0 0; }
      .card { background:var(--panel); border:1px solid var(--line); border-radius:9px; padding:.9rem 1.15rem; }
      .card ul { margin:0; padding-left:1.15rem; } .card li { margin:.35rem 0; }
      .card b { color:var(--fg); }
      footer { margin-top:2.75rem; padding-top:1.1rem; border-top:1px solid var(--line);
        color:var(--dim); font-size:.82rem; line-height:1.6; }
      footer b { color:var(--fg); } footer a { color:var(--accent); }
      footer code { background:var(--panel); padding:.05rem .35rem; border-radius:4px; font-size:.9em; }
    </style>
    <div class="wrap">
      <h1>Lobsters benchmark — Roundhouse vs Rails</h1>
      <p class="sub">Milliseconds per iteration of the frozen 114-visit sequence — <b>lower is
        better</b>. Every row runs the same benchmark <b>in-process, in-memory, single-threaded</b>;
        only the language&nbsp;×&nbsp;JIT differs.</p>

      <h2>Throughput</h2>
      <div class="bars">
      #{bars}
      </div>
      <p class="lower">Bar length ∝ ms/iter · shorter is faster.</p>

      <h2>Detail</h2>
      <table>
        <tr><th>Stack</th><th>JIT</th><th class="num">ms/iter</th><th class="num">min–max</th><th class="num">iters</th><th class="num">vs Rails</th></tr>
        #{table}
      </table>
      <p class="note">“vs Rails” compares each row to Rails at the <i>same</i> JIT level.</p>

      #{insights.empty? ? "" : %{<h2>What moves the needle</h2>\n<div class="card"><ul>\n#{insights.map { |i| "<li>#{i}</li>" }.join("\n")}\n</ul></div>}}

      <footer>
        <p><b>Methodology.</b> Faithful to the
          <a href="https://railsatscale.com/2023-08-25-we-turned-lobsters-into-a-rails-benchmark-for-yjit/">ruby-bench lobsters-for-YJIT</a>
          benchmark: the app is driven directly at the Rack layer — no HTTP server, no load generator —
          against an in-memory SQLite seeded from the 42&nbsp;MB production DB, replaying one frozen
          RNG-seeded 114-visit authenticated sequence. #{matrix["time"]}+ timed iterations (≥10s) after
          15 warmup iterations; median reported.</p>
        <p>Ruby #{h(rubies.join(", "))}#{rails_v ? " · Rails #{h(rails_v)}" : ""} · host <code>#{h(matrix["host"])}</code> · #{matrix["generated_at"]}</p>
        <p>Rows grow as runtimes gain an in-process replay driver + in-memory seed — JRuby next, then Spinel, Rust, …</p>
      </footer>
    </div>
  HTML

  File.write(File.join(mdir, "index.html"), html)
end

# --render: re-render from an existing matrix.json and exit.
if opts[:render]
  mj = File.join(opts[:render], "matrix.json")
  abort "lobsters-matrix: no matrix.json in #{opts[:render]}" unless File.exist?(mj)
  render_page(JSON.parse(File.read(mj)), opts[:render])
  ok "re-rendered #{File.join(opts[:render], 'index.html')}"
  exit 0
end

# ── run lanes ────────────────────────────────────────────────────────
TS = Time.now.strftime("%Y%m%d-%H%M%S")
MDIR = opts[:out] || File.join(REPO, "bench/results/lobsters/matrix", TS)
FileUtils.mkdir_p(MDIR)

# Lane table. `yjit` sets RUBYOPT; `kind` groups Rails-vs-Roundhouse; `runner`
# picks the harness. Add a row here (+ a runner) to grow the matrix.
LANES = [
  { id: "rails",     label: "Rails",      kind: "rails", yjit: true,  runner: :rails },
  { id: "rails-int", label: "Rails",      kind: "rails", yjit: false, runner: :rails },
  { id: "ruby",      label: "Roundhouse", kind: "emit",  yjit: true,  runner: :emit  },
  { id: "ruby-int",  label: "Roundhouse", kind: "emit",  yjit: false, runner: :emit  },
].freeze

# RUBYOPT is set explicitly per lane so the no-YJIT lanes can't inherit a
# stray --yjit from the ambient environment (determinism over convenience).
def rubyopt_env(yjit) = { "RUBYOPT" => (yjit ? "--yjit" : "") }

def lane_row(lane, t, ruby:, rails: nil, visits: nil)
  { "id" => lane[:id], "label" => lane[:label], "kind" => lane[:kind], "yjit" => lane[:yjit],
    "ms_median" => t["ms_per_iter_median"], "ms_min" => t["ms_per_iter_min"],
    "ms_max" => t["ms_per_iter_max"], "iters" => t["iterations"],
    "warmup" => t["warmup"], "ruby" => ruby, "rails" => rails, "visits" => visits }
end

# $emitted: emit the tree once, then --skip-emit every later emit lane.
def run_emit_lane(lane, opts, mdir)
  dir = dir_p(File.join(mdir, lane[:id]))
  cmd = [File.join(REPO, "scripts/bench-lobsters"), "--frozen", "--time", opts[:time].to_s,
         "--src", opts[:src], "--out", dir]
  cmd << "--skip-emit" if opts[:skip_emit] || $emitted
  step "lane #{lane[:id]}: bench-lobsters --frozen (YJIT #{lane[:yjit] ? 'on' : 'off'})"
  unless system(rubyopt_env(lane[:yjit]), *cmd, out: File.join(dir, "run.log"), err: %i[child out])
    bad "lane #{lane[:id]} failed (see #{dir}/run.log)"; return nil
  end
  $emitted = true
  st  = (JSON.parse(File.read(File.join(dir, "summary.json")))["sequence_timing"] rescue nil)
  env = (JSON.parse(File.read(File.join(dir, "env.json"))) rescue {})
  return (bad "lane #{lane[:id]}: no sequence_timing"; nil) unless st
  lane_row(lane, st, ruby: env["ruby"], visits: st["visits_per_iter"])
end

def run_rails_lane(lane, opts, mdir)
  dir  = dir_p(File.join(mdir, lane[:id]))
  seq  = File.join(dir, "sequence.json")
  json = File.join(dir, "rails.json")
  step "lane #{lane[:id]}: lobsters-rails-replay (YJIT #{lane[:yjit] ? 'on' : 'off'}; boots real Rails, minutes)"
  cmd = [File.join(REPO, "scripts/lobsters-rails-replay"), "--src", opts[:src],
         "--warmup", "15", "--min-iters", opts[:time].to_s, "--min-time", "10",
         "--seq-out", seq, "--json", json]
  unless system(rubyopt_env(lane[:yjit]), *cmd, out: File.join(dir, "run.log"), err: %i[child out])
    bad "lane #{lane[:id]} failed (see #{dir}/run.log)"; return nil
  end
  # The rails lane regenerates the sequence; it must match the frozen one the
  # emit lanes replayed, or the rows aren't comparable.
  if File.exist?(FROZEN) && File.read(seq) != File.read(FROZEN)
    bad "lane #{lane[:id]}: regenerated sequence != committed frozen-sequence.json — DB/generator changed; rows NOT comparable"
  end
  r = (JSON.parse(File.read(json)) rescue nil)
  return (bad "lane #{lane[:id]}: no rails.json"; nil) unless r
  lane_row(lane, r, ruby: r["ruby"], rails: r["rails"], visits: r["visits_per_iter"])
end

$emitted = opts[:skip_emit]
rails_ok = opts[:rails] && system("bash", "-c", "cd #{opts[:src].inspect} && bundle check", %i[out err] => File::NULL)
warn "lobsters-matrix: Rails bundle unavailable — emit lanes only" if opts[:rails] && !rails_ok

rows = LANES.filter_map do |lane|
  case lane[:runner]
  when :emit  then run_emit_lane(lane, opts, MDIR)
  when :rails then rails_ok ? run_rails_lane(lane, opts, MDIR) : nil
  end
end
abort "lobsters-matrix: every lane failed; nothing to render" if rows.empty?

# ── aggregate ────────────────────────────────────────────────────────
# Ratio = same-JIT Rails baseline / this row (Roundhouse rows read as "N×
# faster than Rails at the same JIT level"; Rails rows read 1.00).
rails_by_yjit = rows.select { |r| r["kind"] == "rails" }.to_h { |r| [r["yjit"], r] }
rows.each do |r|
  base = rails_by_yjit[r["yjit"]]
  r["vs_rails"] = base ? (base["ms_median"] / r["ms_median"]).round(2) : nil
end

matrix = {
  "generated_at" => Time.now.utc.strftime("%FT%TZ"),
  "host" => Socket.gethostname,
  "workload" => "frozen #{rows.map { |r| r["visits"] }.compact.first || 114}-visit sequence, in-memory, in-process, single-threaded",
  "time" => opts[:time],
  "rows" => rows,
}
File.write(File.join(MDIR, "matrix.json"), JSON.pretty_generate(matrix))
render_page(matrix, MDIR)

# matrix/latest -> this run (relative, so it resolves inside the served tree).
if File.basename(File.dirname(MDIR)) == "matrix"
  link = File.join(File.dirname(MDIR), "latest")
  File.delete(link) if File.symlink?(link) || File.exist?(link)
  File.symlink(File.basename(MDIR), link)
end

ok "matrix: #{rows.size} lanes → #{File.join(MDIR, 'index.html')}"
puts "\n== lobsters matrix (#{rows.size} lanes, ms/iter, lower=better) =="
rows.sort_by { |r| r["ms_median"] }.each do |r|
  printf "  %-11s %-7s %8.2f ms/iter  %s\n", r["label"], (r["yjit"] ? "YJIT" : "no-JIT"),
         r["ms_median"], (r["vs_rails"] ? "#{r["vs_rails"]}× vs Rails" : "")
end
