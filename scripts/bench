#!/usr/bin/env bash
# scripts/bench — per-target HTTP throughput + memory benchmark.
#
# Measures req/sec, p50/p99 latency, and resident-set-size at sustained
# load, then computes the cost-economics headline: req/sec per GB of
# resident memory. That ratio captures what cloud bills actually charge
# for — CRuby's GVL-fork tax means each worker carries ~200-400MB of
# framework regardless of activity; compiled targets handle the same
# concurrency in one shared image at ~30-50MB.
#
# Usage:  scripts/bench [options] [TARGET ...]
#
#   TARGET ∈ { rails | rails-int | ruby | ruby-int | typescript |
#              crystal | rust | spinel | go | python | elixir }
#              (default: rails ruby)
#
#   `go` = Roundhouse-emit Go (single AOT binary, net/http server,
#          modernc.org/sqlite). Built from `cmd/v2/main.go`.
#   `elixir` = Roundhouse-emit Elixir (BEAM, Plug.Cowboy + Exqlite).
#          One node, scheduler concurrency — `--workers` is ignored.
#   `python` = Roundhouse-emit Python (single-process aiohttp, stdlib
#          sqlite3). Async event loop — `--workers` is ignored.
#
#   `rails`     = Rails reference (Puma + YJIT, production env)
#   `rails-int` = Rails reference (Puma, YJIT disabled, baseline)
#   `ruby`      = Roundhouse-emit Ruby (Puma + YJIT)
#   `ruby-int`  = Roundhouse-emit Ruby (Puma, YJIT disabled, baseline)
#
# Options:
#   --workers N         Puma WEB_CONCURRENCY for Ruby targets (default 1)
#                       Pass repeatedly to sweep: --workers 1 --workers 4
#   --threads N         RAILS_MAX_THREADS per worker (default 5)
#   --duration SEC      Measurement window (default 20)
#   --warmup SEC        Warmup before each measurement (default 20)
#   --connections N     wrk concurrency (default 64)
#   --wrk-threads N     wrk client threads (default 2)
#   --runs N            Repeated measurement runs per cell (default 3)
#   --endpoint PATH     URL path to bench (repeatable)
#                       Default: /articles /articles/1 /articles/new
#                                /articles.json /articles/1.json
#                       (JSON endpoints exercise the jbuilder lowerer
#                       end-to-end; every currently-supported bench
#                       target handles `.json` suffix routing —
#                       rails/rails-int via respond_to in the
#                       articles_controller fixture, ruby/ruby-int via
#                       the ruby_overlay main.rb's .json strip,
#                       crystal/typescript/spinel/go/rust via each
#                       target's server-side .json suffix handling.)
#   --port N            Base port; targets get N, N+1, ... (default 9000)
#   --out DIR           Results dir (default bench/results)
#   --keep              Don't tear down servers / build trees on exit
#   --skip-emit         Reuse existing build trees
#
# Output:
#   bench/results/<timestamp>/per-run.json        # raw per-run data
#   bench/results/<timestamp>/summary.json        # median + computed metrics
#   bench/results/<timestamp>/summary.md          # rendered table
#
# Environment:
#   On Linux: assumes `cpupower frequency-set -g performance` was run
#   beforehand and SMT is set to your preference (script doesn't change
#   these). On macOS: no-op; numbers will be M-class baseline.

set -euo pipefail

# ── arg parsing ──────────────────────────────────────────────────────

# Preserve original invocation for env.json reproducibility metadata.
ORIG_ARGS=("$@")

TARGETS=()
WORKERS=()
THREADS=5
DURATION=20
WARMUP=20
CONNECTIONS=64
WRK_THREADS=2
RUNS=3
ENDPOINTS=()
BASE_PORT=9000
OUT_DIR=""
KEEP=0
SKIP_EMIT=0

while [[ $# -gt 0 ]]; do
    case "$1" in
        --workers)        WORKERS+=("$2"); shift 2 ;;
        --threads)        THREADS="$2"; shift 2 ;;
        --duration)       DURATION="$2"; shift 2 ;;
        --warmup)         WARMUP="$2"; shift 2 ;;
        --connections)    CONNECTIONS="$2"; shift 2 ;;
        --wrk-threads)    WRK_THREADS="$2"; shift 2 ;;
        --runs)           RUNS="$2"; shift 2 ;;
        --endpoint)       ENDPOINTS+=("$2"); shift 2 ;;
        --port)           BASE_PORT="$2"; shift 2 ;;
        --out)            OUT_DIR="$2"; shift 2 ;;
        --keep)           KEEP=1; shift ;;
        --skip-emit)      SKIP_EMIT=1; shift ;;
        -h|--help)        sed -n '2,/^$/p' "$0" | sed 's/^# \?//'; exit 0 ;;
        -*)               echo "unknown flag: $1" >&2; exit 2 ;;
        *)                TARGETS+=("$1"); shift ;;
    esac
done

# Defaults
[[ ${#TARGETS[@]} -eq 0 ]] && TARGETS=(rails ruby)
[[ ${#WORKERS[@]} -eq 0 ]] && WORKERS=(1)
if [[ ${#ENDPOINTS[@]} -eq 0 ]]; then
    ENDPOINTS=(/articles /articles/1 /articles/new)
    # JSON endpoints — exercise the jbuilder lowerer end-to-end.
    # Mirrors scripts/compare's per-target JSON path additions (case
    # branch at scripts/compare:132); all currently-supported bench
    # targets (rails, rails-int, ruby, ruby-int, typescript, crystal,
    # rust, spinel, go, elixir) strip the `.json` suffix before routing
    # and dispatch on `controller.request_format`. Add `--endpoint` to
    # override entirely; this default is the publication-grade mix.
    ENDPOINTS+=(/articles.json /articles/1.json)
fi

# Validate + normalize targets
NORMALIZED=()
for t in "${TARGETS[@]}"; do
    case "$t" in
        rails|rails-int|ruby|ruby-int|jruby|typescript|crystal|rust|spinel|go|elixir|python) NORMALIZED+=("$t") ;;
        jr) NORMALIZED+=(jruby) ;;
        ts) NORMALIZED+=(typescript) ;;
        cr) NORMALIZED+=(crystal) ;;
        rs) NORMALIZED+=(rust) ;;
        sp) NORMALIZED+=(spinel) ;;
        ex) NORMALIZED+=(elixir) ;;
        py) NORMALIZED+=(python) ;;
        *) echo "target not yet supported in this initial cut: $t" >&2
           echo "supported: rails rails-int ruby ruby-int jruby typescript crystal rust spinel go elixir python" >&2; exit 2 ;;
    esac
done
TARGETS=("${NORMALIZED[@]}")

# ── paths ────────────────────────────────────────────────────────────

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
FIXTURE="$REPO_ROOT/fixtures/real-blog"
RUBY_OUT="$REPO_ROOT/build/transpiled-blog-ruby"
# JRuby target — byte-identical emit to the ruby tree but the JDBC db
# backend (runtime/db.rb = db_jruby.rb) and a JRuby-resolved bundle.
# `bin/rh transpile jruby` writes here; matches scripts/compare's
# BUILD_DIR for the jruby target.
JRUBY_OUT="$REPO_ROOT/build/transpiled-blog-jruby"
# scripts/compare's typescript path — emit_preview always writes here,
# so we reuse it to share the npm-install cache across compare runs.
TS_OUT="/tmp/rh-ts-pass2"
# Crystal target — same scratch-dir convention as scripts/compare.
CR_OUT="/tmp/rh-cr-pass2"
# Rust target — same scratch-dir convention as scripts/compare.
RS_OUT="/tmp/rh-rs-pass2"
# Spinel target — uses `bin/rh transpile spinel`, which writes here
# (matches scripts/compare's BUILD_DIR for the spinel target).
SP_OUT="$REPO_ROOT/build/transpiled-blog-spinel"
# Go target — `bin/rh transpile go` writes here. v2 binary lives at
# `cmd/v2/main.go`; staged DB at `storage/development.sqlite3` (the
# default path `runtime/go/v2/server.go` looks for when DATABASE_PATH
# is unset).
GO_OUT="$REPO_ROOT/build/transpiled-blog-go"
# Elixir target — emit_preview writes here (matches scripts/compare's
# BUILD_DIR for the elixir target). `Server.start` opens the staged DB at
# `storage/development.sqlite3` relative to this dir.
EX_OUT="/tmp/rh-ex-pass2"
# Python target — emit_preview writes here (matches scripts/compare's
# BUILD_DIR for the python target). aiohttp server lives in a uv-managed
# venv; `python3 -m app` boots `Server.start`, which opens the staged DB
# at `storage/development.sqlite3` relative to this dir.
PY_OUT="/tmp/rh-py-pass2"
TIMESTAMP="$(date +%Y%m%d-%H%M%S)"
[[ -z "$OUT_DIR" ]] && OUT_DIR="$REPO_ROOT/bench/results/$TIMESTAMP"
mkdir -p "$OUT_DIR"

# Snapshot the machine + harness invocation into env.json. Opportunistic
# capture; runs even if some toolchains/probes aren't available.
"$REPO_ROOT/scripts/bench-env" \
    --workers     "${WORKERS[*]}" \
    --concurrency "$CONNECTIONS" \
    --runs        "$RUNS" \
    --duration    "$DURATION" \
    --warmup      "$WARMUP" \
    --threads     "$THREADS" \
    --wrk-threads "$WRK_THREADS" \
    --endpoints   "${ENDPOINTS[*]}" \
    --targets     "${TARGETS[*]}" \
    --command     "scripts/bench ${ORIG_ARGS[*]}" \
    > "$OUT_DIR/env.json" || true

LOG_DIR="$(mktemp -d -t rh-bench-logs.XXXXXX)"

# ── helpers ──────────────────────────────────────────────────────────

step() { printf '\033[36m→\033[0m %s\n' "$*"; }
ok()   { printf '\033[32m✓\033[0m %s\n' "$*"; }
fail() { printf '\033[31m✗\033[0m %s\n' "$*" >&2; }

wait_for_port() {
    local url="$1"
    local label="$2"
    # Optional readiness budget (seconds); defaults to 30. JRuby needs a
    # larger one — JVM boot + JRuby startup is slower than an MRI boot.
    local budget="${3:-30}"
    local deadline=$(( $(date +%s) + budget ))
    while (( $(date +%s) < deadline )); do
        if curl --silent --fail --output /dev/null "$url" 2>/dev/null; then
            return 0
        fi
        sleep 0.3
    done
    fail "$label did not come up within ${budget}s ($url)"
    return 1
}

# Recursive kill — kills children before parent so Puma workers get hit
# before the master signals them.
kill_tree() {
    local pid="$1"
    [[ -z "$pid" ]] && return 0
    local children
    children="$(pgrep -P "$pid" 2>/dev/null || true)"
    for child in $children; do
        kill_tree "$child"
    done
    kill -TERM "$pid" 2>/dev/null || true
    # Give a beat, then force-kill if it didn't die
    sleep 0.2
    kill -KILL "$pid" 2>/dev/null || true
}

# Sum RSS (in KB) across a PID and all its descendants. macOS and Linux
# both have `ps -o rss=` that returns KB. Reads /proc on Linux too as
# a cross-check but ps suffices for both.
sum_rss_kb() {
    local pid="$1"
    [[ -z "$pid" ]] && { echo 0; return; }
    # Gather PID + descendants
    local pids="$pid"
    local stack="$pid"
    while [[ -n "$stack" ]]; do
        local next=""
        for p in $stack; do
            local kids
            kids="$(pgrep -P "$p" 2>/dev/null || true)"
            for k in $kids; do
                pids="$pids $k"
                next="$next $k"
            done
        done
        stack="$next"
    done
    local total=0
    for p in $pids; do
        local r
        r="$(ps -o rss= -p "$p" 2>/dev/null | tr -d ' ' || echo 0)"
        [[ -z "$r" ]] && r=0
        total=$(( total + r ))
    done
    echo "$total"
}

# Parse wrk's stdout for Requests/sec and Latency percentiles.
# wrk's --latency flag enables percentile output. Output is fixed-shape
# enough that awk pulls it out reliably.
parse_wrk() {
    local out="$1"
    local req_sec p50 p99
    req_sec="$(grep -E '^Requests/sec:' "$out" | awk '{print $2}')"
    # Latency Distribution block lines look like:
    #     50%    1.23ms
    #     99%   12.5ms
    p50="$(awk '/Latency Distribution/{flag=1; next} flag && /^[[:space:]]*50%/{print $2; exit}' "$out")"
    p99="$(awk '/Latency Distribution/{flag=1; next} flag && /^[[:space:]]*99%/{print $2; exit}' "$out")"
    # Strip 'ms'/'us'/'s' suffix and normalize to ms. Use awk for the
    # regex split — bash glob `[a-z]*` matches only one char per the
    # shortest-match `%` operator, so "776.00us" yields num="776.00u".
    # awk's gsub on /[a-z]+$/ handles the full suffix cleanly.
    normalize_latency() {
        local v="$1"
        [[ -z "$v" ]] && { echo "null"; return; }
        awk -v v="$v" 'BEGIN {
            n = v; gsub(/[a-zA-Z]+$/, "", n)
            u = v; sub(/^[0-9.]+/, "", u)
            if (u == "us") printf "%.3f", n/1000
            else if (u == "ms") printf "%.3f", n+0
            else if (u == "s")  printf "%.3f", n*1000
            else printf "null"
        }'
    }
    p50="$(normalize_latency "$p50")"
    p99="$(normalize_latency "$p99")"
    [[ -z "$req_sec" ]] && req_sec="null"
    echo "{\"req_sec\":$req_sec,\"p50_ms\":$p50,\"p99_ms\":$p99}"
}

# ── target lifecycle ─────────────────────────────────────────────────

TARGET_PID=""
TARGET_BUILD_DIR=""
TARGET_GEMFILE=""

cleanup() {
    local code=$?
    if (( KEEP == 0 )); then
        kill_tree "$TARGET_PID"
        sleep 0.3
        wait 2>/dev/null || true
    else
        if [[ -n "$TARGET_PID" ]]; then
            echo
            step "--keep: server PID=$TARGET_PID still running"
        fi
    fi
    exit "$code"
}
trap cleanup EXIT INT TERM

build_target() {
    local target="$1"
    case "$target" in
        rails|rails-int)
            TARGET_BUILD_DIR="$FIXTURE"
            TARGET_GEMFILE=""  # uses fixture's own Gemfile
            if [[ ! -f "$FIXTURE/storage/development.sqlite3" ]]; then
                step "regenerating fixtures/real-blog"
                (cd "$REPO_ROOT" && bin/rh fixture >/dev/null) || return 1
            fi
            ;;
        ruby|ruby-int)
            TARGET_BUILD_DIR="$RUBY_OUT"
            TARGET_GEMFILE="$REPO_ROOT/runtime/spinel/scaffold/Gemfile"
            if (( SKIP_EMIT == 0 )) || [[ ! -d "$RUBY_OUT" ]]; then
                step "regenerating ruby target (bin/rh transpile ruby)"
                (cd "$REPO_ROOT" && bin/rh transpile ruby >/dev/null) || return 1
            fi
            # Assets — Tailwind compile + JS deps. Needed for full
            # response bytes; without it the index page is naked.
            if [[ ! -f "$RUBY_OUT/static/assets/tailwind.css" ]]; then
                step "building ruby assets"
                (cd "$RUBY_OUT" && BUNDLE_GEMFILE="$TARGET_GEMFILE" bundle exec rake assets >/dev/null) || return 1
            fi
            ;;
        jruby)
            TARGET_BUILD_DIR="$JRUBY_OUT"
            # The transpiled tree's own Gemfile — its Gemfile.lock and
            # vendored gems live in $JRUBY_OUT, isolated from the CRuby
            # ruby tree's bundle (they resolve different platform gems).
            TARGET_GEMFILE="$JRUBY_OUT/Gemfile"
            if (( SKIP_EMIT == 0 )) || [[ ! -d "$JRUBY_OUT" ]]; then
                step "regenerating jruby target (bin/rh transpile jruby)"
                (cd "$REPO_ROOT" && bin/rh transpile jruby >/dev/null) || return 1
            fi
            # JRuby resolves the jdbc-sqlite3 driver (and JRuby builds of
            # puma/rack/etc.) into this tree. Slow under the JVM, so only
            # run when the emit is fresh or the lock is missing.
            if (( SKIP_EMIT == 0 )) || [[ ! -f "$JRUBY_OUT/Gemfile.lock" ]]; then
                step "installing jruby bundle"
                (cd "$JRUBY_OUT" && BUNDLE_GEMFILE="$TARGET_GEMFILE" jruby -S bundle install >/dev/null) || return 1
            fi
            # Assets — Tailwind + JS deps. The output is byte-identical to
            # the ruby tree, so reuse those when present (avoids a second
            # asset build under the JVM); otherwise build under JRuby.
            if [[ ! -f "$JRUBY_OUT/static/assets/tailwind.css" ]]; then
                if [[ -f "$RUBY_OUT/static/assets/tailwind.css" ]]; then
                    step "copying ruby assets into jruby tree"
                    mkdir -p "$JRUBY_OUT/static"
                    cp -R "$RUBY_OUT/static/assets" "$JRUBY_OUT/static/assets"
                else
                    step "building jruby assets"
                    (cd "$JRUBY_OUT" && BUNDLE_GEMFILE="$TARGET_GEMFILE" jruby -S bundle exec rake assets >/dev/null) || return 1
                fi
            fi
            ;;
        typescript)
            TARGET_BUILD_DIR="$TS_OUT"
            TARGET_GEMFILE=""
            if (( SKIP_EMIT == 0 )) || [[ ! -f "$TS_OUT/main.ts" ]]; then
                step "regenerating typescript target (emit_preview)"
                (cd "$REPO_ROOT" && cargo run --quiet --bin emit_preview -- --target typescript "$FIXTURE" >/dev/null 2>&1) || return 1
            fi
            if [[ ! -d "$TS_OUT/node_modules" ]]; then
                step "installing npm deps"
                (cd "$TS_OUT" && npm install --silent --no-audit --no-fund) || return 1
            fi
            ;;
        crystal)
            TARGET_BUILD_DIR="$CR_OUT"
            TARGET_GEMFILE=""
            if (( SKIP_EMIT == 0 )) || [[ ! -f "$CR_OUT/src/main.cr" ]]; then
                step "regenerating crystal target (emit_preview)"
                (cd "$REPO_ROOT" && cargo run --quiet --bin emit_preview -- --target crystal "$FIXTURE" >/dev/null 2>&1) || return 1
            fi
            if [[ ! -x "$CR_OUT/.bin/server" ]]; then
                step "building crystal target (release)"
                (cd "$CR_OUT" && mkdir -p .bin && shards install --quiet && crystal build --release --no-debug src/main.cr -o .bin/server) || return 1
            fi
            ;;
        rust)
            TARGET_BUILD_DIR="$RS_OUT"
            TARGET_GEMFILE=""
            if (( SKIP_EMIT == 0 )) || [[ ! -f "$RS_OUT/Cargo.toml" ]]; then
                step "regenerating rust target (emit_preview)"
                (cd "$REPO_ROOT" && cargo run --quiet --bin emit_preview -- --target rust "$FIXTURE" >/dev/null 2>&1) || return 1
            fi
            if [[ ! -x "$RS_OUT/target/release/app" ]]; then
                step "building rust target (release)"
                (cd "$RS_OUT" && cargo build --release --quiet) || return 1
            fi
            ;;
        spinel)
            # `bin/rh transpile spinel` writes to $SP_OUT and additionally
            # vendors Tep transport (sphttp.c) + per-target Makefile;
            # `make assets` builds Tailwind + turbo.min.js; `make build`
            # AOT-compiles main.rb to ./build/blog via the `spinel`
            # binary (needs to be on PATH, e.g. ~/git/spinel).
            TARGET_BUILD_DIR="$SP_OUT"
            TARGET_GEMFILE="$REPO_ROOT/runtime/spinel/scaffold/Gemfile"
            if (( SKIP_EMIT == 0 )) || [[ ! -f "$SP_OUT/main.rb" ]]; then
                step "regenerating spinel target (bin/rh transpile spinel)"
                (cd "$REPO_ROOT" && bin/rh transpile spinel >/dev/null) || return 1
            fi
            if [[ ! -f "$SP_OUT/static/assets/tailwind.css" ]]; then
                step "building spinel assets (tailwind + turbo.min.js)"
                (cd "$SP_OUT" && BUNDLE_GEMFILE="$TARGET_GEMFILE" make assets >/dev/null) || return 1
            fi
            # Recompile whenever we re-emitted (SKIP_EMIT==0) — the spinel
            # COMPILER may have changed under us (git pull && make), and
            # `make`'s mtime check alone can miss that, so force a clean
            # build. Skipping a stale build/blog here silently re-ran an
            # old binary across compiler updates.
            if (( SKIP_EMIT == 0 )) || [[ ! -x "$SP_OUT/build/blog" ]]; then
                step "AOT-compiling main.rb → build/blog (spinel)"
                (cd "$SP_OUT" && rm -f build/blog && make build >/dev/null) || return 1
            fi
            ;;
        go)
            # `bin/rh transpile go` writes to $GO_OUT; build the v2
            # binary from cmd/v2/ (the legacy root main.go is a thin
            # forward but cmd/v2 is the canonical entry point). Single
            # binary, no per-target asset or gem dependencies.
            TARGET_BUILD_DIR="$GO_OUT"
            TARGET_GEMFILE=""
            if (( SKIP_EMIT == 0 )) || [[ ! -f "$GO_OUT/go.mod" ]]; then
                step "regenerating go target (bin/rh transpile go)"
                (cd "$REPO_ROOT" && bin/rh transpile go >/dev/null) || return 1
            fi
            if [[ ! -x "$GO_OUT/.bin/server" ]]; then
                step "building go target (cmd/v2/, release shape)"
                (cd "$GO_OUT" && go mod tidy && mkdir -p .bin && go build -o .bin/server ./cmd/v2/) || return 1
            fi
            ;;
        elixir)
            # `emit_preview --target elixir` writes the lowered-IR Elixir
            # app to $EX_OUT; `mix compile` builds it. The shared
            # `Roundhouse.Db` connection opens the staged DB (see stage_db).
            TARGET_BUILD_DIR="$EX_OUT"
            TARGET_GEMFILE=""
            if (( SKIP_EMIT == 0 )) || [[ ! -f "$EX_OUT/mix.exs" ]]; then
                step "regenerating elixir target (emit_preview)"
                (cd "$REPO_ROOT" && cargo run --quiet --bin emit_preview -- --target elixir "$FIXTURE" >/dev/null 2>&1) || return 1
            fi
            step "building elixir target (mix compile)"
            (cd "$EX_OUT" && mix deps.get >/dev/null 2>&1 && MIX_ENV=prod mix compile >/dev/null) || return 1
            ;;
        python)
            # `emit_preview --target python` writes the lowered-IR Python
            # app to $PY_OUT; aiohttp lives in a uv-managed venv declared by
            # the emitted pyproject.toml. Wipe pycache so emitter changes
            # aren't masked by stale bytecode, sync the venv, and validate
            # imports so a startup failure surfaces here, not as HTTP diffs.
            # Mirrors scripts/compare's python branch.
            TARGET_BUILD_DIR="$PY_OUT"
            TARGET_GEMFILE=""
            if (( SKIP_EMIT == 0 )) || [[ ! -f "$PY_OUT/pyproject.toml" ]]; then
                step "regenerating python target (emit_preview)"
                (cd "$REPO_ROOT" && cargo run --quiet --bin emit_preview -- --target python "$FIXTURE" >/dev/null 2>&1) || return 1
            fi
            step "syncing python venv (uv) + validating imports"
            (cd "$PY_OUT" && find . -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null; uv sync --quiet && uv run python3 -c "import app, app.server, app.routes") || return 1
            ;;
    esac
}

# Stage the seeded DB. Each target gets its own copy so writes don't
# bleed across runs. Note: bench is read-only by default, so the seed
# isn't reapplied between measurement windows.
stage_db() {
    local target="$1"
    case "$target" in
        rails|rails-int)
            # Production Rails reads storage/production.sqlite3 — clone
            # the seeded dev DB into place so the fixture serves real
            # rows. SQLite3's `.backup` produces a clean copy without
            # WAL/SHM artifacts.
            local prod="$FIXTURE/storage/production.sqlite3"
            local dev="$FIXTURE/storage/development.sqlite3"
            rm -f "$prod" "$prod-wal" "$prod-shm"
            sqlite3 "$dev" ".backup $prod"
            ;;
        ruby|ruby-int)
            local db="$RUBY_OUT/tmp/blog.sqlite3"
            mkdir -p "$(dirname "$db")"
            rm -f "$db" "$db-wal" "$db-shm"
            sqlite3 "$FIXTURE/storage/development.sqlite3" ".backup $db"
            ;;
        jruby)
            local db="$JRUBY_OUT/tmp/blog.sqlite3"
            mkdir -p "$(dirname "$db")"
            rm -f "$db" "$db-wal" "$db-shm"
            sqlite3 "$FIXTURE/storage/development.sqlite3" ".backup $db"
            ;;
        typescript)
            local db="$TS_OUT/db/development.sqlite3"
            mkdir -p "$(dirname "$db")"
            rm -f "$db" "$db-wal" "$db-shm"
            sqlite3 "$FIXTURE/storage/development.sqlite3" ".backup $db"
            ;;
        crystal)
            local db="$CR_OUT/db/development.sqlite3"
            mkdir -p "$(dirname "$db")"
            rm -f "$db" "$db-wal" "$db-shm"
            sqlite3 "$FIXTURE/storage/development.sqlite3" ".backup $db"
            ;;
        rust)
            local db="$RS_OUT/storage/development.sqlite3"
            mkdir -p "$(dirname "$db")"
            rm -f "$db" "$db-wal" "$db-shm"
            sqlite3 "$FIXTURE/storage/development.sqlite3" ".backup $db"
            ;;
        spinel)
            local db="$SP_OUT/tmp/blog.sqlite3"
            mkdir -p "$(dirname "$db")"
            rm -f "$db" "$db-wal" "$db-shm"
            sqlite3 "$FIXTURE/storage/development.sqlite3" ".backup $db"
            ;;
        go)
            # Default path the v2 server.go reads when DATABASE_PATH is
            # unset; mirrors scripts/compare's go DB_DEST.
            local db="$GO_OUT/storage/development.sqlite3"
            mkdir -p "$(dirname "$db")"
            rm -f "$db" "$db-wal" "$db-shm"
            sqlite3 "$FIXTURE/storage/development.sqlite3" ".backup $db"
            ;;
        elixir)
            # Path `Server.start` opens (relative to $EX_OUT); mirrors
            # scripts/compare's elixir DB_DEST.
            local db="$EX_OUT/storage/development.sqlite3"
            mkdir -p "$(dirname "$db")"
            rm -f "$db" "$db-wal" "$db-shm"
            sqlite3 "$FIXTURE/storage/development.sqlite3" ".backup $db"
            ;;
        python)
            # Default path `server.start` opens (relative to $PY_OUT);
            # mirrors scripts/compare's python DB_DEST.
            local db="$PY_OUT/storage/development.sqlite3"
            mkdir -p "$(dirname "$db")"
            rm -f "$db" "$db-wal" "$db-shm"
            sqlite3 "$FIXTURE/storage/development.sqlite3" ".backup $db"
            ;;
    esac
}

start_target() {
    local target="$1"
    local port="$2"
    local workers="$3"
    local log="$LOG_DIR/${target}-${workers}w.log"

    case "$target" in
        rails)
            # `RAILS_LOG_LEVEL=${BENCH_RAILS_LOG_LEVEL:-info}` lets the
            # operator opt into a quieter Rails (warn) to isolate the
            # per-request log-write cost from the rest of the stack.
            # Default is `info` — the Rails 8 production-env default —
            # so the headline comparison reflects a stock Rails install.
            (cd "$FIXTURE" && \
                RAILS_ENV=production \
                RAILS_MAX_THREADS="$THREADS" \
                WEB_CONCURRENCY="$workers" \
                RAILS_LOG_LEVEL="${BENCH_RAILS_LOG_LEVEL:-info}" \
                SECRET_KEY_BASE=bench-secret-key \
                RUBYOPT=--yjit \
                bin/rails server -p "$port" -e production \
                >"$log" 2>&1) &
            TARGET_PID=$!
            disown 2>/dev/null || true
            ;;
        rails-int)
            # Same as `rails` minus RUBYOPT=--yjit — isolates the
            # YJIT-attributable share of the rails baseline.
            (cd "$FIXTURE" && \
                RAILS_ENV=production \
                RAILS_MAX_THREADS="$THREADS" \
                WEB_CONCURRENCY="$workers" \
                RAILS_LOG_LEVEL="${BENCH_RAILS_LOG_LEVEL:-info}" \
                SECRET_KEY_BASE=bench-secret-key \
                bin/rails server -p "$port" -e production \
                >"$log" 2>&1) &
            TARGET_PID=$!
            disown 2>/dev/null || true
            ;;
        ruby)
            (cd "$RUBY_OUT" && \
                BUNDLE_GEMFILE="$TARGET_GEMFILE" \
                BLOG_DB=tmp/blog.sqlite3 \
                RAILS_MAX_THREADS="$THREADS" \
                WEB_CONCURRENCY="$workers" \
                RAILS_ENV=production \
                PORT="$port" \
                RUBYOPT=--yjit \
                bundle exec puma -C config/puma.rb config.ru \
                >"$log" 2>&1) &
            TARGET_PID=$!
            disown 2>/dev/null || true
            ;;
        ruby-int)
            (cd "$RUBY_OUT" && \
                BUNDLE_GEMFILE="$TARGET_GEMFILE" \
                BLOG_DB=tmp/blog.sqlite3 \
                RAILS_MAX_THREADS="$THREADS" \
                WEB_CONCURRENCY="$workers" \
                RAILS_ENV=production \
                PORT="$port" \
                bundle exec puma -C config/puma.rb config.ru \
                >"$log" 2>&1) &
            TARGET_PID=$!
            disown 2>/dev/null || true
            ;;
        jruby)
            # JRuby on the JVM. Single-process, multi-threaded: Puma
            # cluster mode forks, which the JVM can't, so force
            # WEB_CONCURRENCY=0 (`workers` is ignored, the per-cell row
            # records workers=1) and lean on RAILS_MAX_THREADS — JRuby has
            # no GVL, so threads run truly parallel. No RUBYOPT=--yjit
            # (that's an MRI flag); JRuby's JIT warms during the harness's
            # warmup window. The RSS sampler walks the process tree, so the
            # JVM child is accounted for.
            #
            # Heap is pinned to 512 MB (-Xmx == -Xms) so the RSS column is a
            # deliberate budget, comparable to the other cells' working
            # sets. Uncapped, the JVM grabs ~25% of host RAM and its RSS
            # climbs with cumulative load across the sequential endpoint
            # measurements — a host-dependent artifact, not a footprint.
            (cd "$JRUBY_OUT" && \
                BUNDLE_GEMFILE="$JRUBY_OUT/Gemfile" \
                BLOG_DB=tmp/blog.sqlite3 \
                RAILS_MAX_THREADS="$THREADS" \
                WEB_CONCURRENCY=0 \
                RAILS_ENV=production \
                PORT="$port" \
                JRUBY_OPTS="-J-Xmx512m -J-Xms512m" \
                jruby -S bundle exec puma -C config/puma.rb config.ru \
                >"$log" 2>&1) &
            TARGET_PID=$!
            disown 2>/dev/null || true
            ;;
        typescript)
            # Single-process node (no worker / preload concept) —
            # `workers` is ignored and the per-cell row records workers=1.
            (cd "$TS_OUT" && \
                PORT="$port" \
                npm start \
                >"$log" 2>&1) &
            TARGET_PID=$!
            disown 2>/dev/null || true
            ;;
        crystal)
            # AOT-compiled binary — single-process, no workers concept.
            (cd "$CR_OUT" && \
                PORT="$port" \
                ./.bin/server \
                >"$log" 2>&1) &
            TARGET_PID=$!
            disown 2>/dev/null || true
            ;;
        rust)
            # AOT-compiled binary — single-process, no workers concept.
            (cd "$RS_OUT" && \
                PORT="$port" \
                ./target/release/app \
                >"$log" 2>&1) &
            TARGET_PID=$!
            disown 2>/dev/null || true
            ;;
        spinel)
            # AOT-compiled native binary (Spinel codegen) — single-process,
            # Tep::Server FFI HTTP/1.1, no workers concept. `workers` is
            # ignored and the per-cell row records workers=1.
            # Size the connection pool to the wrk concurrency: the
            # fiber-per-connection server serves up to `c` requests at
            # once, so a smaller pool would make fibers park on a handle.
            # Same DATABASE_POOL_SIZE knob the rust target reads.
            (cd "$SP_OUT" && \
                BLOG_DB=tmp/blog.sqlite3 \
                PORT="$port" \
                DATABASE_POOL_SIZE="$CONNECTIONS" \
                ./build/blog \
                >"$log" 2>&1) &
            TARGET_PID=$!
            disown 2>/dev/null || true
            ;;
        go)
            # AOT-compiled binary — single-process, net/http server,
            # no workers concept. `workers` ignored; per-cell row
            # records workers=1. Deliberately does NOT pass
            # DATABASE_POOL_SIZE=$CONNECTIONS the way rust/spinel do:
            # the Go target is backed by pure-Go modernc sqlite, whose
            # internal locking collapses under a wrk-concurrency-sized
            # pool (measured: pool=64 → ~half the throughput of pool=4).
            # The runtime defaults the pool to runtime.NumCPU(), which
            # sits on modernc's throughput plateau.
            (cd "$GO_OUT" && \
                PORT="$port" \
                ./.bin/server \
                >"$log" 2>&1) &
            TARGET_PID=$!
            disown 2>/dev/null || true
            ;;
        elixir)
            # BEAM VM — one node, scheduler-level concurrency. No worker
            # processes: `workers` is ignored and per-cell rows record
            # workers=1 (like go). `Main.run` boots Plug.Cowboy via
            # `Server.start`, which opens the staged DB and blocks.
            (cd "$EX_OUT" && \
                PORT="$port" \
                MIX_ENV=prod \
                mix run --no-halt -e 'Main.run' \
                >"$log" 2>&1) &
            TARGET_PID=$!
            disown 2>/dev/null || true
            ;;
        python)
            # Single-process aiohttp (async event loop) — no worker /
            # preload concept, so `workers` is ignored and the per-cell row
            # records workers=1 (like node/go/elixir). `python3 -m app`
            # boots `server.start`, which opens the staged DB and blocks.
            # The RSS sampler + teardown walk the process tree, so the
            # `uv run` → python child is accounted for.
            (cd "$PY_OUT" && \
                PORT="$port" \
                uv run python3 -m app \
                >"$log" 2>&1) &
            TARGET_PID=$!
            disown 2>/dev/null || true
            ;;
    esac
    # JRuby boots the JVM before serving — give it a larger readiness
    # budget than the 30s default the other targets use.
    local ready_budget=30
    [[ "$target" == jruby ]] && ready_budget=90
    wait_for_port "http://localhost:$port/articles" "$target" "$ready_budget" || {
        echo "--- $target log ---" >&2
        tail -40 "$log" >&2
        kill_tree "$TARGET_PID"
        TARGET_PID=""
        return 1
    }
}

# ── measurement ──────────────────────────────────────────────────────

# RSS sampler: poll every 1s while wrk runs, write samples to a file.
# Caller starts it in the background, kills when wrk exits.
rss_sampler() {
    local pid="$1"
    local out="$2"
    : > "$out"
    while kill -0 "$pid" 2>/dev/null; do
        sum_rss_kb "$pid" >> "$out"
        sleep 1
    done
}

# Median of a list of integers (one per line). Used for RSS samples
# to get steady-state memory (peak is too noisy on macOS).
median() {
    sort -n | awk '
        { a[NR] = $1 }
        END {
            n = NR
            if (n == 0) { print 0; exit }
            if (n % 2 == 1) print a[(n+1)/2]
            else print int((a[n/2] + a[n/2+1]) / 2)
        }
    '
}

# Run one measurement (warmup + DURATION-second wrk). Captures req/sec,
# p50, p99, and a steady-state RSS sample. Emits a single-line JSON
# record on stdout.
measure_one() {
    local target="$1"
    local workers="$2"
    local port="$3"
    local endpoint="$4"
    local run_n="$5"

    local url="http://localhost:$port$endpoint"

    # Warmup wrk run — discarded
    wrk -t"$WRK_THREADS" -c"$CONNECTIONS" -d"${WARMUP}s" "$url" \
        >/dev/null 2>&1 || true

    # Measurement window — RSS sampler in parallel
    local wrk_out="$LOG_DIR/wrk-${target}-${workers}w-${run_n}.txt"
    local rss_out="$LOG_DIR/rss-${target}-${workers}w-${run_n}.txt"
    rss_sampler "$TARGET_PID" "$rss_out" &
    local rss_pid=$!
    wrk -t"$WRK_THREADS" -c"$CONNECTIONS" -d"${DURATION}s" --latency \
        "$url" >"$wrk_out" 2>&1 || true
    kill "$rss_pid" 2>/dev/null || true
    wait "$rss_pid" 2>/dev/null || true

    local wrk_json
    wrk_json="$(parse_wrk "$wrk_out")"
    local rss_median_kb
    rss_median_kb="$(median < "$rss_out")"
    [[ -z "$rss_median_kb" || "$rss_median_kb" == "0" ]] && rss_median_kb=0

    # Emit one JSON record
    cat <<EOF
{"target":"$target","workers":$workers,"endpoint":"$endpoint","run":$run_n,"rss_kb":$rss_median_kb,$(echo "$wrk_json" | sed 's/^{//;s/}$//')}
EOF
}

# ── main loop ────────────────────────────────────────────────────────

PER_RUN_JSON="$OUT_DIR/per-run.json"
: > "$PER_RUN_JSON"

port="$BASE_PORT"
for target in "${TARGETS[@]}"; do
    step "build_target $target"
    # Build/compile failures (e.g. a spinel AOT-compile error) skip just
    # this target instead of aborting the whole run, so the remaining
    # languages still get measured. The `if !` context suppresses set -e
    # inside build_target — that's why each build step there ends in
    # `|| return 1`, so the first failure propagates here.
    if ! build_target "$target"; then
        fail "$target failed to build; skipping target"
        continue
    fi
    if ! stage_db "$target"; then
        fail "$target DB staging failed; skipping target"
        continue
    fi

    seen_cells=""
    for workers in "${WORKERS[@]}"; do
        # Ruby targets honor WEB_CONCURRENCY; other targets ignore it
        # (and we record the field as 1 for those).
        case "$target" in
            rails|rails-int|ruby|ruby-int) effective_workers="$workers" ;;
            *)                    effective_workers=1 ;;
        esac

        # Skip dupes — non-worker-honoring targets collapse all
        # `--workers N` iterations onto a single workers=1 cell.
        if [[ " $seen_cells " == *" $effective_workers "* ]]; then
            continue
        fi
        seen_cells="$seen_cells $effective_workers"

        step "start $target (workers=$effective_workers, port=$port)"
        start_target "$target" "$port" "$effective_workers" || {
            fail "$target failed to start; skipping cell"
            port=$(( port + 1 ))
            continue
        }
        ok "$target up on :$port"

        for endpoint in "${ENDPOINTS[@]}"; do
            for run in $(seq 1 "$RUNS"); do
                step "measure $target w=$effective_workers $endpoint run=$run/$RUNS"
                rec="$(measure_one "$target" "$effective_workers" "$port" "$endpoint" "$run")"
                echo "$rec" >> "$PER_RUN_JSON"
                printf '  '
                # Pretty-print the cell so the user sees progress
                echo "$rec" | awk -F'[,:]' '{
                    for(i=1;i<=NF;i++) {
                        gsub(/["{}]/, "", $i)
                        if($i=="req_sec") req=$(i+1)
                        if($i=="p99_ms") p99=$(i+1)
                        if($i=="rss_kb") rss=$(i+1)
                    }
                    gsub(/["{}]/, "", req); gsub(/["{}]/, "", p99); gsub(/["{}]/, "", rss)
                    printf "req/sec=%s  p99=%sms  rss=%dMB\n", req, p99, int(rss/1024)
                }'
                # Cooldown between runs to let thermals settle
                sleep 2
            done
        done

        kill_tree "$TARGET_PID"
        TARGET_PID=""
        sleep 0.5
        port=$(( port + 1 ))
    done
done

# ── aggregation ──────────────────────────────────────────────────────

step "aggregating $(wc -l < "$PER_RUN_JSON") runs → $OUT_DIR/summary.md"

# Aggregate via Ruby (always present on dev machines, and we ship Ruby
# targets so it's guaranteed available). Median across runs per
# (target, workers, endpoint) cell. Compute req/sec/GB.
ruby - "$PER_RUN_JSON" "$OUT_DIR/summary.json" "$OUT_DIR/summary.md" <<'RUBY'
require "json"

per_run_path, summary_json_path, summary_md_path = ARGV

records = File.readlines(per_run_path, chomp: true).reject(&:empty?).map { |l| JSON.parse(l) }

# Group by (target, workers, endpoint), median across runs
def median(xs)
  xs = xs.compact.sort
  return nil if xs.empty?
  n = xs.size
  n.odd? ? xs[n / 2] : ((xs[n / 2 - 1] + xs[n / 2]) / 2.0)
end

cells = records.group_by { |r| [r["target"], r["workers"], r["endpoint"]] }.map do |(target, workers, endpoint), runs|
  req_sec = median(runs.map { |r| r["req_sec"] })
  p50     = median(runs.map { |r| r["p50_ms"] })
  p99     = median(runs.map { |r| r["p99_ms"] })
  rss_kb  = median(runs.map { |r| r["rss_kb"] })
  rss_gb  = rss_kb ? rss_kb / 1024.0 / 1024.0 : nil
  rps_per_gb = (req_sec && rss_gb && rss_gb > 0) ? req_sec / rss_gb : nil
  {
    target: target, workers: workers, endpoint: endpoint,
    runs: runs.size,
    req_sec: req_sec, p50_ms: p50, p99_ms: p99,
    rss_kb: rss_kb, rss_mb: rss_kb ? rss_kb / 1024.0 : nil,
    rps_per_gb: rps_per_gb,
  }
end

File.write(summary_json_path, JSON.pretty_generate(cells))

# Markdown table grouped by endpoint
by_endpoint = cells.group_by { |c| c[:endpoint] }
md = +""
md << "# Benchmark results\n\n"
md << "_#{records.size} measurements across #{cells.size} cells_\n\n"

by_endpoint.each do |endpoint, eg_cells|
  md << "## `#{endpoint}`\n\n"
  md << "| target | workers | req/sec | p50 (ms) | p99 (ms) | RSS (MB) | req/sec/GB |\n"
  md << "|--------|--------:|--------:|---------:|---------:|---------:|-----------:|\n"
  eg_cells.sort_by { |c| [c[:target], c[:workers]] }.each do |c|
    md << "| %s | %d | %.0f | %.2f | %.2f | %.0f | %.0f |\n" % [
      c[:target], c[:workers],
      c[:req_sec] || 0, c[:p50_ms] || 0, c[:p99_ms] || 0,
      c[:rss_mb] || 0, c[:rps_per_gb] || 0,
    ]
  end
  md << "\n"
end

File.write(summary_md_path, md)
RUBY

ok "summary written to $OUT_DIR/summary.md"

# Atomically repoint bench/results/latest at this run. Symlink because
# POSIX doesn't permit hard-linking directories. -n keeps `ln -f` from
# dereferencing the existing symlink and creating a nested link inside.
if [[ "$OUT_DIR" == "$REPO_ROOT/bench/results/"* ]]; then
    ln -sfn "$(basename "$OUT_DIR")" "$REPO_ROOT/bench/results/latest"
    ok "bench/results/latest → $(basename "$OUT_DIR")"
fi

echo
cat "$OUT_DIR/summary.md"
