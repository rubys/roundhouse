#!/usr/bin/env ruby
# frozen_string_literal: true

# rh — Roundhouse workflow runner. Subcommand-shaped CLI in front of
# the per-target dev loops. Lives outside the Rust crate so Ruby is
# the only prerequisite for the no-Rust onboarding paths
# (`doctor`, `fetch`, `fixture`); Rust-dependent subcommands
# (added later) shell out to the `roundhouse` binary via `cargo run`.
#
# Why Ruby: the audience is Rails developers (Ruby guaranteed), and
# stdlib has everything needed — OptionParser, open-uri, Zlib,
# Gem::Package::TarReader. No gem dependencies. Cross-platform.

require 'optparse'
require 'fileutils'
require 'open3'
require 'shellwords'

ROUNDHOUSE_ROOT = File.expand_path('..', __dir__)
TARGETS = %w[spinel ruby crystal elixir go python rust typescript typescript-worker].freeze
SITE_BASE = 'https://rubys.github.io/roundhouse'

def main(argv)
  cmd = argv.shift
  case cmd
  when 'doctor'    then cmd_doctor(argv)
  when 'fetch'     then cmd_fetch(argv)
  when 'fixture'   then cmd_fixture(argv)
  when 'transpile' then cmd_transpile(argv)
  when 'dev'       then cmd_dev_test_run(argv, 'dev')
  when 'test'      then cmd_dev_test_run(argv, 'test')
  when 'run'       then cmd_dev_test_run(argv, 'run')
  when 'clean'     then cmd_clean(argv)
  when 'compare'   then cmd_compare(argv)
  when 'site'      then cmd_site(argv)
  when '-h', '--help', nil
    print_usage
    0
  when '-V', '--version'
    puts "rh #{rh_version}"
    0
  else
    warn "rh: unknown command '#{cmd}'"
    warn ''
    print_usage
    1
  end
end

def print_usage
  puts <<~USAGE
    Usage: bin/rh <command> [options]

    Roundhouse workflow runner.

    Onboarding (no Rust required):
      doctor              Check installed prerequisites; show which subcommands work today.
      fetch <target>      Download a pre-transpiled archive.
      fixture [path]      Generate a Rails source fixture via `rails new`.

    Build (requires Rust):
      transpile <target>  Build the source fixture into build/transpiled-blog-<target>/.
      dev <target>        Transpile, then start dev server (ruby only for now).
      test <target>       Transpile, then run target's native tests (ruby only for now).
      run <target>        Transpile, then run main (ruby only for now).
      compare [<target>]  End-to-end Rails-vs-target HTTP compare (wraps scripts/compare).
      site                Build the full GitHub Pages site (all targets).

    Cleanup:
      clean <target>      rm -rf build/transpiled-blog-<target>/
      clean fixture       rm -rf fixtures/real-blog/

    Pass `--help` to any subcommand for its options.

    Targets: #{TARGETS.join(', ')}
  USAGE
end

def build_dir(target)
  File.join(ROUNDHOUSE_ROOT, 'build', "transpiled-blog-#{target}")
end

def fixture_path
  File.join(ROUNDHOUSE_ROOT, 'fixtures', 'real-blog')
end

def need_cargo!
  return if version_of(probe('cargo', '--version'))
  warn 'rh: cargo not installed (required for transpile/site).'
  warn '  Install: https://rustup.rs'
  warn '  (or run `bin/rh doctor` to see all prerequisites)'
  exit 1
end

def need_fixture!
  return if File.directory?(fixture_path)
  warn "rh: fixture not found at #{fixture_path}"
  warn '  Generate: bin/rh fixture'
  exit 1
end

def validate_target!(target, allow_blog: false)
  valid = allow_blog ? TARGETS + ['blog'] : TARGETS
  return if valid.include?(target)
  warn "rh: unknown target '#{target.inspect}'"
  warn "  valid: #{valid.join(', ')}"
  exit 1
end

def rh_version
  cargo = File.join(ROUNDHOUSE_ROOT, 'Cargo.toml')
  return 'unknown' unless File.exist?(cargo)
  File.foreach(cargo) do |line|
    return Regexp.last_match(1) if line =~ /^version\s*=\s*"([^"]+)"/
  end
  'unknown'
end

# ---------------------------------------------------------------------
# Tool probes — Open3 + version regex. Returns the parsed version
# string, or nil if the command isn't on PATH or fails.

def probe(*cmd)
  out, err, status = Open3.capture3(*cmd)
  status.success? ? "#{out}#{err}".strip : nil
rescue Errno::ENOENT, Errno::EACCES
  nil
end

def version_of(output, re = /(\d+\.\d+(?:\.\d+)?)/)
  return nil unless output
  m = re.match(output)
  m ? m[1] : nil
end

# ---------------------------------------------------------------------
# Subcommand: doctor

DOCTOR_CHECKS = [
  { key: :ruby,   label: 'Ruby',      unlocks: 'always (rh itself)',     min: '3.4' },
  { key: :rust,   label: 'Rust',      unlocks: 'transpile, site, compare' },
  { key: :node,   label: 'Node',      unlocks: 'typescript target' },
  { key: :sqlite, label: 'SQLite',    unlocks: 'ruby/spinel/rust targets' },
  { key: :rails,  label: 'Rails gem', unlocks: 'fixture' },
].freeze

def cmd_doctor(argv)
  OptionParser.new do |o|
    o.banner = 'Usage: bin/rh doctor'
    o.separator ''
    o.separator 'Check installed prerequisites; show which subcommands work today.'
  end.parse!(argv)

  versions = {
    ruby:   RUBY_VERSION,
    rust:   version_of(probe('cargo', '--version')),
    node:   version_of(probe('node', '--version')),
    sqlite: version_of(probe('sqlite3', '--version')),
    rails:  version_of(probe('rails', '--version')),
  }

  puts 'Roundhouse environment check:'
  puts ''
  DOCTOR_CHECKS.each do |c|
    v = versions[c[:key]]
    mark = v ? "\u2713" : "\u2717"
    val = v ? v.ljust(10) : 'not found'.ljust(10)
    puts "  #{c[:label].ljust(10)} #{mark} #{val}  #{c[:unlocks]}"
  end

  puts ''
  available = ['doctor', 'fetch <target>', 'clean <target | fixture>']
  available << 'fixture' if versions[:rails]
  if versions[:rust]
    available << 'transpile <target>'
    available << 'site'
  end
  available << 'compare [<target>]' if versions[:rust] && versions[:rails]
  if versions[:rust] && versions[:rails]
    available << 'dev | test | run ruby'
  end
  puts 'Available now:'
  available.each { |s| puts "  bin/rh #{s}" }

  missing = DOCTOR_CHECKS.reject { |c| c[:key] == :ruby || versions[c[:key]] }
  unless missing.empty?
    puts ''
    puts 'Install to unlock more:'
    missing.each do |c|
      hint = install_hint(c[:key])
      puts "  #{c[:label].ljust(10)} \u2192 #{c[:unlocks]}#{hint ? "  (#{hint})" : ''}"
    end
  end

  0
end

def install_hint(key)
  case key
  when :rust   then 'https://rustup.rs'
  when :node   then 'https://nodejs.org or `brew install node`'
  when :sqlite then 'macOS: preinstalled; Debian/Ubuntu: apt install libsqlite3-dev'
  when :rails  then 'gem install rails'
  end
end

# ---------------------------------------------------------------------
# Subcommand: fetch
#
# Download a pre-transpiled archive from rubys.github.io/roundhouse/
# and explode it into ./downloads/<target>/. Pure Ruby stdlib —
# open-uri (follows redirects, handles HTTPS), Zlib::GzipReader,
# Gem::Package::TarReader. No curl/wget/tar shell dep.

def cmd_fetch(argv)
  dest_root = File.join(ROUNDHOUSE_ROOT, 'downloads')
  parser = OptionParser.new do |o|
    o.banner = 'Usage: bin/rh fetch <target> [--out DIR]'
    o.separator ''
    o.separator "Download #{SITE_BASE}/browse/<target>.tgz and extract it."
    o.separator "Default output: ./downloads/<target>/"
    o.separator ''
    o.separator "Targets: #{TARGETS.join(', ')}"
    o.on('--out DIR', 'Output root (target name is appended)') { |v| dest_root = v }
  end
  parser.parse!(argv)

  target = argv.shift
  unless target
    warn 'rh fetch: missing <target>'
    warn parser.help
    return 1
  end
  unless TARGETS.include?(target)
    warn "rh fetch: unknown target '#{target}'"
    warn "  valid: #{TARGETS.join(', ')}"
    return 1
  end

  url = "#{SITE_BASE}/browse/#{target}.tgz"
  dest = File.join(dest_root, target)
  if File.exist?(dest)
    warn "rh fetch: #{dest} already exists; remove it or pass --out elsewhere"
    return 1
  end

  warn "rh fetch: downloading #{url}"
  require 'open-uri'
  require 'zlib'
  require 'rubygems/package'

  count = 0
  begin
    URI.open(url) do |io|
      Zlib::GzipReader.wrap(io) do |gz|
        Gem::Package::TarReader.new(gz) do |tar|
          tar.each do |entry|
            rel = entry.full_name.sub(%r{\A#{Regexp.escape(target)}/}, '')
            next if rel.empty?
            path = File.join(dest, rel)
            if entry.directory?
              FileUtils.mkdir_p(path)
            elsif entry.file?
              FileUtils.mkdir_p(File.dirname(path))
              File.binwrite(path, entry.read)
              count += 1
            end
          end
        end
      end
    end
  rescue OpenURI::HTTPError => e
    warn "rh fetch: HTTP error: #{e.message}"
    warn "  (was the archive ever published? check #{SITE_BASE}/browse/)"
    return 1
  rescue SocketError, Errno::ECONNREFUSED => e
    warn "rh fetch: network error: #{e.message}"
    return 1
  end

  puts "rh fetch: wrote #{count} files to #{dest}"
  readme = File.join(dest, 'README.md')
  puts "  next: see #{readme}" if File.exist?(readme)
  0
end

# ---------------------------------------------------------------------
# Subcommand: fixture
#
# Wrap scripts/create-blog — the bash script that runs `rails new` +
# `rails generate scaffold` to produce a canonical Rails source app.
# Required by transpile/site as the input application.

def cmd_fixture(argv)
  force = false
  parser = OptionParser.new do |o|
    o.banner = 'Usage: bin/rh fixture [path]'
    o.separator ''
    o.separator 'Generate a Rails source fixture (wraps scripts/create-blog).'
    o.separator 'Default path: fixtures/real-blog'
    o.separator ''
    o.on('-f', '--force', 'Remove path first if it exists') { force = true }
  end
  parser.parse!(argv)
  path = argv.shift || 'fixtures/real-blog'

  unless version_of(probe('rails', '--version'))
    warn 'rh fixture: Rails gem not installed.'
    warn '  Install: gem install rails'
    warn '  (or run `bin/rh doctor` to see all prerequisites)'
    return 1
  end

  if File.exist?(path)
    if force
      warn "rh fixture: removing existing #{path}"
      FileUtils.rm_rf(path)
    else
      warn "rh fixture: #{path} already exists; pass -f to overwrite"
      return 1
    end
  end

  script = File.join(ROUNDHOUSE_ROOT, 'scripts', 'create-blog')
  unless File.executable?(script)
    warn "rh fixture: #{script} missing or not executable"
    return 1
  end

  # `rails new <path>` creates parent dirs as needed, and create-blog
  # does `cd "$APP_NAME"` so subsequent rails-generate steps run in
  # the new app dir. Pass `path` straight through.
  ok = system(script, path)
  return 1 unless ok

  # Match the legacy `make real-blog` post-create steps: ensure gems
  # are present, then migrate + seed the development DB so the
  # transpiled-blog seed copy carries real content.
  Dir.chdir(path) do
    return 1 unless system('bundle', 'install', '--quiet')
    return 1 unless system('bin/rails', 'db:prepare')
  end
  0
end

# ---------------------------------------------------------------------
# Subcommand: transpile
#
# `cargo run --release --bin roundhouse -- --target <t> -o <out>
# <fixture>` produces a runnable tree for <t>. Two targets need a
# post-build step:
#   - ruby:    seed the demo SQLite DB from real-blog's Rails-populated
#              storage/development.sqlite3 (binary; can't ride along
#              with the text-only emit).
#   - spinel:  compile sphttp.o (the FFI HTTP server's C extension)
#              and substitute its path into runtime/tep/net.rb.

def cmd_transpile(argv)
  OptionParser.new do |o|
    o.banner = 'Usage: bin/rh transpile <target>'
    o.separator ''
    o.separator "Transpile fixtures/real-blog → build/transpiled-blog-<target>/."
    o.separator ''
    o.separator "Targets: #{TARGETS.join(', ')}"
  end.parse!(argv)

  target = argv.shift
  unless target
    warn 'rh transpile: missing <target>'
    return 1
  end
  validate_target!(target)
  need_fixture!
  need_cargo!

  out = build_dir(target)
  FileUtils.rm_rf(out)
  FileUtils.mkdir_p(File.dirname(out))

  ok = system(
    'cargo', 'run', '--release', '--quiet', '--bin', 'roundhouse', '--',
    '--target', target, '-o', out, fixture_path
  )
  return 1 unless ok

  case target
  when 'ruby'       then post_transpile_ruby(out)
  when 'spinel'     then post_transpile_spinel(out)
  when 'crystal'    then post_transpile_crystal(out)
  when 'rust'       then post_transpile_rust(out)
  when 'typescript' then post_transpile_typescript(out)
  end
  0
end

# Ruby target's post-build: seed the demo DB. main.rb's Schema.load!
# is idempotent (CREATE TABLE IF NOT EXISTS), so the seed just gives
# the app three articles + comments out of the box. `bin/rh clean
# ruby` resets to seeded state.
def post_transpile_ruby(out)
  seed = File.join(fixture_path, 'storage', 'development.sqlite3')
  return unless File.exist?(seed)
  tmp = File.join(out, 'tmp')
  FileUtils.mkdir_p(tmp)
  FileUtils.cp(seed, File.join(tmp, 'blog.sqlite3'))
end

# Spinel target's post-build: compile the Tep FFI HTTP server's C
# extension, then sed-substitute the resulting path into net.rb (which
# ships with an @TEP_SPHTTP_O@ placeholder).
def post_transpile_spinel(out)
  tep_dir = File.join(out, 'runtime', 'tep')
  c_src = File.join(tep_dir, 'sphttp.c')
  o_out = File.join(tep_dir, 'sphttp.o')
  net_rb = File.join(tep_dir, 'net.rb')
  unless File.exist?(c_src)
    warn "rh transpile spinel: #{c_src} missing — extend spinel_files in src/project.rs"
    return
  end
  unless system('cc', '-O2', '-c', c_src, '-o', o_out)
    warn 'rh transpile spinel: cc failed'
    exit 1
  end
  if File.exist?(net_rb)
    content = File.read(net_rb)
    content.gsub!('@TEP_SPHTTP_O@', 'runtime/tep/sphttp.o')
    File.write(net_rb, content)
  end
end

# Crystal target's post-build: build Tailwind CSS and stage turbo.min.js
# into static/assets/, mirroring what the Ruby target's Rakefile does
# (compile via `npx @tailwindcss/cli`, copy turbo.min.js from the
# turbo-rails gem dir). The Crystal runtime's HTTP server serves
# `/assets/*` from `static/assets/` — see runtime/crystal/server.cr.
#
# Content glob for Tailwind is the transpiled `.cr` tree under
# build/transpiled-blog-crystal/src/ — the same place HTML strings get
# built into. `app/assets/tailwind.css` is a one-line `@import
# "tailwindcss";` (same shape as the ruby scaffold's).
def post_transpile_crystal(out)
  build_assets(
    out,
    label: 'crystal',
    content_globs: ['src/**/*.cr'],
  )
end

# Rust target's post-build: same shape as crystal — emit Tailwind input,
# compile via npx, copy turbo.min.js. The rust runtime serves
# `static/assets/` via tower-http's ServeDir mounted on /assets/ in
# runtime/rust/server.rs.
def post_transpile_rust(out)
  build_assets(
    out,
    label: 'rust',
    content_globs: ['src/**/*.rs'],
  )
end

# TypeScript target's post-build: same shape as crystal/rust. The TS
# runtime serves `static/assets/` via an inline static-file handler
# at the top of handleRequest (runtime/typescript/server.ts +
# server-libsql.ts). Content glob scans the emitted `app/**/*.ts`
# tree where view-rendering HTML strings live.
def post_transpile_typescript(out)
  build_assets(
    out,
    label: 'typescript',
    content_globs: ['app/**/*.ts'],
  )
end

# Shared asset-build helper. Emits app/assets/tailwind.css, compiles
# Tailwind via npx, and copies turbo.min.js from the turbo-rails gem.
# Warn-but-don't-fail on missing prereqs (npx, turbo-rails) so a
# user without the asset toolchain still gets a transpiled tree —
# they'll see unstyled pages instead of a broken transpile.
def build_assets(out, label:, content_globs:)
  static_assets = File.join(out, 'static', 'assets')
  FileUtils.mkdir_p(static_assets)
  app_assets = File.join(out, 'app', 'assets')
  FileUtils.mkdir_p(app_assets)

  tailwind_input = File.join(app_assets, 'tailwind.css')
  File.write(tailwind_input, "@import \"tailwindcss\";\n")

  # Tailwind v4 resolves `tailwindcss` from node_modules/ of the cwd,
  # so install it locally (--no-save: don't add to a package.json).
  # `.installed` stamp file means a re-transpile skips this step.
  stamp = File.join(out, 'node_modules', '.installed')
  unless File.exist?(stamp)
    warn "rh transpile #{label}: installing tailwindcss (one-time, ~5s)"
    unless system('npm', 'install', '--silent', '--no-save',
                  'tailwindcss', '@tailwindcss/cli',
                  chdir: out, out: File::NULL)
      warn "rh transpile #{label}: npm install failed (Node/npm required); skipping assets"
      return
    end
    FileUtils.mkdir_p(File.dirname(stamp))
    FileUtils.touch(stamp)
  end

  tailwind_output = File.join(static_assets, 'tailwind.css')
  npx_args = ['npx', '@tailwindcss/cli',
              '--input', tailwind_input,
              '--output', tailwind_output,
              '--minify']
  content_globs.each do |g|
    npx_args << '--content' << File.join(out, g)
  end

  warn "rh transpile #{label}: building tailwind.css"
  unless system(*npx_args, chdir: out, out: File::NULL)
    warn "rh transpile #{label}: tailwind build failed; skipping assets"
    return
  end

  # turbo.min.js — same resolution as the Ruby scaffold's Rakefile:
  # ask Bundler-managed Ruby for the turbo-rails gem's dir, then copy
  # the bundled minified file. Requires the fixture to have been
  # bundled (bin/rh fixture does `bundle install`).
  gem_dir = `cd #{fixture_path.shellescape} && bundle exec ruby -e 'puts Gem::Specification.find_by_name(%q(turbo-rails)).gem_dir' 2>/dev/null`.strip
  if gem_dir.empty? || !File.directory?(gem_dir)
    warn "rh transpile #{label}: turbo-rails gem not found; skipping turbo.min.js (cable client will fail to load in browser)"
    return
  end
  turbo_src = File.join(gem_dir, 'app', 'assets', 'javascripts', 'turbo.min.js')
  unless File.file?(turbo_src)
    warn "rh transpile #{label}: #{turbo_src} missing; skipping turbo.min.js"
    return
  end
  FileUtils.cp(turbo_src, File.join(static_assets, 'turbo.min.js'))
end

# ---------------------------------------------------------------------
# Subcommand: dev / test / run
#
# Transpile-and-act. The emitted tree's inner Makefile / Rakefile owns
# the action — bin/rh just cds in. Currently wired for the ruby target
# (rake-driven); other targets either don't have a dev/test action yet
# (spinel-AOT is build, not dev) or use their native runner directly
# (cd build/transpiled-blog-rust && cargo run).

def cmd_dev_test_run(argv, action)
  OptionParser.new do |o|
    o.banner = "Usage: bin/rh #{action} <target>"
    o.separator ''
    o.separator "Transpile <target>, then run `#{action}` in the emitted tree."
    o.separator 'Currently wired for ruby; other targets use their native runner.'
  end.parse!(argv)

  target = argv.shift
  unless target
    warn "rh #{action}: missing <target>"
    return 1
  end
  validate_target!(target)

  rc = cmd_transpile([target])
  return rc if rc != 0

  out = build_dir(target)
  case target
  when 'ruby'
    Dir.chdir(out) { system('rake', action) ? 0 : 1 }
  else
    warn "rh #{action}: target '#{target}' has no #{action} action yet."
    warn "  emitted dir: #{out}"
    warn "  see #{out}/README.md for the native command"
    1
  end
end

# ---------------------------------------------------------------------
# Subcommand: clean

def cmd_clean(argv)
  OptionParser.new do |o|
    o.banner = 'Usage: bin/rh clean <target | fixture>'
    o.separator ''
    o.separator "Remove build/transpiled-blog-<target>/, or fixtures/real-blog/ for `fixture`."
    o.separator ''
    o.separator "Targets: #{TARGETS.join(', ')}, fixture"
  end.parse!(argv)

  what = argv.shift
  unless what
    warn 'rh clean: missing <target | fixture>'
    return 1
  end

  case what
  when 'fixture'
    if File.exist?(fixture_path)
      FileUtils.rm_rf(fixture_path)
      puts "rh clean: removed #{fixture_path}"
    else
      puts 'rh clean: fixture already absent'
    end
    0
  else
    validate_target!(what)
    dir = build_dir(what)
    if File.exist?(dir)
      FileUtils.rm_rf(dir)
      puts "rh clean: removed #{dir}"
    else
      puts "rh clean: #{dir} already absent"
    end
    0
  end
end

# ---------------------------------------------------------------------
# Subcommand: compare — delegate to scripts/compare with passthrough.

def cmd_compare(argv)
  script = File.join(ROUNDHOUSE_ROOT, 'scripts', 'compare')
  unless File.executable?(script)
    warn "rh compare: #{script} missing or not executable"
    return 1
  end
  # Default target is typescript (matching the legacy `make compare`
  # rule). With any args (including `--help`), pass through verbatim
  # — scripts/compare has its own argument parser.
  args = argv.empty? ? ['typescript'] : argv
  exec(script, *args)
end

# ---------------------------------------------------------------------
# Subcommand: site — build the multi-target Pages site.

def cmd_site(argv)
  out = File.join(ROUNDHOUSE_ROOT, '_site')
  OptionParser.new do |o|
    o.banner = 'Usage: bin/rh site [--out DIR]'
    o.separator ''
    o.separator 'Build the multi-target archive site (all targets + landing-page assets).'
    o.on('--out DIR', 'Output directory (default: _site)') { |v| out = v }
  end.parse!(argv)
  need_fixture!
  need_cargo!
  system(
    'cargo', 'run', '--release', '--quiet', '--bin', 'roundhouse', '--',
    '--site', '-o', out, fixture_path
  ) ? 0 : 1
end

exit main(ARGV) if $PROGRAM_NAME == __FILE__
